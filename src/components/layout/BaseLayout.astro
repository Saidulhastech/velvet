---
import '../../styles/global.css';
import { Font } from 'astro:assets';
import Header from './Header.astro';
import Footer from './Footer.astro';
import CartDrawer from '../cart/CartDrawer.astro';
import WishlistDrawer from '../cart/WishlistDrawer.astro';
import QuickViewModal from '../cart/QuickViewModal.astro';
import { BRAND } from '../../config/velvet';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  /** Keep the page out of search indexes (account, cart, search). */
  noindex?: boolean;
  /** Extra JSON-LD schema.org objects to embed (Product, BreadcrumbList, …). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = "Maison Arden — Quiet luxury fashion. Considered wardrobe, refined materials, small-batch craftsmanship.",
  ogImage = "/og-image.jpg",
  canonicalUrl = Astro.url.href,
  noindex = false,
  jsonLd,
} = Astro.props;

// Localize the document language + og:locale from the active market.
const market = Astro.locals.market ?? { country: 'US', language: 'EN' };
const htmlLang = market.language.toLowerCase();
const ogLocale = `${market.language.toLowerCase()}_${market.country.toUpperCase()}`;

const fullTitle = `${title} — MAISON ARDEN`;
const ogImageUrl = new URL(ogImage, Astro.site ?? Astro.url).toString();

// Site-wide Organization + WebSite schema; pages may add more via `jsonLd`.
const baseSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: BRAND.name,
    url: (Astro.site ?? Astro.url).toString(),
    logo: ogImageUrl,
    sameAs: Object.values(BRAND.social),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: BRAND.name,
    url: (Astro.site ?? Astro.url).toString(),
  },
];
const schemas = [...baseSchema, ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [])];
---

<!DOCTYPE html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Title and Metas -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow" />}

    <!-- Open Graph / SEO -->
    <meta property="og:site_name" content={BRAND.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Canonical Link -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Self-hosted fonts (no external render-blocking request) -->
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-cormorant" preload />

    <!-- Icons + theme -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/og-image.jpg" />
    <meta name="theme-color" content="#30382C" />

    <!-- Structured data -->
    {schemas.map((s) => <script type="application/ld+json" is:inline set:html={JSON.stringify(s)} />)}
  </head>

  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <!-- Cart Overlay Backdrop -->
    <div class="drawer-overlay" data-drawer-overlay aria-hidden="true"></div>
    
    <!-- Navigation & Header -->
    <Header />
    
    <!-- Main Content Slot -->
    <main id="main-content">
      <slot />
    </main>
    
    <!-- Footer -->
    <Footer />
    
    <!-- Interactive Drawers and Modals -->
    <CartDrawer />
    <WishlistDrawer />
    <QuickViewModal />

    <!-- Global Client side scripts for animation triggers, scroll listening, etc. -->
    <script>
      import { addToCart, toggleWishlist, persistedWishItems, toggleCompare, persistedCompareItems } from '../../stores/cart';

      // Scroll listener for sticky header shading
      const header = document.getElementById('siteHeader');
      const onScroll = () => {
        if (header) {
          header.classList.toggle('is-scrolled', window.scrollY > 8);
        }
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      // Intersection Observer for scroll reveal animations
      const revealElements = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('in');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.14 });
        revealElements.forEach(el => observer.observe(el));
      } else {
        revealElements.forEach(el => el.classList.add('in'));
      }

      // Swatch selection click handler
      document.addEventListener('click', (e) => {
        const sw = (e.target as HTMLElement).closest('.pc__sw') as HTMLElement | null;
        if (sw) {
          const swatchesWrap = sw.parentElement;
          if (swatchesWrap) {
            swatchesWrap.querySelectorAll('.pc__sw').forEach(x => x.classList.remove('is-active'));
            sw.classList.add('is-active');
          }
          const card = sw.closest('.pc') as HTMLElement | null;
          if (card) {
            const imgUrl = sw.dataset.img;
            const mainImg = card.querySelector('.pc__media img') as HTMLImageElement | null;
            if (imgUrl && mainImg) {
              mainImg.src = imgUrl;
              mainImg.srcset = '';
            }
            const vId = sw.dataset.variantId;
            const addBtn = card.querySelector('[data-add-bag]');
            if (vId && addBtn) {
              addBtn.setAttribute('data-id', vId);
            }
          }
        }
      });

      // Global Add to Bag click listener
      document.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const addBagBtn = target.closest('[data-add-bag]');
        if (addBagBtn) {
          // If it's a multi-add button (e.g., ShopTheLook), don't process it here
          if (addBagBtn.hasAttribute('data-ids')) return;

          e.preventDefault();
          const card = addBagBtn.closest('.pc') as HTMLElement | null;
          if (card) {
            // Multi-option product (e.g. Colour + Size) → open Quick View to pick a
            // size and resolve the real variant, instead of adding the wrong one.
            if (card.dataset.needsPicker === 'true') {
              (card.querySelector('[data-qv]') as HTMLElement | null)?.click();
              return;
            }
            const dataset = card.dataset;
            const priceNum = parseFloat((dataset.price || '').replace(/[^0-9.]/g, '')) || 0;
            const resolvedImg = dataset.img || '';
            const activeSwatch = card.querySelector('.pc__sw.is-active') as HTMLElement | null;
            const color = activeSwatch ? activeSwatch.dataset.color : undefined;
            const swatchImg = activeSwatch ? activeSwatch.dataset.img : undefined;
            // Colour-only / single-variant: the active swatch's variant (or the
            // product's first variant) is the correct one; no size to choose.
            const variantId = addBagBtn.getAttribute('data-id') || dataset.id || '';

            addToCart({
              id: variantId,
              name: dataset.name || '',
              price: priceNum,
              image: swatchImg || (resolvedImg.startsWith('/src/assets/') ? resolvedImg.split('/').pop() || '' : resolvedImg),
              color: color || undefined,
              size: undefined,
              description: dataset.handle || ''
            }, 1);
          }
        }

        // Global Wishlist Toggle click listener
        const wishBtn = target.closest('[data-wish-add]');
        if (wishBtn) {
          e.preventDefault();
          const card = wishBtn.closest('.pc') as HTMLElement | null;
          if (card) {
            const dataset = card.dataset;
            const priceNum = parseFloat((dataset.price || '').replace(/[^0-9.]/g, '')) || 0;
            const resolvedImg = dataset.img || '';
            const activeSwatch = card.querySelector('.pc__sw.is-active') as HTMLElement | null;
            const color = activeSwatch ? activeSwatch.dataset.color : undefined;
            let variants: any[] = [];
            let options: any[] = [];
            try { variants = dataset.variants ? JSON.parse(dataset.variants) : []; } catch { variants = []; }
            try { options = dataset.options ? JSON.parse(dataset.options) : []; } catch { options = []; }
            // Snapshot each swatch's real rendered colour (card CSS, not a
            // Shopify metafield on this store) so the wishlist drawer's inline
            // picker can reuse the exact same swatch colours as the grid.
            const swatchHex: Record<string, string> = {};
            card.querySelectorAll<HTMLElement>('.pc__sw').forEach((sw) => {
              const c = sw.dataset.color?.toLowerCase();
              if (c) swatchHex[c] = sw.style.backgroundColor || sw.style.background || '#858A76';
            });

            toggleWishlist({
              id: dataset.id || '',
              name: dataset.name || '',
              price: priceNum,
              image: resolvedImg.startsWith('/src/assets/') ? resolvedImg.split('/').pop() || '' : resolvedImg,
              color: color || undefined,
              size: undefined,
              category: dataset.cat || '',
              description: dataset.handle || '',
              needsPicker: dataset.needsPicker === 'true',
              variants,
              options,
              swatchHex
            });
          }
        }

        // Global Compare Toggle click listener
        const compareBtn = target.closest('[data-compare-add]');
        if (compareBtn) {
          e.preventDefault();
          const card = compareBtn.closest('.pc') as HTMLElement | null;
          if (card) {
            const dataset = card.dataset;
            const priceNum = parseFloat((dataset.price || '').replace(/[^0-9.]/g, '')) || 0;
            const resolvedImg = dataset.img || '';
            toggleCompare({
              id: dataset.id || '',
              handle: dataset.handle || '',
              name: dataset.name || '',
              price: priceNum,
              formattedPrice: dataset.price || '',
              image: resolvedImg.startsWith('/src/assets/') ? resolvedImg.split('/').pop() || '' : resolvedImg,
              category: dataset.cat || '',
              rating: parseFloat(dataset.rating || '') || undefined,
              material: (dataset.material || '').split(' ')[0] || undefined,
              sizes: dataset.size || undefined,
              stock: dataset.stock || undefined,
              needsPicker: dataset.needsPicker === 'true',
            });
          }
        }
      });

      // Sync wishlist buttons aria-pressed
      persistedWishItems.subscribe((items) => {
        const savedIds = new Set(items.map(i => i.id));
        document.querySelectorAll('[data-wish-add]').forEach((btnEl) => {
          const btn = btnEl as HTMLElement;
          const card = btn.closest('.pc') as HTMLElement | null;
          if (card) {
            const id = card.dataset.id || '';
            btn.setAttribute('aria-pressed', String(savedIds.has(id)));
          }
        });
      });

      // Sync compare buttons aria-pressed
      persistedCompareItems.subscribe((items) => {
        const ids = new Set(items.map(i => i.id));
        document.querySelectorAll('[data-compare-add]').forEach((btnEl) => {
          const btn = btnEl as HTMLElement;
          const card = btn.closest('.pc') as HTMLElement | null;
          if (card) btn.setAttribute('aria-pressed', String(ids.has(card.dataset.id || '')));
        });
      });

      // Newsletter forms — validate the email + show inline success feedback
      // (site-wide, any .news__form). No markup change: reuses existing hooks.
      document.addEventListener('submit', (e) => {
        const form = (e.target as HTMLElement)?.closest?.('.news__form') as HTMLFormElement | null;
        if (!form) return;
        e.preventDefault();
        const input = form.querySelector('.news__input') as HTMLInputElement | null;
        const btn = form.querySelector('.news__btn') as HTMLButtonElement | null;
        const email = (input?.value || '').trim();
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          input?.setAttribute('aria-invalid', 'true');
          input?.focus();
          return;
        }
        input?.removeAttribute('aria-invalid');
        if (btn) {
          const orig = btn.textContent;
          btn.textContent = '✓ Subscribed';
          btn.disabled = true;
          if (input) input.value = '';
          setTimeout(() => { btn.textContent = orig; btn.disabled = false; }, 4000);
        }
      });
    </script>
    
    <style is:global>
      /* Skip-to-content link — visible on keyboard focus */
      .skip-link {
        position: fixed;
        top: 8px;
        left: 8px;
        z-index: 200;
        transform: translateY(-150%);
        background: var(--lux-primary-dark, #30382C);
        color: #fff;
        padding: 10px 16px;
        border-radius: 4px;
        font-size: 13px;
        font-weight: 600;
        transition: transform 0.2s ease;
      }

      .skip-link:focus {
        transform: translateY(0);
        outline: 2px solid var(--lux-accent-lime, #E7EC78);
      }

      /* Drawer Overlay Backdrop Styling */
      .drawer-overlay {
        position: fixed;
        inset: 0;
        background: rgba(23, 26, 21, 0.5);
        z-index: 99;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.4s var(--ease), visibility 0s linear 0.4s;
      }
      
      .drawer-overlay.is-open {
        opacity: 1;
        visibility: visible;
        transition: opacity 0.4s var(--ease);
      }
    </style>
  </body>
</html>
