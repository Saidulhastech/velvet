<style>
.footer {
  position: relative;
  background: var(--lux-bg-dark);
  color: var(--lux-text-secondary);
  overflow: hidden;
}

.footer__top {
  max-width: var(--maxw);
  margin: 0 auto;
  padding: clamp(56px, 7vw, 100px) var(--gutter) clamp(34px, 4vw, 52px);
  display: grid;
  grid-template-columns: 1.8fr 1fr 1fr 1fr;
  gap: clamp(28px, 4vw, 60px);
}

.footer__brand-mark {
  font-family: var(--font-display);
  font-size: 26px;
  font-weight: 500;
  letter-spacing: 6px;
  color: var(--lux-text-primary);
}

.footer__brand-sub {
  font-size: 8px;
  font-weight: 600;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--lux-text-secondary);
  margin-top: 8px;
}

.footer__brand-text {
  font-size: 14px;
  line-height: 1.7;
  color: var(--lux-text-secondary);
  max-width: 36ch;
  margin: 22px 0 22px;
}

.footer__contact {
  display: flex;
  flex-direction: column;
  gap: 9px;
  margin-bottom: 22px;
}

.footer__contact a {
  font-size: 13px;
  color: var(--lux-text-soft);
  display: inline-flex;
  align-items: center;
  gap: 9px;
  transition: color .22s var(--ease);
}

.footer__contact a:hover {
  color: var(--lux-accent-lime);
}

.footer__contact svg {
  color: var(--lux-secondary-olive);
  flex-shrink: 0;
}

.footer__social {
  display: flex;
  gap: 10px;
}

.footer__social a {
  width: 38px;
  height: 38px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--lux-border);
  border-radius: 50%;
  color: var(--lux-text-soft);
  transition: background .25s var(--ease), color .25s var(--ease), border-color .25s var(--ease), transform .25s var(--ease);
}

.footer__social a:hover {
  background: var(--lux-accent-lime);
  color: var(--lux-bg-dark);
  border-color: var(--lux-accent-lime);
  transform: translateY(-3px);
}

.footer__col h4 {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 1.6px;
  text-transform: uppercase;
  color: var(--lux-text-primary);
  margin: 0 0 18px;
}

.footer__col ul {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.footer__col a {
  font-size: 14px;
  color: var(--lux-text-secondary);
  transition: color .22s var(--ease), padding-left .22s var(--ease);
}

.footer__col a:hover {
  color: var(--lux-accent-lime);
  padding-left: 5px;
}

.footer__visit {
  max-width: var(--maxw);
  margin: 0 auto;
  padding: clamp(22px, 2.5vw, 30px) var(--gutter);
  border-top: 1px solid var(--lux-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  flex-wrap: wrap;
}

.footer__visit-text {
  font-family: var(--font-display);
  font-style: italic;
  font-size: clamp(18px, 1.8vw, 24px);
  color: var(--lux-text-soft);
}

.footer__visit-text span {
  color: var(--lux-accent-lime);
}

.footer__appt {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 13px 26px;
  background: var(--lux-accent-hover);
  border: 1px solid var(--lux-accent-hover);
  border-radius: 0;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: var(--lux-bg-dark);
  transition: background .28s var(--ease), color .28s var(--ease), border-color .28s var(--ease);
}

.footer__appt:hover {
  background: transparent;
  color: var(--lux-text-primary);
  border-color: var(--lux-border);
}

.footer__wordmark {
  font-family: var(--font-display);
  font-weight: 500;
  text-align: center;
  white-space: nowrap;
  font-size: clamp(58px, 15.5vw, 236px);
  line-height: .82;
  letter-spacing: clamp(2px, .8vw, 10px);
  color: transparent;
  -webkit-text-stroke: 1px rgba(231, 236, 120, .22);
  margin: clamp(8px, 1.5vw, 18px) 0 clamp(-6px, -.5vw, -2px);
  padding: 0 var(--gutter);
  user-select: none;
  pointer-events: none;
}

.footer__bottom {
  border-top: 1px solid var(--lux-border);
}

.footer__bottom-inner {
  max-width: var(--maxw);
  margin: 0 auto;
  padding: 22px var(--gutter);
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 14px;
}

.footer__copy {
  font-size: 12px;
  color: var(--lux-text-secondary);
}

.footer__pay {
  display: flex;
  align-items: center;
  gap: 8px;
}

.footer__pay span {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--lux-text-secondary);
  border: 1px solid var(--lux-border);
  padding: 5px 9px;
  border-radius: 0;
}

.footer__legal {
  display: flex;
  align-items: center;
  gap: 22px;
  flex-wrap: wrap;
}

.footer__legal a {
  font-size: 12px;
  color: var(--lux-text-secondary);
  transition: color .22s var(--ease);
}

.footer__legal a:hover {
  color: var(--lux-text-soft);
}

.footer__totop {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: var(--lux-text-primary);
}

.footer__totop svg {
  transition: transform .25s var(--ease);
}

.footer__totop:hover svg {
  transform: translateY(-3px);
}

@media (max-width: 860px) {
  .footer__top {
    grid-template-columns: 1fr 1fr;
    gap: 38px 28px;
  }
  .footer__visit {
    flex-direction: column;
    align-items: flex-start;
  }
}

@media (max-width: 520px) {
  .footer__top {
    grid-template-columns: 1fr;
  }
  .footer__bottom-inner {
    flex-direction: column;
    align-items: flex-start;
  }
}
</style>
