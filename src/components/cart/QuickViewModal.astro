---
// QuickViewModal component. Triggers overlay modal with product quick detail options.
---

<!-- Overlay backdrop -->
<div class="qv-overlay" id="qvOverlay" data-qv-overlay aria-hidden="true"></div>

<!-- Modal Dialog -->
<div class="qv-modal" id="qvModal" role="dialog" aria-modal="true" aria-label="Quick view" aria-hidden="true">
  <!-- Media section (Left) -->
  <div class="qv__media">
    <button class="qv__close" id="qvCloseBtn" aria-label="Close modal">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M3 3l12 12M15 3L3 15" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
      </svg>
    </button>
    <img id="qvImg" src="" alt="Product Showcase" />
  </div>

  <!-- Detail Content (Right) -->
  <div class="qv__body">
    <span class="qv__cat" id="qvCat">Collection</span>
    <h3 class="qv__name" id="qvName">Product Name</h3>
    <div class="qv__price">
      <span id="qvPrice">€0</span>
      <span class="qv__rating" id="qvRating">★ 0.0</span>
    </div>
    
    <div class="qv__rule"></div>
    <p class="qv__desc" id="qvDesc">Description text goes here...</p>
    
    <!-- Color Swatches selection -->
    <div class="qv__label" id="qvColorLabel">Colour</div>
    <div class="qv__swatches" id="qvSwatches">
      <!-- Populated via script -->
    </div>

    <!-- Second option (Size / Material / …) — label set dynamically -->
    <div class="qv__label" id="qvSizeLabel">Size</div>
    <div class="qv__sizes" id="qvSizes">
      <!-- Populated via script -->
    </div>
    
    <!-- Action buttons -->
    <div class="qv__actions">
      <button class="btn-primary qv__add" id="qvAddToCartBtn">
        Add to Bag 
        <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
          <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"></path>
        </svg>
      </button>
      <button class="qv__wish" id="qvWishlistBtn" aria-label="Save to wishlist" aria-pressed="false">
        <svg width="18" height="18" viewBox="0 0 22 22" fill="none">
          <path d="M11 19S3 14 3 8.3C3 5.5 5.2 3.5 8 3.5c1.6 0 3 .8 4 2 1-1.2 2.4-2 4-2 2.8 0 5 2 5 4.8C21 14 13 19 11 19z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"></path>
        </svg>
      </button>
    </div>
  </div>
</div>

<script>
  import { addToCart, toggleWishlist, persistedWishItems } from '../../stores/cart';
  import { shopifyImageUrl } from '../../lib/shopify/image-url';

  // Quick View media panel renders at ~600px — cap remote (Shopify CDN)
  // images to that instead of shipping full-resolution originals.
  const qvResize = (src: string) => /^https?:\/\//.test(src) ? shopifyImageUrl(src, 600, 750) : src;

  const overlay = document.getElementById('qvOverlay');
  const modal = document.getElementById('qvModal');
  const closeBtn = document.getElementById('qvCloseBtn');
  const qvImg = document.getElementById('qvImg') as HTMLImageElement | null;
  const qvCat = document.getElementById('qvCat');
  const qvName = document.getElementById('qvName');
  const qvPrice = document.getElementById('qvPrice');
  const qvRating = document.getElementById('qvRating');
  const qvDesc = document.getElementById('qvDesc');
  const qvSwatches = document.getElementById('qvSwatches');
  const qvSizes = document.getElementById('qvSizes');
  const qvColorLabel = document.getElementById('qvColorLabel');
  const qvSizeLabel = document.getElementById('qvSizeLabel');
  const addToCartBtn = document.getElementById('qvAddToCartBtn');
  const wishlistBtn = document.getElementById('qvWishlistBtn');

  // Currently opened product data reference
  let currentProduct: {
    id: string;
    name: string;
    price: number;
    image: string;
    category?: string;
    handle?: string;
  } | null = null;

  let selectedColor = '';
  let selectedSize = '';
  // Element focused before the modal opened, restored on close (a11y).
  let lastFocused: HTMLElement | null = null;

  // Trap Tab focus within the modal while it's open.
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab' || !modal?.classList.contains('is-open')) return;
    const f = Array.from(modal.querySelectorAll<HTMLElement>(
      'a[href],button:not([disabled]),input,textarea,select,[tabindex]:not([tabindex="-1"])'
    )).filter((el) => el.offsetParent !== null);
    if (!f.length) return;
    const first = f[0], last = f[f.length - 1];
    if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
    else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
  });

  // ---- Real variant matrix state (size×colour → specific Shopify variant) ----
  let qvVariants: any[] = [];
  let qvOptions: any[] = [];
  let qvSwatchHex: Record<string, string> = {};
  let qvSelected: Record<string, string> = {};
  let qvColorKey = '';
  let qvSizeKey = '';
  let qvSymbol = '$';

  const qvMoney = (n: number) => `${qvSymbol}${n.toLocaleString('en-US', {
    minimumFractionDigits: Number.isInteger(n) ? 0 : 2,
    maximumFractionDigits: 2,
  })}`;

  function qvCurrentVariant() {
    if (!qvVariants.length) return null;
    return qvVariants.find((v) => Object.keys(qvSelected).every((k) => v.opts[k] === qvSelected[k])) || null;
  }
  function qvOptionAvailable(key: string, value: string) {
    const trial = { ...qvSelected, [key]: value };
    return qvVariants.some((v) => v.available && Object.keys(trial).every((k) => v.opts[k] === trial[k]));
  }
  // Recompute price / image / availability / add-button from the current selection.
  function qvResolve() {
    if (!qvVariants.length) return;
    const v = qvCurrentVariant();
    if (qvPrice) qvPrice.textContent = v ? qvMoney(v.price) : 'Unavailable';
    if (v?.img && qvImg) qvImg.src = qvResize(v.img);
    if (qvColorKey) selectedColor = qvSelected[qvColorKey] || selectedColor;
    if (qvSizeKey) selectedSize = qvSelected[qvSizeKey] || selectedSize;
    if (addToCartBtn) (addToCartBtn as HTMLButtonElement).disabled = !(v && v.available);
    // Dawn-style grey-out of values with no available variant given the rest.
    qvSwatches?.querySelectorAll('.qv__sw').forEach((el) => {
      const val = (el as HTMLElement).dataset.value || '';
      el.classList.toggle('is-unavailable', !!qvColorKey && !qvOptionAvailable(qvColorKey, val));
    });
    qvSizes?.querySelectorAll('.qv__size').forEach((el) => {
      const val = (el as HTMLElement).dataset.value || '';
      const ok = !qvSizeKey || qvOptionAvailable(qvSizeKey, val);
      (el as HTMLButtonElement).disabled = !ok;
      el.classList.toggle('is-oos', !ok);
    });
  }

  function openQV(card: HTMLElement) {
    if (!modal || !overlay || !qvImg || !qvCat || !qvName || !qvPrice || !qvRating || !qvDesc || !qvSwatches || !qvSizes || !wishlistBtn) return;

    const dataset = card.dataset;
    const priceNum = parseFloat((dataset.price || '').replace(/[^0-9.]/g, '')) || 0;
    const resolvedImg = dataset.img || '';

    // Assign reference
    currentProduct = {
      id: dataset.id || 'p-' + Math.random().toString(36).substr(2, 9),
      name: dataset.name || '',
      price: priceNum,
      image: resolvedImg,
      category: dataset.cat || '',
      handle: dataset.handle || ''
    };

    // Update Text Elements
    qvImg.src = resolvedImg.startsWith('Images/') ? `/src/assets/images/${resolvedImg.split('/').pop()}` : qvResize(resolvedImg);
    qvImg.alt = dataset.name || 'Product Image';
    qvCat.textContent = dataset.cat || 'Collection';
    qvName.textContent = dataset.name || 'Product';
    qvPrice.textContent = dataset.price || '€0';
    if (dataset.rating) {
      qvRating.textContent = '★ ' + dataset.rating;
      qvRating.style.display = '';
    } else {
      qvRating.style.display = 'none';
    }
    if (dataset.desc) {
      qvDesc.textContent = dataset.desc;
      qvDesc.style.display = '';
    } else {
      qvDesc.style.display = 'none';
    }

    // ---- Pickers: prefer the real variant matrix, fall back to card swatches ----
    qvVariants = [];
    qvColorKey = ''; qvSizeKey = '';
    try { qvVariants = dataset.variants ? JSON.parse(dataset.variants) : []; } catch { qvVariants = []; }
    let optionData: any[] = [];
    try { optionData = dataset.options ? JSON.parse(dataset.options) : []; } catch { optionData = []; }
    qvOptions = optionData;
    qvSwatchHex = {};
    qvSymbol = (String(dataset.price || '').match(/^[^\d.,]+/) || ['$'])[0];

    if (qvVariants.length) {
      const optNames = Object.keys(qvVariants[0].opts || {}).filter((n) => !/^title$/i.test(n));
      qvColorKey = optNames.find((n) => /colou?r/i.test(n)) || '';
      // Second dimension: prefer Size, else the first non-colour option (Material, …).
      qvSizeKey = optNames.find((n) => /size/i.test(n)) || optNames.find((n) => n !== qvColorKey) || '';
      // Reflect the real option name + hide inapplicable groups.
      if (qvSizeLabel) { qvSizeLabel.textContent = qvSizeKey || 'Options'; (qvSizeLabel as HTMLElement).style.display = qvSizeKey ? '' : 'none'; }
      if (qvSizes) (qvSizes as HTMLElement).style.display = qvSizeKey ? '' : 'none';
      if (qvColorLabel) (qvColorLabel as HTMLElement).style.display = qvColorKey ? '' : 'none';
      if (qvSwatches) (qvSwatches as HTMLElement).style.display = qvColorKey ? '' : 'none';
      const hexMap: Record<string, string> = {};
      (optionData.find((o: any) => /colou?r/i.test(o.name))?.values || []).forEach((cv: any) => { if (cv.color) hexMap[cv.name] = cv.color; });
      // Shopify's colour swatch metafield is often left unconfigured by the
      // merchant — reuse the card's already-resolved hex (real swatch → curated
      // palette → neutral grey, see mapToLegacyProduct) instead of rendering blank.
      const cardHexMap: Record<string, string> = {};
      card.querySelectorAll<HTMLElement>('.pc__sw').forEach((sw) => {
        const name = (sw.dataset.color || '').toLowerCase();
        const hex = sw.style.backgroundColor;
        if (name && hex) cardHexMap[name] = hex;
      });
      qvSwatchHex = cardHexMap;
      const seed = qvVariants.find((v) => v.available) || qvVariants[0];
      qvSelected = { ...seed.opts };
      selectedColor = qvColorKey ? qvSelected[qvColorKey] : '';
      selectedSize = qvSizeKey ? qvSelected[qvSizeKey] : '';

      const distinct = (key: string) => {
        const seen: string[] = [];
        qvVariants.forEach((v) => { const val = v.opts[key]; if (val && !seen.includes(val)) seen.push(val); });
        return seen;
      };
      const colors = qvColorKey ? distinct(qvColorKey) : [];
      const sizeVals = qvSizeKey ? distinct(qvSizeKey) : [];

      qvSwatches.innerHTML = colors.map((c) =>
        `<span class="qv__sw ${qvSelected[qvColorKey] === c ? 'is-active' : ''}" data-value="${c}" style="background:${hexMap[c] || cardHexMap[c.toLowerCase()] || '#858A76'}" title="${c}"></span>`
      ).join('');
      qvSizes.innerHTML = sizeVals.map((s) =>
        `<button class="qv__size ${qvSelected[qvSizeKey] === s ? 'is-active' : ''}" data-value="${s}">${s.toUpperCase()}</button>`
      ).join('');

      qvSwatches.querySelectorAll('.qv__sw').forEach((sw) => sw.addEventListener('click', () => {
        if (sw.classList.contains('is-unavailable')) return;
        qvSwatches.querySelectorAll('.qv__sw').forEach(x => x.classList.remove('is-active'));
        sw.classList.add('is-active');
        if (qvColorKey) qvSelected[qvColorKey] = sw.getAttribute('data-value') || '';
        qvResolve();
      }));
      qvSizes.querySelectorAll('.qv__size').forEach((sz) => sz.addEventListener('click', () => {
        if ((sz as HTMLButtonElement).disabled) return;
        qvSizes.querySelectorAll('.qv__size').forEach(x => x.classList.remove('is-active'));
        sz.classList.add('is-active');
        if (qvSizeKey) qvSelected[qvSizeKey] = sz.getAttribute('data-value') || '';
        qvResolve();
      }));

      qvResolve();
    } else {
      // Fallback: products without a real variant matrix — clone card swatches + size strings.
      const cardSwatches = Array.from(card.querySelectorAll('.pc__sw')) as HTMLElement[];
      if (qvColorLabel) (qvColorLabel as HTMLElement).style.display = cardSwatches.length ? '' : 'none';
      if (qvSwatches) (qvSwatches as HTMLElement).style.display = cardSwatches.length ? '' : 'none';
      selectedColor = cardSwatches[0]?.dataset.color || '';
      qvSwatches.innerHTML = cardSwatches.map((sw, idx) => {
        const col = sw.dataset.color || '';
        const hex = sw.style.backgroundColor || '';
        const vId = sw.dataset.variantId || '';
        const img = sw.dataset.img || '';
        return `<span class="qv__sw ${idx === 0 ? 'is-active' : ''}" data-value="${col}" data-variant-id="${vId}" data-img="${img}" style="background:${hex}" title="${col}"></span>`;
      }).join('');
      qvSwatches.querySelectorAll('.qv__sw').forEach((sw) => {
        sw.addEventListener('click', () => {
          qvSwatches.querySelectorAll('.qv__sw').forEach(x => x.classList.remove('is-active'));
          sw.classList.add('is-active');
          selectedColor = sw.getAttribute('data-value') || '';
          const imgUrl = sw.getAttribute('data-img');
          if (imgUrl && qvImg) qvImg.src = qvResize(imgUrl);
        });
      });

      const sizes = (dataset.size || '').split('|').filter(Boolean);
      if (qvSizeLabel) (qvSizeLabel as HTMLElement).style.display = sizes.length ? '' : 'none';
      if (qvSizes) (qvSizes as HTMLElement).style.display = sizes.length ? '' : 'none';
      selectedSize = sizes[0] || '';
      qvSizes.innerHTML = sizes.map((size, idx) =>
        `<button class="qv__size ${idx === 0 ? 'is-active' : ''}" data-value="${size}">${size.toUpperCase()}</button>`
      ).join('');
      qvSizes.querySelectorAll('.qv__size').forEach((sz) => {
        sz.addEventListener('click', () => {
          qvSizes.querySelectorAll('.qv__size').forEach(x => x.classList.remove('is-active'));
          sz.classList.add('is-active');
          selectedSize = sz.getAttribute('data-value') || '';
        });
      });
    }

    // Sync wishlist button icon state
    const isSaved = persistedWishItems.get().some(item => item.id === currentProduct?.id);
    wishlistBtn.setAttribute('aria-pressed', String(isSaved));

    // Reflect availability — for matrix products qvResolve() already set this
    // per-variant; only fall back to the product-level stock flag otherwise.
    if (addToCartBtn && !qvVariants.length) {
      (addToCartBtn as HTMLButtonElement).disabled = (dataset.stock || 'in') !== 'in';
    }

    // Show Modal
    lastFocused = document.activeElement as HTMLElement | null;
    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.classList.add('no-scroll');
    requestAnimationFrame(() => (closeBtn as HTMLElement | null)?.focus());
  }

  function closeQV() {
    if (!overlay || !modal) return;
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');

    // Only unlock scroll if cart drawer is also closed
    const isCartOpen = document.getElementById('cartDrawer')?.classList.contains('is-open');
    const isWishlistOpen = document.getElementById('wishDrawer')?.classList.contains('is-open');
    if (!isCartOpen && !isWishlistOpen) {
      document.body.classList.remove('no-scroll');
    }

    // Restore focus to the element that opened the modal.
    lastFocused?.focus();
  }

  // Bind Open Trigger globally across the DOM. Data source is the product card
  // (`.pc`) or any element flagged `data-qv-source` (e.g. Shop the Look rows).
  document.addEventListener('click', (e) => {
    const trigger = (e.target as HTMLElement).closest('[data-qv]');
    if (trigger) {
      e.preventDefault();
      const card = trigger.closest('.pc, [data-qv-source]') as HTMLElement | null;
      if (card) openQV(card);
    }
  });

  // Bind Close triggers
  closeBtn?.addEventListener('click', closeQV);
  overlay?.addEventListener('click', closeQV);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeQV();
  });

  // Resolve the add-to-cart target: the real size×colour variant when the matrix
  // is present, else the active swatch's variant / product id (fallback).
  function qvResolveTarget(): { id: string; price: number; image: string } | null {
    if (qvVariants.length) {
      const v = qvCurrentVariant();
      if (!v || !v.available) return null; // unresolved / out of stock
      return { id: v.id, price: v.price, image: v.img || currentProduct!.image };
    }
    const activeSwatch = qvSwatches?.querySelector('.qv__sw.is-active') as HTMLElement | null;
    return {
      id: activeSwatch?.getAttribute('data-variant-id') || currentProduct!.id,
      price: currentProduct!.price,
      image: activeSwatch?.getAttribute('data-img') || currentProduct!.image,
    };
  }

  // Add to Bag action inside Modal
  addToCartBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    if (!currentProduct) return;
    const target = qvResolveTarget();
    if (!target) return; // matrix product with no valid variant selected

    addToCart({
      id: target.id,
      name: currentProduct.name,
      price: target.price,
      image: target.image,
      color: selectedColor || undefined,
      size: selectedSize || undefined,
      description: (currentProduct as any).handle || ''
    }, 1);

    closeQV();
  });

  // Toggle Wishlist action inside Modal
  wishlistBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    if (!currentProduct) return;
    const target = qvResolveTarget();
    const id = target?.id || currentProduct.id;

    toggleWishlist({
      id,
      name: currentProduct.name,
      price: target?.price ?? currentProduct.price,
      image: target?.image || currentProduct.image,
      color: selectedColor || undefined,
      size: selectedSize || undefined,
      category: currentProduct.category,
      description: (currentProduct as any).handle || '',
      variants: qvVariants,
      options: qvOptions,
      swatchHex: qvSwatchHex,
      // Modal already has these rendered (from openQV) — reuse rather than
      // re-deriving, so wishlisting from inside quick view carries them too.
      desc: qvDesc?.textContent || undefined,
      rating: qvRating && (qvRating as HTMLElement).style.display !== 'none'
        ? parseFloat((qvRating.textContent || '').replace(/[^\d.]/g, '')) || undefined
        : undefined,
    });

    const isSaved = wishlistBtn.getAttribute('aria-pressed') === 'true';
    wishlistBtn.setAttribute('aria-pressed', String(!isSaved));
  });
</script>

<style>
  /* Quick View Modal and overlay styling ported directly from V02 HTML codebase */
  .qv-overlay {
    position: fixed;
    inset: 0;
    background: rgba(15, 18, 13, .65);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    z-index: 110;
    opacity: 0;
    visibility: hidden;
    transition: opacity .35s var(--ease), visibility 0s linear .35s;
  }

  .qv-overlay.is-open {
    opacity: 1;
    visibility: visible;
    transition: opacity .35s var(--ease);
  }

  .qv-modal {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -46%) scale(.96);
    width: min(94vw, 840px);
    aspect-ratio: 16/10.5;
    background: var(--lux-light-elevated);
    border: 1px solid var(--lux-light-border);
    z-index: 115;
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    opacity: 0;
    visibility: hidden;
    transition: opacity .38s var(--ease), transform .38s var(--ease), visibility 0s linear .38s;
    box-shadow: 0 38px 90px -20px rgba(15, 18, 13, .45);
  }

  .qv-modal.is-open {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, -50%) scale(1);
    transition: opacity .38s var(--ease), transform .38s var(--ease);
  }

  .qv__media {
    position: relative;
    height: 100%;
    overflow: hidden;
    background: var(--lux-light-surface);
  }

  .qv__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .qv__close {
    position: absolute;
    top: 16px;
    left: 16px;
    z-index: 5;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(252, 252, 248, .88);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
    border: 1px solid var(--lux-light-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--lux-on-light);
    transition: background .25s var(--ease), color .25s var(--ease), border-color .25s var(--ease);
  }

  .qv__close:hover {
    background: var(--lux-primary-dark);
    color: var(--lux-text-primary);
    border-color: var(--lux-primary-dark);
  }

  .qv__body {
    padding: clamp(24px, 3.5vw, 42px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow-y: auto;
  }

  .qv__cat {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--lux-on-light-soft);
  }

  .qv__name {
    font-family: var(--font-display);
    font-size: clamp(24px, 2.5vw, 36px);
    font-weight: 500;
    color: var(--lux-on-light);
    line-height: 1.15;
    margin: 8px 0;
    letter-spacing: -.6px;
  }

  .qv__price {
    font-size: 17px;
    font-weight: 600;
    color: var(--lux-on-light);
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .qv__rating {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--lux-on-light-soft);
    font-weight: 500;
    margin-top: 1px;
  }

  .qv__rule {
    height: 1px;
    background: var(--lux-light-border);
    margin: 18px 0;
  }

  .qv__desc {
    font-size: 13.5px;
    line-height: 1.7;
    color: var(--lux-on-light-soft);
    margin: 0 0 20px;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 4;
    overflow: hidden;
  }

  .qv__label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--lux-on-light);
    margin-bottom: 10px;
  }

  .qv__swatches {
    display: flex;
    gap: 8px;
    margin-bottom: 22px;
  }

  :global(.qv__sw) {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 1px solid var(--lux-light-border-strong);
    cursor: pointer;
    outline: 2px solid transparent;
    outline-offset: 2px;
    transition: outline-color .2s var(--ease), transform .2s var(--ease);
  }

  :global(.qv__sw:hover) {
    transform: scale(1.1);
  }

  :global(.qv__sw.is-active) {
    outline-color: var(--lux-primary-dark);
  }

  :global(.qv__sw.is-unavailable) {
    opacity: .35;
    cursor: not-allowed;
  }

  .qv__sizes {
    display: flex;
    flex-wrap: wrap;
