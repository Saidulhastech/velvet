---
// WishlistDrawer component. Displays the user's saved wishlist items.
---

<aside class="drawer" id="wishDrawer" role="dialog" aria-modal="true" aria-labelledby="wishTitle" aria-hidden="true">
  <!-- Drawer Header -->
  <div class="drawer__head">
    <div>
      <span class="drawer__head-eyebrow">Saved Pieces</span>
      <h2 class="drawer__title" id="wishTitle">Wishlist <span class="drawer__title-count" id="drawerWishCount">0</span></h2>
    </div>
    <button class="drawer__close" id="wishCloseBtn" aria-label="Close wishlist">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M3 3l12 12M15 3L3 15" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
      </svg>
    </button>
  </div>

  <!-- Empty Wishlist State -->
  <div class="cart__empty" id="wishEmptyState">
    <p>Your wishlist is currently empty.</p>
    <a href="/shop" class="btn-ghost" id="emptyWishShopBtn">Explore The Collection</a>
  </div>

  <!-- Items list (populated by client JS) -->
  <ul class="drawer__items" id="wishItemsList">
    <!-- Populated dynamically -->
  </ul>

  <!-- Drawer Footer -->
  <div class="drawer__foot" id="wishDrawerFoot">
    <button class="btn-primary cart__checkout" id="addAllToCartBtn">
      Add All to Bag 
      <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
        <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"></path>
      </svg>
    </button>
    <button class="cart__continue" id="wishContinueBtn" type="button">Continue Shopping</button>
  </div>
</aside>

<script>
  import { 
    isWishOpen, 
    persistedWishItems, 
    wishCount,
    removeFromWishlist,
    addToCart 
  } from '../../stores/cart';

  const wishDrawer = document.getElementById('wishDrawer');
  const overlay = document.querySelector('[data-drawer-overlay]');
  const closeBtn = document.getElementById('wishCloseBtn');
  const continueBtn = document.getElementById('wishContinueBtn');
  const itemsList = document.getElementById('wishItemsList');
  const emptyState = document.getElementById('wishEmptyState');
  const footer = document.getElementById('wishDrawerFoot');
  const addAllBtn = document.getElementById('addAllToCartBtn');

  function euro(n: number) {
    return '€' + n.toLocaleString('en-US');
  }

  // Subscribe to Drawer Open/Close State
  isWishOpen.subscribe((isOpen) => {
    if (!wishDrawer || !overlay) return;
    
    if (isOpen) {
      wishDrawer.classList.add('is-open');
      wishDrawer.setAttribute('aria-hidden', 'false');
      overlay.classList.add('is-open');
      document.body.classList.add('no-scroll');
      setTimeout(() => closeBtn?.focus(), 200);
    } else {
      wishDrawer.classList.remove('is-open');
      wishDrawer.setAttribute('aria-hidden', 'true');
      // Only remove no-scroll and overlay if cart drawer is also closed
      const isCartlistOpen = document.getElementById('cartDrawer')?.classList.contains('is-open');
      if (!isCartlistOpen) {
        overlay.classList.remove('is-open');
        document.body.classList.remove('no-scroll');
      }
    }
  });

  // Action listeners to close drawer
  closeBtn?.addEventListener('click', () => isWishOpen.set(false));
  continueBtn?.addEventListener('click', () => isWishOpen.set(false));
  emptyState?.querySelector('#emptyWishShopBtn')?.addEventListener('click', () => isWishOpen.set(false));

  // Render Wishlist Items
  persistedWishItems.subscribe((items) => {
    if (!itemsList || !emptyState || !footer) return;

    if (items.length === 0) {
      emptyState.style.display = 'flex';
      itemsList.style.display = 'none';
      footer.style.display = 'none';
      return;
    }

    emptyState.style.display = 'none';
    itemsList.style.display = 'block';
    footer.style.display = 'flex';

    // Populate List
    itemsList.innerHTML = items.map((item) => {
      // Resolve local vs remote images
      const imgUrl = (item.image && typeof item.image === 'string')
        ? (item.image.startsWith('Images/') 
          ? `/src/assets/images/${item.image.split('/').pop()}` 
          : item.image)
        : '';

      return `
        <li class="ditem" data-id="${item.id}">
          <a href="/products/${item.id}" class="ditem__media">
            <img src="${imgUrl}" alt="${item.name}" loading="lazy" />
          </a>
          <div class="ditem__body">
            <div class="ditem__row">
              <h3 class="ditem__name">${item.name}</h3>
              <button class="ditem__remove" data-wish-remove aria-label="Remove">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                  <path d="M2 2l8 8M10 2l-8 8" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"></path>
                </svg>
              </button>
            </div>
            <p class="ditem__meta">${item.color || ''}${item.color && item.size ? ' · ' : ''}${item.size || ''}</p>
            <div class="ditem__foot">
              <span class="ditem__price">${euro(item.price)}</span>
              <button class="ditem__add" data-add-bag-from-wish style="background:none; border:none; border-bottom: 1px solid var(--lux-accent-lime); padding-bottom:2px; font-size:11px; font-weight:600; text-transform:uppercase; cursor:pointer;">
                Add to Bag
              </button>
            </div>
          </div>
        </li>
      `;
    }).join('');

    // Attach Event Listeners
    const rows = itemsList.querySelectorAll('.ditem');
    rows.forEach((rowEl) => {
      const id = rowEl.getAttribute('data-id') || '';
      const item = items.find(i => i.id === id);
      if (!item) return;

      // Remove
      rowEl.querySelector('[data-wish-remove]')?.addEventListener('click', () => {
        const itemLi = rowEl as HTMLElement;
        itemLi.style.transition = 'opacity 0.3s, transform 0.3s';
        itemLi.style.opacity = '0';
        itemLi.style.transform = 'translateX(20px)';
        setTimeout(() => {
          removeFromWishlist(id);
        }, 300);
      });

      // Add to bag
      rowEl.querySelector('[data-add-bag-from-wish]')?.addEventListener('click', () => {
        addToCart({
          id: item.id,
          name: item.name,
          price: item.price,
          image: item.image,
          color: item.color || undefined,
          size: item.size || undefined,
          description: item.description || ''
        }, 1);
        removeFromWishlist(id); // Remove from wishlist on adding to bag
      });
    });
  });

  // Add all items to bag
  addAllBtn?.addEventListener('click', () => {
    const items = persistedWishItems.get();
    items.forEach((item) => {
      addToCart({
        id: item.id,
        name: item.name,
        price: item.price,
        image: item.image,
        color: item.color || undefined,
        size: item.size || undefined,
        description: item.description || ''
      }, 1);
    });
    persistedWishItems.set([]); // Clear wishlist
  });

  // Subscribe to count
  wishCount.subscribe((count) => {
    const countEl = document.getElementById('drawerWishCount');
    if (countEl) countEl.textContent = String(count);
  });
</script>

<style>
  /* Drawer Shell reused from CartDrawer */
  .drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(88vw, 440px);
    background: var(--lux-light-bg);
    z-index: 100;
    transform: translateX(100%);
    transition: transform .5s var(--ease);
    display: flex;
    flex-direction: column;
    box-shadow: -12px 0 40px -16px rgba(48, 56, 44, .24);
  }

  .drawer.is-open {
    transform: translateX(0);
  }

  .drawer__head {
    padding: 28px 28px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--lux-light-border);
    flex-shrink: 0;
  }

  .drawer__head-eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--lux-on-light-soft);
    display: block;
    margin-bottom: 3px;
  }

  .drawer__title {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 500;
    color: var(--lux-on-light);
    letter-spacing: -.5px;
  }

  .drawer__title-count {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--lux-on-light-soft);
    font-weight: 500;
    margin-left: 4px;
  }

  .drawer__close {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1px solid var(--lux-light-border-strong);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--lux-on-light);
    transition: background .25s var(--ease), color .25s var(--ease), border-color .25s var(--ease);
  }

  .drawer__close:hover {
    background: var(--lux-primary-dark);
    color: var(--lux-text-primary);
    border-color: var(--lux-primary-dark);
  }

  /* Empty State */
  .cart__empty {
    padding: 80px 28px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
    text-align: center;
    color: var(--lux-on-light-soft);
    font-size: 14px;
    flex-grow: 1;
  }

  /* Items List */
  .drawer__items {
    flex-grow: 1;
    overflow-y: auto;
    scrollbar-width: thin;
    list-style: none;
    margin: 0;
    padding: 10px 28px;
    display: flex;
    flex-direction: column;
  }

  .drawer__items::-webkit-scrollbar {
    width: 4px;
  }

  .drawer__items::-webkit-scrollbar-thumb {
    background: var(--lux-light-border-strong);
  }

  /* Footer */
  .drawer__foot {
    background: var(--lux-light-surface);
    border-top: 1px solid var(--lux-light-border);
    padding: 22px 28px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .cart__checkout {
    width: 100%;
    justify-content: center;
    padding: 18px;
    letter-spacing: 1.2px;
  }

  .cart__continue {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--lux-on-light);
    text-align: center;
    padding: 4px 0;
    align-self: center;
    border-bottom: 1px solid var(--lux-light-border-strong);
    transition: color .3s var(--ease), border-color .3s var(--ease);
    display: inline-block;
  }

  .cart__continue:hover {
    color: var(--lux-secondary-olive);
    border-color: var(--lux-secondary-olive);
  }

  :global(.ditem__add:hover) {
    color: var(--lux-secondary-olive) !important;
    border-color: var(--lux-secondary-olive) !important;
  }

  @media (max-width: 480px) {
    .drawer__head,
    .drawer__items,
    .drawer__foot {
      padding-left: 20px;
      padding-right: 20px;
    }
  }
</style>
