---
// WishlistDrawer component. Displays the user's saved wishlist items.
---

<aside class="drawer" id="wishDrawer" role="dialog" aria-modal="true" aria-labelledby="wishTitle" aria-hidden="true">
  <!-- Drawer Header -->
  <div class="drawer__head">
    <div>
      <span class="drawer__head-eyebrow">Saved Pieces</span>
      <h2 class="drawer__title" id="wishTitle">Wishlist <span class="drawer__title-count" id="drawerWishCount">0</span></h2>
    </div>
    <button class="drawer__close" id="wishCloseBtn" aria-label="Close wishlist">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M3 3l12 12M15 3L3 15" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
      </svg>
    </button>
  </div>

  <!-- Empty Wishlist State -->
  <div class="cart__empty" id="wishEmptyState">
    <p>Your wishlist is currently empty.</p>
    <a href="/shop" class="btn-ghost" id="emptyWishShopBtn">Explore The Collection</a>
  </div>

  <!-- Items list (populated by client JS) -->
  <ul class="drawer__items" id="wishItemsList">
    <!-- Populated dynamically -->
  </ul>

  <!-- Drawer Footer -->
  <div class="drawer__foot" id="wishDrawerFoot">
    <button class="btn-primary cart__checkout" id="addAllToCartBtn">
      Add All to Bag
      <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
        <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"></path>
      </svg>
    </button>
    <button class="cart__continue" id="wishContinueBtn" type="button">Continue Shopping</button>
  </div>
</aside>

<script>
  import {
    isWishOpen,
    persistedWishItems,
    wishCount,
    cartCurrency,
    removeFromWishlist,
    addToCart,
    addMultipleToCart,
    updateWishTotals
  } from '../../stores/cart';
  import { shopifyImageUrl } from '../../lib/shopify/image-url';

  const wishDrawer = document.getElementById('wishDrawer');
  const overlay = document.querySelector('[data-drawer-overlay]');
  const closeBtn = document.getElementById('wishCloseBtn');
  const continueBtn = document.getElementById('wishContinueBtn');
  const itemsList = document.getElementById('wishItemsList');
  const emptyState = document.getElementById('wishEmptyState');
  const footer = document.getElementById('wishDrawerFoot');
  const addAllBtn = document.getElementById('addAllToCartBtn') as HTMLButtonElement | null;

  let currencyCode = cartCurrency.get();
  cartCurrency.subscribe((code) => { currencyCode = code || 'EUR'; });
  function euro(n: number) {
    try {
      return new Intl.NumberFormat('en', {
        style: 'currency',
        currency: currencyCode,
        minimumFractionDigits: Number.isInteger(n) ? 0 : 2,
        maximumFractionDigits: 2,
      }).format(n);
    } catch {
      return String(n);
    }
  }

  // Subscribe to Drawer Open/Close State
  isWishOpen.subscribe((isOpen) => {
    if (!wishDrawer || !overlay) return;
    
    if (isOpen) {
      wishDrawer.classList.add('is-open');
      wishDrawer.setAttribute('aria-hidden', 'false');
      overlay.classList.add('is-open');
      document.body.classList.add('no-scroll');
      setTimeout(() => closeBtn?.focus(), 200);
    } else {
      wishDrawer.classList.remove('is-open');
      wishDrawer.setAttribute('aria-hidden', 'true');
      // Only remove no-scroll and overlay if cart drawer is also closed
      const isCartlistOpen = document.getElementById('cartDrawer')?.classList.contains('is-open');
      if (!isCartlistOpen) {
        overlay.classList.remove('is-open');
        document.body.classList.remove('no-scroll');
      }
    }
  });

  // Action listeners to close drawer
  closeBtn?.addEventListener('click', () => isWishOpen.set(false));
  continueBtn?.addEventListener('click', () => isWishOpen.set(false));
  emptyState?.querySelector('#emptyWishShopBtn')?.addEventListener('click', () => isWishOpen.set(false));

  // Resolved-variant state per row (id → currently selected real variant).
  // Rebuilt every render since the list's DOM nodes are entirely replaced.
  interface WishResolved { id: string; price: number; image: string; available: boolean; color?: string; size?: string; }
  let resolvedByRow = new Map<HTMLElement, WishResolved>();

  // Build an inline colour/size picker for one wishlist row straight from its
  // snapshotted Shopify variant matrix — same pattern as Shop the Look, so a
  // shopper can pick the exact variant here instead of hitting a dead end.
  function initWishRow(row: HTMLElement, item: any) {
    const variants: any[] = Array.isArray(item.variants) ? item.variants : [];
    const swatchHex: Record<string, string> = item.swatchHex || {};
    const addBtn = row.querySelector<HTMLButtonElement>('[data-add-bag-from-wish]');
    const colorsEl = row.querySelector<HTMLElement>('[data-role="wcolors"]');
    const sizesEl = row.querySelector<HTMLElement>('[data-role="wsizes"]');
    const optLine = row.querySelector<HTMLElement>('[data-role="woptline"]');
    const priceEl = row.querySelector<HTMLElement>('[data-role="wprice"]');
    const imgEl = row.querySelector<HTMLImageElement>('.ditem__media img');

    if (!variants.length) {
      // No snapshotted matrix (older wishlist entry, or a single-variant
      // product) — fall back to whatever was captured at add-time.
      resolvedByRow.set(row, {
        id: item.id,
        price: item.price,
        image: item.image,
        available: true,
        color: item.color || undefined,
        size: item.size || undefined,
      });
      if (optLine) optLine.textContent = [item.color, item.size].filter(Boolean).join(' · ');
      return;
    }

    const optNames = Object.keys(variants[0].opts || {}).filter((n) => !/^title$/i.test(n));
    const colorKey = optNames.find((n) => /colou?r/i.test(n)) || '';
    const sizeKey = optNames.find((n) => /size/i.test(n)) || optNames.find((n) => n !== colorKey) || '';

    const distinct = (key: string) => {
      const seen: string[] = [];
      variants.forEach((v) => { const val = v.opts[key]; if (val && !seen.includes(val)) seen.push(val); });
      return seen;
    };
    const colors = colorKey ? distinct(colorKey) : [];
    const sizes = sizeKey ? distinct(sizeKey) : [];

    // Seed from the item's originally-saved colour/size when it still
    // resolves to a real variant, else the first available variant.
    const savedMatch = variants.find((v) =>
      (!colorKey || !item.color || v.opts[colorKey]?.toLowerCase() === String(item.color).toLowerCase()) &&
      (!sizeKey || !item.size || v.opts[sizeKey]?.toLowerCase() === String(item.size).toLowerCase())
    );
    const seed = (savedMatch && savedMatch.available) ? savedMatch : (variants.find((v) => v.available) || variants[0]);
    const selected: Record<string, string> = { ...seed.opts };

    function currentVariant() {
      return variants.find((v) => Object.keys(selected).every((k) => v.opts[k] === selected[k])) || null;
    }
    function optionAvailable(key: string, value: string) {
      const trial = { ...selected, [key]: value };
      return variants.some((v) => v.available && Object.keys(trial).every((k) => v.opts[k] === trial[k]));
    }

    function resolve() {
      const v = currentVariant();
      const resolved: WishResolved = {
        id: v?.id || seed.id,
        price: v ? v.price : seed.price,
        image: v?.img || item.image || '',
        available: !!(v && v.available),
        color: colorKey ? selected[colorKey] : undefined,
        size: sizeKey ? selected[sizeKey] : undefined,
      };
      resolvedByRow.set(row, resolved);

      if (priceEl) priceEl.textContent = euro(resolved.price);
      if (imgEl && resolved.image) imgEl.src = resolved.image;
      if (addBtn) addBtn.disabled = !resolved.available;
      if (optLine) optLine.textContent = [resolved.color, resolved.size].filter(Boolean).join(' · ');

      colorsEl?.querySelectorAll<HTMLElement>('.witem-sw').forEach((el) => {
        const val = el.dataset.value || '';
        el.classList.toggle('is-active', selected[colorKey] === val);
        el.classList.toggle('is-unavailable', !!colorKey && !optionAvailable(colorKey, val));
      });
      sizesEl?.querySelectorAll<HTMLButtonElement>('.witem-size').forEach((el) => {
        const val = el.dataset.value || '';
        const ok = !sizeKey || optionAvailable(sizeKey, val);
        el.classList.toggle('is-active', selected[sizeKey] === val);
        el.disabled = !ok;
        el.classList.toggle('is-oos', !ok);
      });
    }

    if (colors.length > 1 && colorsEl) {
      colorsEl.hidden = false;
      colorsEl.innerHTML = colors.map((c) =>
        `<span class="witem-sw" data-value="${c}" style="background:${swatchHex[c.toLowerCase()] || '#858A76'}" title="${c}"></span>`
      ).join('');
      colorsEl.querySelectorAll<HTMLElement>('.witem-sw').forEach((sw) => sw.addEventListener('click', () => {
        if (sw.classList.contains('is-unavailable')) return;
        selected[colorKey] = sw.dataset.value || '';
        resolve();
      }));
    }

    if (sizes.length > 1 && sizesEl) {
      sizesEl.hidden = false;
      sizesEl.innerHTML = sizes.map((s) =>
        `<button type="button" class="witem-size" data-value="${s}">${s.toUpperCase()}</button>`
      ).join('');
      sizesEl.querySelectorAll<HTMLButtonElement>('.witem-size').forEach((btn) => btn.addEventListener('click', () => {
        if (btn.disabled) return;
        selected[sizeKey] = btn.dataset.value || '';
        resolve();
      }));
    }

    resolve();
  }

  // Render Wishlist Items
  persistedWishItems.subscribe((items) => {
    if (!itemsList || !emptyState || !footer) return;

    if (items.length === 0) {
      itemsList.style.display = 'none';
      footer.style.display = 'none';
      emptyState.style.display = 'flex';
      emptyState.style.opacity = '0';
      requestAnimationFrame(() => {
        emptyState.style.transition = 'opacity .35s var(--ease)';
        emptyState.style.opacity = '1';
      });
      return;
    }

    emptyState.style.display = 'none';
    itemsList.style.display = 'block';
    footer.style.display = 'flex';

    // Populate List
    itemsList.innerHTML = items.map((item) => {
      // Resolve local vs remote images
      const imgUrl = (item.image && typeof item.image === 'string')
        ? (item.image.startsWith('Images/')
          ? `/src/assets/images/${item.image.split('/').pop()}`
          : (item.image.startsWith('http') ? shopifyImageUrl(item.image, 100, 134) : item.image))
        : '';

      return `
        <li class="ditem" data-id="${item.id}">
          <a href="/products/${item.description || item.id}" class="ditem__media">
            <img src="${imgUrl}" alt="${item.name}" loading="lazy" decoding="async" />
          </a>
          <div class="ditem__body">
            <div class="ditem__row">
              <h3 class="ditem__name">${item.name}</h3>
              <button class="ditem__remove" data-wish-remove aria-label="Remove">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                  <path d="M2 2l8 8M10 2l-8 8" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"></path>
                </svg>
              </button>
            </div>
            <p class="witem-optline" data-role="woptline"></p>
            <div class="witem-colors" data-role="wcolors" hidden></div>
            <div class="witem-sizes" data-role="wsizes" hidden></div>
            <div class="ditem__foot">
              <span class="ditem__price" data-role="wprice">${euro(item.price)}</span>
              <button class="ditem__add" data-add-bag-from-wish style="background:none; border:none; border-bottom: 1px solid var(--lux-accent-lime); padding-bottom:2px; font-size:11px; font-weight:600; text-transform:uppercase; cursor:pointer;">
                Add to Bag
              </button>
            </div>
          </div>
        </li>
      `;
    }).join('');

    // (Re)build resolved-variant state + attach listeners for the fresh DOM.
    resolvedByRow = new Map();
    const rows = Array.from(itemsList.querySelectorAll<HTMLElement>('.ditem'));
    rows.forEach((rowEl) => {
      const id = rowEl.getAttribute('data-id') || '';
      const item = items.find(i => i.id === id);
      if (!item) return;

      initWishRow(rowEl, item);

      // Remove
      rowEl.querySelector('[data-wish-remove]')?.addEventListener('click', () => {
        rowEl.style.transition = 'opacity 0.3s, transform 0.3s';
        rowEl.style.opacity = '0';
        rowEl.style.transform = 'translateX(20px)';
        setTimeout(() => {
          removeFromWishlist(id);
        }, 300);
      });

      // Add to bag — uses whatever variant is currently selected in this row's
      // inline picker (defaults to the saved colour/size, or the first
      // available variant when that combo no longer exists).
      rowEl.querySelector('[data-add-bag-from-wish]')?.addEventListener('click', () => {
        const resolved = resolvedByRow.get(rowEl);
        if (!resolved || !resolved.available) return;
        addToCart({
          id: resolved.id,
          name: item.name,
          price: resolved.price,
          image: resolved.image || item.image,
          color: resolved.color,
          size: resolved.size,
          description: item.description || ''
        }, 1);
        removeFromWishlist(id); // Remove from wishlist on adding to bag
        isWishOpen.set(false); // Hand off to the cart drawer, which addToCart opens
      });
    });
  });

  // Add all items to bag — every row is resolved inline (colour + size already
  // chosen or defaulted), so this always has a real variant to add, no more
  // silent skips. Rows fade out first and the button shows a loading spinner
  // so the move to cart reads as a deliberate action, not an instant wipe.
  const addAllOriginalHtml = addAllBtn?.innerHTML ?? '';
  addAllBtn?.addEventListener('click', () => {
    if (!addAllBtn || addAllBtn.classList.contains('is-loading')) return;
    const items = persistedWishItems.get();
    const rows = Array.from(itemsList?.querySelectorAll<HTMLElement>('.ditem') || []);
    if (!rows.length) return;

    addAllBtn.disabled = true;
    addAllBtn.classList.add('is-loading');
    addAllBtn.innerHTML = '<span class="btn-spinner"></span> Adding to Bag…';

    rows.forEach((rowEl) => {
      rowEl.style.transition = 'opacity .35s var(--ease), transform .35s var(--ease)';
      rowEl.style.opacity = '0';
      rowEl.style.transform = 'translateX(20px)';
    });

    setTimeout(() => {
      const addedIds: string[] = [];
      const toAdd: Parameters<typeof addMultipleToCart>[0] = [];
      rows.forEach((rowEl) => {
        const id = rowEl.getAttribute('data-id') || '';
        const item = items.find((i) => i.id === id);
        const resolved = resolvedByRow.get(rowEl);
        if (!item || !resolved || !resolved.available) return;
        toAdd.push({
          id: resolved.id,
          name: item.name,
          price: resolved.price,
          image: resolved.image || item.image,
          color: resolved.color,
          size: resolved.size,
          description: item.description || ''
        });
        addedIds.push(id);
      });

      // One batched mutation for every line — firing N separate addToCart
      // calls here raced (see addMultipleToCart's doc comment).
      addMultipleToCart(toAdd);

      persistedWishItems.set(items.filter((i) => !addedIds.includes(i.id)));
      updateWishTotals();
      isWishOpen.set(false); // Hand off to the cart drawer, which addToCart opens

      addAllBtn.disabled = false;
      addAllBtn.classList.remove('is-loading');
      addAllBtn.innerHTML = addAllOriginalHtml;
    }, 360);
  });

  // Subscribe to count
  wishCount.subscribe((count) => {
    const countEl = document.getElementById('drawerWishCount');
    if (countEl) countEl.textContent = String(count);
  });
</script>

<style>
  /* Drawer Shell reused from CartDrawer */
  .drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(88vw, 440px);
    background: var(--lux-light-bg);
    z-index: 100;
    transform: translateX(100%);
    transition: transform .5s var(--ease);
    display: flex;
    flex-direction: column;
    box-shadow: -12px 0 40px -16px rgba(48, 56, 44, .24);
  }

  .drawer.is-open {
    transform: translateX(0);
  }

  .drawer__head {
    padding: 28px 28px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--lux-light-border);
    flex-shrink: 0;
  }

  .drawer__head-eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--lux-on-light-soft);
    display: block;
    margin-bottom: 3px;
  }

  .drawer__title {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 500;
    color: var(--lux-on-light);
    letter-spacing: -.5px;
  }

  .drawer__title-count {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--lux-on-light-soft);
    font-weight: 500;
    margin-left: 4px;
  }

  .drawer__close {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--lux-light-border-strong);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--lux-on-light);
    transition: background .25s var(--ease), color .25s var(--ease), border-color .25s var(--ease);
  }

  .drawer__close:hover {
    background: var(--lux-primary-dark);
    color: var(--lux-text-primary);
    border-color: var(--lux-primary-dark);
  }

  /* Empty State */
  .cart__empty {
    padding: 80px 28px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
    text-align: center;
    color: var(--lux-on-light-soft);
    font-size: 14px;
    flex-grow: 1;
  }

  /* Items List */
  .drawer__items {
    flex-grow: 1;
    overflow-y: auto;
    scrollbar-width: thin;
    list-style: none;
    margin: 0;
    padding: 10px 28px;
    display: flex;
    flex-direction: column;
  }

  .drawer__items::-webkit-scrollbar {
    width: 4px;
  }

  .drawer__items::-webkit-scrollbar-thumb {
    background: var(--lux-light-border-strong);
  }

  /* Footer */
  .drawer__foot {
    background: var(--lux-light-surface);
    border-top: 1px solid var(--lux-light-border);
    padding: 22px 28px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .cart__checkout {
    width: 100%;
    justify-content: center;
    padding: 18px;
    letter-spacing: 1.2px;
  }

  .cart__checkout.is-loading {
    opacity: .75;
    cursor: wait;
  }

  :global(.btn-spinner) {
    display: inline-block;
    width: 13px;
    height: 13px;
    border: 2px solid rgba(255, 255, 255, .35);
    border-top-color: currentColor;
    border-radius: 50%;
    animation: btn-spin .6s linear infinite;
    vertical-align: -2px;
  }

  @keyframes btn-spin {
    to { transform: rotate(360deg); }
  }

  .cart__continue {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--lux-on-light);
    text-align: center;
    padding: 4px 0;
    align-self: center;
    border-bottom: 1px solid var(--lux-light-border-strong);
    transition: color .3s var(--ease), border-color .3s var(--ease);
    display: inline-block;
  }

  .cart__continue:hover {
    color: var(--lux-secondary-olive);
    border-color: var(--lux-secondary-olive);
  }

  :global(.ditem__add:hover) {
    color: var(--lux-secondary-olive) !important;
    border-color: var(--lux-secondary-olive) !important;
  }

  :global(.ditem__add:disabled) {
    opacity: .4;
    cursor: not-allowed;
  }

  /* Inline colour/size picker per wishlist row — built client-side (see
     initWishRow), so these rules are :global to reach JS-injected markup. */
  :global(.witem-optline) {
    font-size: 11px;
    letter-spacing: .3px;
    text-transform: capitalize;
    color: var(--lux-on-light-soft);
    margin: 4px 0 0;
    min-height: 14px;
  }

  :global(.witem-colors) {
    display: flex;
    gap: 6px;
    margin-top: 8px;
  }

  :global(.witem-sw) {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 1px solid var(--lux-light-border-strong);
    cursor: pointer;
    outline: 2px solid transparent;
    outline-offset: 2px;
    transition: outline-color .2s var(--ease), transform .2s var(--ease);
  }

  :global(.witem-sw:hover) {
    transform: scale(1.1);
  }

  :global(.witem-sw.is-active) {
    outline-color: var(--lux-primary-dark);
  }

  :global(.witem-sw.is-unavailable) {
    opacity: .35;
    cursor: not-allowed;
  }

  :global(.witem-sizes) {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 8px;
  }

  :global(.witem-size) {
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: .3px;
    color: var(--lux-on-light-soft);
    border: 1px solid var(--lux-light-border-strong);
    background: var(--lux-light-elevated);
    min-width: 28px;
    height: 28px;
    padding: 0 8px;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background .25s var(--ease), color .25s var(--ease), border-color .25s var(--ease);
  }

  :global(.witem-size:hover) {
    border-color: var(--lux-primary-dark);
  }

  :global(.witem-size.is-active) {
    background: var(--lux-primary-dark);
    color: var(--lux-text-primary);
    border-color: var(--lux-primary-dark);
  }

  :global(.witem-size.is-oos) {
    opacity: .35;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  @media (max-width: 480px) {
    .drawer__head,
    .drawer__items,
    .drawer__foot {
      padding-left: 20px;
      padding-right: 20px;
    }
  }
</style>
