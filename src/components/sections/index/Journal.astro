---
import { getShopifyArticles } from '~/lib/shopify/client';
import { shopifyImageUrl, shopifySrcset } from '~/lib/shopify/image-url';

const posts = (await getShopifyArticles(Astro.locals.market)).slice(0, 3);
---

<section class="journal" id="journal" aria-label="The journal">
  <div class="journal__inner">
    <div class="journal__head reveal">
      <span class="eyebrow eyebrow--center">The Journal</span>
      <h2 class="section-title" style="margin-top: 14px;">Notes & <em>Stories</em></h2>
    </div>
    <div class="journal__grid">
      {posts.map((post) => (
        <article class="bcard reveal">
          <a href={`/blog/${post.handle}`} class="bcard__media">
            <span class="bcard__tag">{post.category}</span>
            {post.image && (
              <img
                src={shopifyImageUrl(post.image, 360, 288)}
                srcset={shopifySrcset(post.image, [360, 720])}
                sizes="(min-width: 1024px) 360px, 50vw"
                alt={post.title}
                width="360"
                height="288"
                loading="lazy"
              />
            )}
          </a>
          <div class="bcard__body">
            <div class="bcard__meta">{post.category} · {post.readTime}</div>
            <h3 class="bcard__title"><a href={`/blog/${post.handle}`}>{post.title}</a></h3>
            <p class="bcard__excerpt">{post.excerpt}</p>
            <a href={`/blog/${post.handle}`} class="bcard__btn">
              Read Article
              <svg width="13" height="9" viewBox="0 0 14 10" fill="none">
                <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .journal {
    background: var(--lux-light-bg);
  }

  .journal__inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: var(--section-y) var(--gutter);
  }

  .journal__head {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    margin-bottom: clamp(36px, 4vw, 58px);
  }

  .journal__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(20px, 2.4vw, 34px);
  }

  .bcard {
    display: flex;
    flex-direction: column;
    background: var(--lux-light-elevated);
    border: 1px solid var(--lux-light-border);
    border-radius: 0;
    overflow: hidden;
    transition: transform .5s var(--ease), box-shadow .5s var(--ease), border-color .5s var(--ease);
  }

  .bcard:hover {
    transform: translateY(-8px);
    box-shadow: 0 40px 80px -50px rgba(48, 56, 44, .5);
    border-color: var(--lux-light-border-strong);
  }

  .bcard__media {
    position: relative;
    aspect-ratio: 5/4;
    overflow: hidden;
    background: var(--lux-light-surface);
  }

  .bcard__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.1s var(--ease);
  }

  .bcard:hover .bcard__media img {
    transform: scale(1.07);
  }

  .bcard__tag {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 2;
    background: rgba(23, 26, 21, .78);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    color: var(--lux-accent-lime);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    padding: 7px 13px;
    border-radius: 0;
  }

  .bcard__body {
    padding: clamp(22px, 2vw, 30px);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .bcard__meta {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--lux-on-light-soft);
    margin-bottom: 12px;
  }

  .bcard__title {
    font-family: var(--font-display);
    font-size: clamp(22px, 1.9vw, 27px);
    font-weight: 500;
    line-height: 1.18;
    letter-spacing: -.4px;
    color: var(--lux-on-light);
  }

  .bcard__title a {
    color: inherit;
    transition: color .3s var(--ease);
  }

  .bcard__title a:hover {
    color: var(--lux-secondary-olive);
  }

  .bcard__excerpt {
    font-size: 14px;
    line-height: 1.65;
    color: var(--lux-on-light-soft);
    margin: 12px 0 22px;
    flex: 1;
  }

  .bcard__btn {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 13px 24px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    background: var(--lux-primary-dark);
    color: var(--lux-text-primary);
    border: 1px solid var(--lux-primary-dark);
    transition: background .3s var(--ease), color .3s var(--ease), border-color .3s var(--ease), gap .3s var(--ease);
  }

  .bcard__btn:hover {
    background: var(--lux-accent-hover);
    color: var(--lux-bg-dark);
    border-color: var(--lux-accent-hover);
    gap: 14px;
  }

  .bcard__btn svg {
    transition: transform .3s var(--ease);
  }

  .bcard:hover .bcard__btn svg {
    transform: translateX(3px);
  }

  @media (max-width: 1024px) {
    .journal__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .journal__grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>
