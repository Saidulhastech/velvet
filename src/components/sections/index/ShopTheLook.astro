---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import {
  formatMoney,
  getShopifyCollection,
  getShopifyProducts,
  getShopifyProductWithVariants,
} from '../../../lib/shopify/client';
import { SHOP_THE_LOOK_HANDLE } from '../../../config/velvet';

const market = Astro.locals.market;

// Static stage backdrop.
import imgStage from '../../../assets/images/Shop the look section left image.png';

// Resolve a product image ref: Shopify CDN URLs pass through; a bare demo
// filename resolves via the local assets glob to an optimizable URL.
const localImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.{jpeg,jpg,png,gif,webp,WebP}', { eager: true });
const resolveImg = (img: string) => {
  if (!img) return '';
  if (/^https?:\/\//.test(img)) return img;
  return localImages[`/src/assets/images/${img}`]?.default.src ?? img;
};

// Preset hotspot coordinates. Product ORDER in the `shop-the-look` collection
// maps to these slots (1st product → slot 1, …) — curate order in Shopify admin.
const POSITIONS = [
  { dotStyle: 'top:28%; left:46%;', tipStyle: 'top:30%; left:52%;' },
  { dotStyle: 'top:55%; left:38%;', tipStyle: 'top:57%; left:44%;' },
  { dotStyle: 'top:74%; left:56%;', tipStyle: 'top:62%; left:56%;' },
];

// The `shop-the-look` collection decides WHICH products + their order. Each is
// then fetched in full (getShopifyProductWithVariants) so the real variant matrix
// drives the inline Quick View. If the collection is missing/empty, fall back to
// the first few store (or demo) products so the section never blanks.
const curated = await getShopifyCollection(SHOP_THE_LOOK_HANDLE, market);
let handles = (curated?.products ?? []).map((p) => p.handle);
if (handles.length === 0) {
  const all = await getShopifyProducts(market);
  handles = all.map((p) => p.handle);
}
handles = handles.slice(0, POSITIONS.length);

const resolved = await Promise.all(
  handles.map((h) => getShopifyProductWithVariants(h, market)),
);

const lookItems = resolved
  .map((r, i) => {
    const p = r.product;
    if (!p) return null;
    return {
      index: i,
      handle: p.handle,
      id: p.id,
      name: p.name,
      price: p.price,
      formattedPrice: p.formattedPrice,
      originalPrice: undefined as string | undefined,
      color: p.swatches?.[0]?.color ?? '',
      image: resolveImg(p.image),
      needsPicker: p.needsPicker ?? false,
      currency: r.currency,
      // Data the Quick View needs to build its variant picker inline.
      variants: p.variants ?? [],
      options: p.options ?? [],
      category: p.category,
      rating: p.rating,
      description: p.description,
      sizes: p.filterSizes ?? [],
      stock: p.stock,
      ...POSITIONS[i],
    };
  })
  .filter((x): x is NonNullable<typeof x> => x !== null);

// Bundle total computed + formatted in the active currency.
const bundleCurrency = lookItems.find((i) => i.currency)?.currency || 'EUR';
const bundleTotal = lookItems.reduce((sum, i) => sum + (i.price || 0), 0);
const bundleTotalFormatted = formatMoney(bundleTotal, bundleCurrency);
---

<section class="look" id="lookbook" aria-label="Shop the look">
  <div class="look__inner">
    <div class="look__stage reveal">
      <Image src={imgStage} alt="The Riviera Set" width={560} height={560} loading="lazy" />
      
      {lookItems.map((item, idx) => (
        <>
          <button 
            class={`look__dot ${idx === 0 ? 'is-active' : ''}`} 
            style={item.dotStyle} 
            data-index={item.index} 
            aria-label={item.name}
          />
          <div 
            class={`look__tip ${idx === 0 ? 'is-active' : ''}`} 
            style={item.tipStyle} 
            data-index={item.index}
          >
            <img src={item.image} alt={item.name} width={42} height={42} loading="lazy" />
            <div>
              <div class="look__tip-name">{item.name}</div>
              <div class="look__tip-price">{item.formattedPrice}</div>
            </div>
          </div>
        </>
      ))}
    </div>
    
    <div class="look__panel reveal d1">
      <div class="look__panel-head">
        <div class="look__panel-eyebrow">Curated Edit</div>
        <h2 class="look__panel-title">The Riviera Set</h2>
      </div>
      
      <div class="look__set">
        {lookItems.map((item, idx) => (
          <div
            class={`look__row ${idx !== 0 ? 'is-dim' : ''}`}
            data-qv-source
            data-index={item.index}
            data-id={item.id}
            data-name={item.name}
            data-price={item.formattedPrice}
            data-img={item.image}
            data-color={item.color}
            data-handle={item.handle}
            data-cat={item.category ?? ''}
            data-rating={item.rating ?? ''}
            data-desc={item.description ?? ''}
            data-size={(item.sizes ?? []).join(' ')}
            data-stock={item.stock ?? 'in'}
            data-variants={item.variants?.length ? JSON.stringify(item.variants) : ''}
            data-options={item.options?.length ? JSON.stringify(item.options) : ''}
            data-needs-picker={item.needsPicker ? 'true' : 'false'}
          >
            <div class="look__row-thumb">
              <img src={item.image} alt={item.name} width={66} height={66} loading="lazy" />
            </div>
            <div>
              <div class="look__row-name">{item.name}</div>
              <span class="look__row-opt">
                Colour: {item.color} 
                <svg width="11" height="11" viewBox="0 0 12 12" fill="none">
                  <path d="M3 4.5l3 3 3-3" stroke="currentColor" stroke-linecap="round" />
                </svg>
              </span>
              <br />
              <button
                class="look__row-add"
                data-add-bag
                data-id={item.id}
                data-qv={(item as any).needsPicker ? '' : undefined}
                aria-label={(item as any).needsPicker ? `Select options for ${item.name}` : `Add ${item.name} to bag`}
              >{(item as any).needsPicker ? 'Select Options' : 'Add to Bag'}</button>
            </div>
            <div class="look__row-price">
              {item.originalPrice ? (
                <>
                  <span class="sale">{item.formattedPrice}</span> 
                  <s>{item.originalPrice}</s>
                </>
              ) : (
                item.formattedPrice
              )}
            </div>
          </div>
        ))}
      </div>
      
      <button class="look__total" data-add-bag data-ids={lookItems.map(item => item.id).join(',')}>
        Add All to Bag — {bundleTotalFormatted}
        <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
          <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
  import { addToCart } from '../../../stores/cart';

  const dots = Array.from(document.querySelectorAll('.look__dot')) as HTMLElement[];
  const rows = Array.from(document.querySelectorAll('.look__row')) as HTMLElement[];
  const tips = Array.from(document.querySelectorAll('.look__tip')) as HTMLElement[];

  function setLook(indexStr: string) {
    dots.forEach(d => d.classList.toggle('is-active', d.dataset.index === indexStr));
    tips.forEach(t => t.classList.toggle('is-active', t.dataset.index === indexStr));
    rows.forEach(r => r.classList.toggle('is-dim', r.dataset.index !== indexStr));
  }

  dots.forEach(d => d.addEventListener('click', () => {
    if (d.dataset.index) setLook(d.dataset.index);
  }));
  
  rows.forEach(r => r.addEventListener('mouseenter', () => {
    if (r.dataset.index) setLook(r.dataset.index);
  }));

  // Add one directly-resolvable row to the bag (strips the currency symbol from
  // the localized data-price before parsing).
  function addRowDirect(dataset: DOMStringMap) {
    addToCart({
      id: dataset.id || '',
      name: dataset.name || '',
      price: parseFloat((dataset.price || '').replace(/[^0-9.]/g, '')) || 0,
      image: dataset.img || '',
      color: dataset.color || undefined,
      size: undefined,
      description: dataset.handle || '',
    }, 1);
  }

  // Single hotspot add to bag. Variant rows carry `data-qv` and are opened by
  // the Quick View's global listener (pick a size inline) — so here we only
  // handle the directly-addable ones and let QV take the rest.
  document.querySelectorAll('.look__row-add').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      const rowEl = btn.closest('.look__row') as HTMLElement | null;
      if (!rowEl) return;
      if (rowEl.dataset.needsPicker === 'true') return; // → Quick View
      e.preventDefault();
      addRowDirect(rowEl.dataset);
    });
  });

  // Add entire lookbook edit to bag. Add every directly-addable piece, then open
  // the Quick View for the first piece that still needs a size/option chosen so
  // the shopper can complete the set (no more silent skips / total mismatch).
  const addAllBtn = document.querySelector('.look__total');
  addAllBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    const rows = Array.from(document.querySelectorAll('.look__row')) as HTMLElement[];
    let firstPending: HTMLElement | null = null;
    rows.forEach((rowEl) => {
      if (rowEl.dataset.needsPicker === 'true') {
        if (!firstPending) firstPending = rowEl;
        return;
      }
      addRowDirect(rowEl.dataset);
    });
    if (firstPending) {
      (firstPending as HTMLElement).querySelector<HTMLElement>('.look__row-add[data-qv]')?.click();
    }
  });
</script>

<style>
  @keyframes hsPulse {
    0% {
      transform: scale(.8);
      opacity: .9;
    }
    100% {
      transform: scale(1.7);
      opacity: 0;
    }
  }

  .look {
    background: var(--lux-light-surface);
  }

  .look__inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: var(--section-y) var(--gutter);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 5vw, 80px);
    align-items: center;
  }

  .look__stage {
    position: relative;
    overflow: hidden;
    background: var(--lux-light-bg);
    aspect-ratio: 1/1;
  }

  .look__stage img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .look__dot {
    position: absolute;
    z-index: 3;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    background: rgba(252, 252, 248, .94);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px -3px rgba(23, 26, 21, .45);
    transition: transform .3s var(--ease), background .3s var(--ease);
  }

  .look__dot::after {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--lux-on-light);
    transition: background .3s var(--ease);
  }

  .look__dot::before {
    content: "";
    position: absolute;
    inset: -7px;
    border-radius: 50%;
    border: 1px solid rgba(48, 56, 44, .28);
    animation: hsPulse 2.6s var(--ease) infinite;
  }

  .look__dot:hover,
  .look__dot.is-active {
    transform: scale(1.12);
    background: var(--lux-primary-dark);
  }

  .look__dot.is-active::after,
  .look__dot:hover::after {
    background: var(--lux-accent-lime);
  }

  .look__tip {
    position: absolute;
    z-index: 4;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 9px 16px 9px 9px;
    background: var(--lux-light-elevated);
    border-radius: 0;
    box-shadow: 0 14px 34px -12px rgba(23, 26, 21, .4);
    opacity: 0;
    transform: translateY(8px) scale(.96);
    pointer-events: none;
    transition: opacity .3s var(--ease), transform .3s var(--ease);
    white-space: nowrap;
  }

  .look__tip.is-active {
    opacity: 1;
    transform: none;
  }

  .look__tip img {
    width: 42px;
    height: 42px;
    object-fit: cover;
    border-radius: 0;
  }

  .look__tip-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--lux-on-light);
  }

  .look__tip-price {
    font-size: 13px;
    color: var(--lux-on-light-soft);
  }

  .look__panel-head {
    text-align: center;
    margin-bottom: clamp(20px, 2.5vw, 30px);
  }

  .look__panel-eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--lux-on-light-soft);
  }

  .look__panel-title {
    position: relative;
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(34px, 4.2vw, 60px);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -1.3px;
    color: var(--lux-on-light);
    margin: 8px 0 40px;
  }

  .look__panel-title::after {
    content: "";
    position: absolute;
    left: 12%;
    right: 12%;
    bottom: -8px;
    height: 3px;
    border-radius: 0;
  }

  .look__set {
    display: flex;
    flex-direction: column;
  }

  .look__row {
    display: grid;
    grid-template-columns: 66px 1fr auto;
    gap: 16px;
    align-items: center;
    padding: 18px 0;
    border-top: 1px solid var(--lux-light-border);
    cursor: pointer;
    transition: opacity .35s var(--ease);
  }

  .look__row:last-of-type {
    border-bottom: 1px solid var(--lux-light-border);
  }

  .look__row.is-dim {
    opacity: .45;
  }

  .look__row-thumb {
    width: 66px;
    height: 66px;
    overflow: hidden;
    background: var(--lux-light-bg);
  }

  .look__row-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .look__row-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--lux-on-light);
  }

  .look__row-opt {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--lux-on-light-soft);
    margin-top: 5px;
  }

  .look__row-add {
    display: inline-block;
    margin-top: 7px;
    font-size: 12px;
    font-weight: 600;
    color: var(--lux-on-light);
    border-bottom: 1px solid var(--lux-on-light);
    padding-bottom: 1px;
    background: none;
    border-left: none;
    border-right: none;
    border-top: none;
    padding-left: 0;
    padding-right: 0;
  }

  .look__row-add:hover {
    color: var(--lux-secondary-olive);
    border-color: var(--lux-secondary-olive);
  }

  .look__row-price {
    font-size: 15px;
    font-weight: 600;
    color: var(--lux-on-light);
    white-space: nowrap;
  }

  .look__row-price s {
    color: var(--lux-on-light-soft);
    font-weight: 400;
    margin-left: 6px;
  }

  .look__row-price .sale {
    color: #B0492F;
  }

  .look__total {
    width: 100%;
    justify-content: center;
    margin-top: 28px;
    padding: 18px;
    background: var(--lux-primary-dark);
    color: var(--lux-text-primary);
    border: 1px solid var(--lux-primary-dark);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: background .28s var(--ease), color .28s var(--ease), border-color .28s var(--ease);
  }

  .look__total:hover {
    background: var(--lux-accent-hover);
    color: var(--lux-bg-dark);
    border-color: var(--lux-accent-hover);
  }

  .look__guide {
    display: block;
    text-align: center;
    margin-top: 16px;
    font-size: 13px;
    font-weight: 600;
    color: var(--lux-on-light);
  }

  .look__guide span {
    border-bottom: 1px solid var(--lux-on-light);
    padding-bottom: 2px;
  }

  @media (max-width: 860px) {
    .look__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
