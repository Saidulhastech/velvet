---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import {
  formatMoney,
  getShopifyCollection,
  getShopifyProducts,
  getShopifyProductWithVariants,
} from '../../../lib/shopify/client';
import { SHOP_THE_LOOK_HANDLE } from '../../../config/velvet';
import { shopifyImageUrl, shopifySrcset } from '../../../lib/shopify/image-url';

const isRemoteImg = (img: string) => /^https?:\/\//.test(img);

const market = Astro.locals.market;

// Static stage backdrop.
import imgStage from '../../../assets/images/Shop the look section left image.png';

// Resolve a product image ref: Shopify CDN URLs pass through; a bare demo
// filename resolves via the local assets glob to an optimizable URL.
const localImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.{jpeg,jpg,png,gif,webp,WebP}', { eager: true });
const resolveImg = (img: string) => {
  if (!img) return '';
  if (/^https?:\/\//.test(img)) return img;
  return localImages[`/src/assets/images/${img}`]?.default.src ?? img;
};

// Preset hotspot coordinates. Product ORDER in the `shop-the-look` collection
// maps to these slots (1st product → slot 1, …) — curate order in Shopify admin.
const POSITIONS = [
  { dotStyle: 'top:28%; left:46%;', tipStyle: 'top:30%; left:52%;' },
  { dotStyle: 'top:55%; left:38%;', tipStyle: 'top:57%; left:44%;' },
  { dotStyle: 'top:74%; left:56%;', tipStyle: 'top:62%; left:56%;' },
];

// The `shop-the-look` collection decides WHICH products + their order. Each is
// then fetched in full (getShopifyProductWithVariants) so the real variant matrix
// drives the inline colour/size pickers on each row. If the collection is
// missing/empty, fall back to the first few store (or demo) products so the
// section never blanks.
const curated = await getShopifyCollection(SHOP_THE_LOOK_HANDLE, market);
let handles = (curated?.products ?? []).map((p) => p.handle);
if (handles.length === 0) {
  const all = await getShopifyProducts(market);
  handles = all.map((p) => p.handle);
}
handles = handles.slice(0, POSITIONS.length);

const resolved = await Promise.all(
  handles.map((h) => getShopifyProductWithVariants(h, market)),
);

const lookItems = resolved
  .map((r, i) => {
    const p = r.product;
    if (!p) return null;
    return {
      index: i,
      handle: p.handle,
      id: p.id,
      name: p.name,
      price: p.price,
      formattedPrice: p.formattedPrice,
      swatches: p.swatches ?? [],
      image: resolveImg(p.image),
      currency: r.currency,
      // Real variant matrix — drives the inline colour/size pickers per row.
      variants: p.variants ?? [],
      options: p.options ?? [],
      ...POSITIONS[i],
    };
  })
  .filter((x): x is NonNullable<typeof x> => x !== null);

// Bundle total computed + formatted in the active currency.
const bundleCurrency = lookItems.find((i) => i.currency)?.currency || 'EUR';
const bundleTotal = lookItems.reduce((sum, i) => sum + (i.price || 0), 0);
const bundleTotalFormatted = formatMoney(bundleTotal, bundleCurrency);
---

<section class="look" id="lookbook" aria-label="Shop the look">
  <div class="look__inner">
    <div class="look__stage reveal">
      <Image src={imgStage} alt="The Riviera Set" width={560} height={560} loading="lazy" />
      
      {lookItems.map((item, idx) => (
        <>
          <button 
            class={`look__dot ${idx === 0 ? 'is-active' : ''}`} 
            style={item.dotStyle} 
            data-index={item.index} 
            aria-label={item.name}
          />
          <div 
            class={`look__tip ${idx === 0 ? 'is-active' : ''}`} 
            style={item.tipStyle} 
            data-index={item.index}
          >
            <img
              src={isRemoteImg(item.image) ? shopifyImageUrl(item.image, 42, 42) : item.image}
              srcset={isRemoteImg(item.image) ? shopifySrcset(item.image, [42, 84]) : undefined}
              alt={item.name}
              width={42}
              height={42}
              loading="lazy"
              decoding="async"
            />
            <div>
              <div class="look__tip-name">{item.name}</div>
              <div class="look__tip-price">{item.formattedPrice}</div>
            </div>
          </div>
        </>
      ))}
    </div>
    
    <div class="look__panel reveal d1">
      <div class="look__panel-head">
        <div class="look__panel-eyebrow">Curated Edit</div>
        <h2 class="look__panel-title">The Riviera Set</h2>
      </div>
      
      <div class="look__set">
        {lookItems.map((item, idx) => (
          <div
            class={`look__row ${idx !== 0 ? 'is-dim' : ''}`}
            data-index={item.index}
            data-id={item.id}
            data-name={item.name}
            data-img={item.image}
            data-handle={item.handle}
            data-symbol={(item.formattedPrice.match(/^[^\d.,]+/) || ['$'])[0]}
            data-variants={item.variants?.length ? JSON.stringify(item.variants) : ''}
            data-options={item.options?.length ? JSON.stringify(item.options) : ''}
            data-swatch-hex={JSON.stringify(Object.fromEntries((item.swatches ?? []).map((sw) => [sw.color, sw.hex])))}
          >
            <div class="look__row-thumb">
              <img
                class="look__row-img"
                src={isRemoteImg(item.image) ? shopifyImageUrl(item.image, 66, 66) : item.image}
                srcset={isRemoteImg(item.image) ? shopifySrcset(item.image, [66, 132]) : undefined}
                alt={item.name}
                width={66}
                height={66}
                loading="lazy"
                decoding="async"
              />
            </div>
            <div>
              <div class="look__row-name">{item.name}</div>
              <div class="look__opt-line" data-role="opt-line"></div>
              <div class="look__sw-row" data-role="colors" hidden></div>
              <div class="look__sizes-row" data-role="sizes" hidden></div>
              <button class="look__row-add" data-add-bag disabled>Add to Bag</button>
            </div>
            <div class="look__row-price" data-role="price">{item.formattedPrice}</div>
          </div>
        ))}
      </div>

      <button class="look__total" data-add-bag>
        <span data-role="total-label">Add All to Bag — {bundleTotalFormatted}</span>
        <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
          <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
  import { addToCart } from '../../../stores/cart';

  const dots = Array.from(document.querySelectorAll('.look__dot')) as HTMLElement[];
  const rows = Array.from(document.querySelectorAll<HTMLElement>('.look__row'));
  const tips = Array.from(document.querySelectorAll('.look__tip')) as HTMLElement[];
  const totalBtn = document.querySelector<HTMLElement>('.look__total');
  const totalLabel = totalBtn?.querySelector<HTMLElement>('[data-role="total-label"]');

  function setLook(indexStr: string) {
    dots.forEach(d => d.classList.toggle('is-active', d.dataset.index === indexStr));
    tips.forEach(t => t.classList.toggle('is-active', t.dataset.index === indexStr));
    rows.forEach(r => r.classList.toggle('is-dim', r.dataset.index !== indexStr));
  }

  dots.forEach(d => d.addEventListener('click', () => {
    if (d.dataset.index) setLook(d.dataset.index);
  }));

  rows.forEach(r => r.addEventListener('mouseenter', () => {
    if (r.dataset.index) setLook(r.dataset.index);
  }));

  const money = (symbol: string, n: number) => `${symbol}${n.toLocaleString('en-US', {
    minimumFractionDigits: Number.isInteger(n) ? 0 : 2,
    maximumFractionDigits: 2,
  })}`;

  interface Resolved { id: string; price: number; image: string; available: boolean; color?: string; size?: string; }
  const resolvedByRow = new Map<HTMLElement, Resolved>();

  function updateTotal() {
    if (!totalLabel) return;
    const symbol = rows[0]?.dataset.symbol || '$';
    const total = rows.reduce((sum, r) => sum + (resolvedByRow.get(r)?.price ?? 0), 0);
    totalLabel.textContent = `Add All to Bag — ${money(symbol, total)}`;
  }

  // Build an inline colour/size picker for one row straight from its real
  // Shopify variant matrix — no Quick View round-trip needed for this section.
  function initRow(row: HTMLElement) {
    let variants: any[] = [];
    let options: any[] = [];
    try { variants = row.dataset.variants ? JSON.parse(row.dataset.variants) : []; } catch { variants = []; }
    try { options = row.dataset.options ? JSON.parse(row.dataset.options) : []; } catch { options = []; }
    let swatchHex: Record<string, string> = {};
    try { swatchHex = row.dataset.swatchHex ? JSON.parse(row.dataset.swatchHex) : {}; } catch { swatchHex = {}; }
    void options;

    const addBtn = row.querySelector<HTMLButtonElement>('.look__row-add');
    const colorsEl = row.querySelector<HTMLElement>('[data-role="colors"]');
    const sizesEl = row.querySelector<HTMLElement>('[data-role="sizes"]');
    const optLine = row.querySelector<HTMLElement>('[data-role="opt-line"]');
    const priceEl = row.querySelector<HTMLElement>('[data-role="price"]');
    const imgEl = row.querySelector<HTMLImageElement>('.look__row-img');
    const symbol = row.dataset.symbol || '$';

    if (!variants.length) {
      if (addBtn) addBtn.disabled = true;
      return;
    }

    const optNames = Object.keys(variants[0].opts || {}).filter((n) => !/^title$/i.test(n));
    const colorKey = optNames.find((n) => /colou?r/i.test(n)) || '';
    const sizeKey = optNames.find((n) => /size/i.test(n)) || optNames.find((n) => n !== colorKey) || '';

    const distinct = (key: string) => {
      const seen: string[] = [];
      variants.forEach((v) => { const val = v.opts[key]; if (val && !seen.includes(val)) seen.push(val); });
      return seen;
    };
    const colors = colorKey ? distinct(colorKey) : [];
    const sizes = sizeKey ? distinct(sizeKey) : [];

    const seed = variants.find((v) => v.available) || variants[0];
    const selected: Record<string, string> = { ...seed.opts };

    function currentVariant() {
      return variants.find((v) => Object.keys(selected).every((k) => v.opts[k] === selected[k])) || null;
    }
    function optionAvailable(key: string, value: string) {
      const trial = { ...selected, [key]: value };
      return variants.some((v) => v.available && Object.keys(trial).every((k) => v.opts[k] === trial[k]));
    }

    function resolve() {
      const v = currentVariant();
      const resolved: Resolved = {
        id: v?.id || seed.id,
        price: v ? v.price : seed.price,
        image: v?.img || row.dataset.img || '',
        available: !!(v && v.available),
        color: colorKey ? selected[colorKey] : undefined,
        size: sizeKey ? selected[sizeKey] : undefined,
      };
      resolvedByRow.set(row, resolved);

      if (priceEl) priceEl.textContent = money(symbol, resolved.price);
      if (imgEl && resolved.image) imgEl.src = resolved.image;
      if (addBtn) addBtn.disabled = !resolved.available;
      if (optLine) optLine.textContent = [resolved.color, resolved.size].filter(Boolean).join(' · ');

      colorsEl?.querySelectorAll<HTMLElement>('.look__sw').forEach((el) => {
        const val = el.dataset.value || '';
        el.classList.toggle('is-active', selected[colorKey] === val);
        el.classList.toggle('is-unavailable', !!colorKey && !optionAvailable(colorKey, val));
      });
      sizesEl?.querySelectorAll<HTMLButtonElement>('.look__size').forEach((el) => {
        const val = el.dataset.value || '';
        const ok = !sizeKey || optionAvailable(sizeKey, val);
        el.classList.toggle('is-active', selected[sizeKey] === val);
        el.disabled = !ok;
        el.classList.toggle('is-oos', !ok);
      });

      updateTotal();
    }

    if (colors.length > 1 && colorsEl) {
      colorsEl.hidden = false;
      colorsEl.innerHTML = colors.map((c) =>
        `<span class="look__sw" data-value="${c}" style="background:${swatchHex[c.toLowerCase()] || '#858A76'}" title="${c}"></span>`
      ).join('');
      colorsEl.querySelectorAll<HTMLElement>('.look__sw').forEach((sw) => sw.addEventListener('click', () => {
        if (sw.classList.contains('is-unavailable')) return;
        selected[colorKey] = sw.dataset.value || '';
        resolve();
      }));
    }

    if (sizes.length > 1 && sizesEl) {
      sizesEl.hidden = false;
      sizesEl.innerHTML = sizes.map((s) =>
        `<button type="button" class="look__size" data-value="${s}">${s.toUpperCase()}</button>`
      ).join('');
      sizesEl.querySelectorAll<HTMLButtonElement>('.look__size').forEach((btn) => btn.addEventListener('click', () => {
        if (btn.disabled) return;
        selected[sizeKey] = btn.dataset.value || '';
        resolve();
      }));
    }

    resolve();
  }

  rows.forEach(initRow);

  function addRowToBag(row: HTMLElement) {
    const resolved = resolvedByRow.get(row);
    if (!resolved || !resolved.available) return false;
    addToCart({
      id: resolved.id,
      name: row.dataset.name || '',
      price: resolved.price,
      image: resolved.image || row.dataset.img || '',
      color: resolved.color,
      size: resolved.size,
      description: row.dataset.handle || '',
    }, 1);
    return true;
  }

  rows.forEach((row) => {
    row.querySelector('.look__row-add')?.addEventListener('click', (e) => {
      e.preventDefault();
      addRowToBag(row);
    });
  });

  // Every row is fully resolved inline (colour + size already chosen or
  // defaulted) — add them all in one shot, no modal hand-off, no silent drops.
  totalBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    rows.forEach((row) => addRowToBag(row));
  });
</script>

<style>
  @keyframes hsPulse {
    0% {
      transform: scale(.8);
      opacity: .9;
    }
    100% {
      transform: scale(1.7);
      opacity: 0;
    }
  }

  .look {
    background: var(--lux-light-surface);
  }

  .look__inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: var(--section-y) var(--gutter);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 5vw, 80px);
    align-items: center;
  }

  .look__stage {
    position: relative;
    overflow: hidden;
    background: var(--lux-light-bg);
    aspect-ratio: 1/1;
  }

  .look__stage img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .look__dot {
    position: absolute;
    z-index: 3;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    background: rgba(252, 252, 248, .94);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px -3px rgba(23, 26, 21, .45);
    transition: transform .3s var(--ease), background .3s var(--ease);
  }

  .look__dot::after {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--lux-on-light);
    transition: background .3s var(--ease);
  }

  .look__dot::before {
    content: "";
    position: absolute;
    inset: -7px;
    border-radius: 50%;
    border: 1px solid rgba(48, 56, 44, .28);
    animation: hsPulse 2.6s var(--ease) infinite;
  }

  .look__dot:hover,
  .look__dot.is-active {
    transform: scale(1.12);
    background: var(--lux-primary-dark);
  }

  .look__dot.is-active::after,
  .look__dot:hover::after {
    background: var(--lux-accent-lime);
  }

  .look__tip {
    position: absolute;
    z-index: 4;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 9px 16px 9px 9px;
    background: var(--lux-light-elevated);
    border-radius: 0;
    box-shadow: 0 14px 34px -12px rgba(23, 26, 21, .4);
    opacity: 0;
    transform: translateY(8px) scale(.96);
    pointer-events: none;
    transition: opacity .3s var(--ease), transform .3s var(--ease);
    white-space: nowrap;
  }

  .look__tip.is-active {
    opacity: 1;
    transform: none;
  }

  .look__tip img {
    width: 42px;
    height: 42px;
    object-fit: cover;
    border-radius: 0;
  }

  .look__tip-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--lux-on-light);
  }

  .look__tip-price {
    font-size: 13px;
    color: var(--lux-on-light-soft);
  }

  .look__panel-head {
    text-align: center;
    margin-bottom: clamp(20px, 2.5vw, 30px);
  }

  .look__panel-eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--lux-on-light-soft);
  }

  .look__panel-title {
    position: relative;
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(34px, 4.2vw, 60px);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -1.3px;
    color: var(--lux-on-light);
    margin: 8px 0 40px;
  }

  .look__panel-title::after {
    content: "";
    position: absolute;
    left: 12%;
    right: 12%;
    bottom: -8px;
    height: 3px;
    border-radius: 0;
  }

  .look__set {
    display: flex;
    flex-direction: column;
  }

  .look__row {
    display: grid;
    grid-template-columns: 66px 1fr auto;
    gap: 16px;
    align-items: center;
    padding: 18px 0;
    border-top: 1px solid var(--lux-light-border);
    cursor: pointer;
    transition: opacity .35s var(--ease);
  }

  .look__row:last-of-type {
    border-bottom: 1px solid var(--lux-light-border);
  }

  .look__row.is-dim {
    opacity: .45;
  }

  .look__row-thumb {
    width: 66px;
    height: 66px;
    overflow: hidden;
    background: var(--lux-light-bg);
  }

  .look__row-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .look__row-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--lux-on-light);
  }

  .look__opt-line {
    font-size: 11px;
    letter-spacing: .3px;
    text-transform: capitalize;
    color: var(--lux-on-light-soft);
    margin-top: 4px;
    min-height: 14px;
  }

  .look__sw-row {
    display: flex;
    gap: 6px;
    margin-top: 8px;
  }

  :global(.look__sw) {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 1px solid var(--lux-light-border-strong);
    cursor: pointer;
    outline: 2px solid transparent;
    outline-offset: 2px;
    transition: outline-color .2s var(--ease), transform .2s var(--ease);
  }

  :global(.look__sw:hover) {
    transform: scale(1.1);
  }

  :global(.look__sw.is-active) {
    outline-color: var(--lux-primary-dark);
  }

  :global(.look__sw.is-unavailable) {
    opacity: .35;
    cursor: not-allowed;
  }

  .look__sizes-row {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 8px;
  }

  :global(.look__size) {
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: .3px;
    color: var(--lux-on-light-soft);
    border: 1px solid var(--lux-light-border-strong);
    background: var(--lux-light-elevated);
    min-width: 28px;
    height: 28px;
    padding: 0 8px;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background .25s var(--ease), color .25s var(--ease), border-color .25s var(--ease);
  }

  :global(.look__size:hover) {
    border-color: var(--lux-primary-dark);
  }

  :global(.look__size.is-active) {
    background: var(--lux-primary-dark);
    color: var(--lux-text-primary);
    border-color: var(--lux-primary-dark);
  }

  :global(.look__size.is-oos) {
    opacity: .35;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  .look__row-add {
    display: inline-block;
    margin-top: 10px;
    font-size: 12px;
    font-weight: 600;
    color: var(--lux-on-light);
    border-bottom: 1px solid var(--lux-on-light);
    padding-bottom: 1px;
    background: none;
    border-left: none;
    border-right: none;
    border-top: none;
    padding-left: 0;
    padding-right: 0;
    cursor: pointer;
  }

  .look__row-add:hover {
    color: var(--lux-secondary-olive);
    border-color: var(--lux-secondary-olive);
  }

  .look__row-add:disabled {
    opacity: .4;
    cursor: not-allowed;
  }

  .look__row-price {
    font-size: 15px;
    font-weight: 600;
    color: var(--lux-on-light);
    white-space: nowrap;
  }

  .look__total {
    width: 100%;
    justify-content: center;
    margin-top: 28px;
    padding: 18px;
    background: var(--lux-primary-dark);
    color: var(--lux-text-primary);
    border: 1px solid var(--lux-primary-dark);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: background .28s var(--ease), color .28s var(--ease), border-color .28s var(--ease);
  }

  .look__total:hover {
    background: var(--lux-accent-hover);
    color: var(--lux-bg-dark);
    border-color: var(--lux-accent-hover);
  }

  .look__guide {
    display: block;
    text-align: center;
    margin-top: 16px;
    font-size: 13px;
    font-weight: 600;
    color: var(--lux-on-light);
  }

  .look__guide span {
    border-bottom: 1px solid var(--lux-on-light);
    padding-bottom: 2px;
  }

  @media (max-width: 860px) {
    .look__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
