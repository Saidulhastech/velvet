---
import BaseLayout from '../components/layout/BaseLayout.astro';
import ProductCard from '../components/product/ProductCard.astro';
import { getShopifyProducts } from '../lib/shopify/client';

const products = await getShopifyProducts(Astro.locals.market);

// Fetch all categories, colors, sizes, materials from catalog
const allMaterials = Array.from(new Set(products.flatMap(p => p.materials)));
const allColors = Array.from(new Set(products.flatMap(p => p.swatches.map(s => s.color))));
// Real per-colour hex, same source ProductCard/Quick View already use — no
// second guessed dictionary, so the filter dot always matches the product's own swatch.
const colorHexMap: Record<string, string> = Object.fromEntries(
  products.flatMap(p => p.swatches.map(s => [s.color, s.hex]))
);
const allSizes = Array.from(new Set(products.flatMap(p => p.filterSizes)));
const allCategories = Array.from(new Set(products.map(p => p.filterCategory).filter(Boolean)));

// Count products per material for filter counts
const materialCounts = allMaterials.reduce((acc, mat) => {
  acc[mat] = products.filter(p => p.materials.includes(mat)).length;
  return acc;
}, {} as Record<string, number>);

// Real min/max from the catalog — a hardcoded 100 floor previously collided
// with a hardcoded min="100" on the slider whenever every real price was under
// 100 (e.g. a catalog of ~$1 test products), making min === max and leaving
// the slider with zero travel distance (undraggable). Guard against an empty
// catalogue (Shopify down + no mocks) → Math.max()/min() of an empty list is
// ±Infinity, which also breaks the range slider.
const prices = products.map(p => p.price);
const minPrice = prices.length ? Math.floor(Math.min(...prices)) : 0;
const rawMaxPrice = prices.length ? Math.ceil(Math.max(...prices)) : 1000;
// Always leave real travel room even for a very cheap catalog.
const maxPrice = Math.max(rawMaxPrice, minPrice + 20);
const priceStep = maxPrice - minPrice > 200 ? 20 : 1;
---

<BaseLayout title="Shop the Collection" description="Shop the full Maison Arden collection — tailoring, outerwear, knitwear, denim and accessories in natural fibres. Filter by category, colour, size and material.">

  <!-- SHOP HERO -->
  <section class="shop-hero">
    <div class="shop-hero__inner">
      <div class="shop-hero__crumb"><a href="/">Home</a> &nbsp;/&nbsp; <span>Shop</span></div>
      <h1 class="shop-hero__title">The <em>Collection</em></h1>
      <p class="shop-hero__sub">Considered pieces in natural fibres, finished by hand. Explore the full Maison Arden wardrobe.</p>
    </div>
  </section>

  <!-- FILTER OVERLAY FOR MOBILE -->
  <div class="filter-overlay" data-filter-overlay aria-hidden="true"></div>

  <!-- SHOP LAYOUT -->
  <section class="shop-layout" aria-label="Shop products">
    <!-- FILTERS SIDEBAR -->
    <aside class="filters" id="filters">
      <div class="filters__head">
        <span class="filters__title">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M1 3h14M4 8h8M6 13h4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
          </svg> 
          Filters
        </span>
        <button class="filters__clear" data-clear-filters>Clear All</button>
        <button class="filters__close" data-filter-close aria-label="Close filters">
          <svg width="16" height="16" viewBox="0 0 18 18" fill="none">
            <path d="M3 3l12 12M15 3L3 15" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
          </svg>
        </button>
      </div>

      <!-- Category Filter — only shown when the catalog actually has real
           category data (Shopify's `productType` field set on products) -->
      {allCategories.length > 0 && (
        <div class="fgroup is-open">
          <button class="fgroup__toggle">
            Category
            <svg class="fgroup__icon" width="11" height="7" viewBox="0 0 11 7" fill="none">
              <path d="M1 1l4.5 4.5L10 1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
            </svg>
          </button>
          <div class="fgroup__body">
            <div class="fpills">
              <button class="fpill is-active" data-group="cat" data-value="all">All</button>
              {allCategories.map(cat => (
                <button class="fpill" data-group="cat" data-value={cat}>{cat.charAt(0).toUpperCase() + cat.slice(1)}</button>
              ))}
            </div>
          </div>
        </div>
      )}

      <!-- Color Swatches Filter -->
      <div class="fgroup is-open">
        <button class="fgroup__toggle">
          Colour 
          <svg class="fgroup__icon" width="11" height="7" viewBox="0 0 11 7" fill="none">
            <path d="M1 1l4.5 4.5L10 1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
          </svg>
        </button>
        <div class="fgroup__body">
          <div class="fswatches">
            {allColors.map((color) => (
              <div class="fswatch" data-group="color" data-value={color}>
                <span class="fswatch__dot" style={`background: ${colorHexMap[color.trim().toLowerCase()] || '#858A76'}`}></span>
                <span class="fswatch__name">{color.charAt(0).toUpperCase() + color.slice(1)}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Size Filter -->
      <div class="fgroup is-open">
        <button class="fgroup__toggle">
          Size 
          <svg class="fgroup__icon" width="11" height="7" viewBox="0 0 11 7" fill="none">
            <path d="M1 1l4.5 4.5L10 1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
          </svg>
        </button>
        <div class="fgroup__body">
          <div class="fpills">
            {allSizes.map(size => (
              <button class="fpill" data-group="size" data-value={size}>{size.toUpperCase()}</button>
            ))}
          </div>
        </div>
      </div>

      <!-- Material Checkbox Filter -->
      {allMaterials.length > 0 && (
        <div class="fgroup is-open">
          <button class="fgroup__toggle">
            Material
            <svg class="fgroup__icon" width="11" height="7" viewBox="0 0 11 7" fill="none">
              <path d="M1 1l4.5 4.5L10 1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
            </svg>
          </button>
          <div class="fgroup__body">
            <div class="fchecks">
              {allMaterials.map((mat) => (
                <label class="fcheck">
                  <input type="checkbox" data-group="material" data-value={mat} />
                  <span class="fcheck__label">
                    {mat.charAt(0).toUpperCase() + mat.slice(1)}
                    <span class="fcheck__count">{materialCounts[mat] || 0}</span>
                  </span>
                </label>
              ))}
            </div>
          </div>
        </div>
      )}

      <!-- Stock Status Filter -->
      <div class="fgroup is-open">
        <button class="fgroup__toggle">
          Availability 
          <svg class="fgroup__icon" width="11" height="7" viewBox="0 0 11 7" fill="none">
            <path d="M1 1l4.5 4.5L10 1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
          </svg>
        </button>
        <div class="fgroup__body">
          <div class="fpills">
            <button class="fpill" data-group="stock" data-value="in">In Stock</button>
            <button class="fpill" data-group="stock" data-value="pre">Pre-Order</button>
          </div>
        </div>
      </div>

      <!-- Price Range Filter -->
      <div class="fgroup is-open">
        <button class="fgroup__toggle">
          Price 
          <svg class="fgroup__icon" width="11" height="7" viewBox="0 0 11 7" fill="none">
            <path d="M1 1l4.5 4.5L10 1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
          </svg>
        </button>
        <div class="fgroup__body">
          <div class="fprice">
            <div class="fprice__readout">Up to <strong data-price-readout>{`€${maxPrice}`}</strong></div>
            <input class="fprice__range" type="range" min={minPrice} max={maxPrice} value={maxPrice} step={priceStep} data-price-range aria-label="Maximum price" />
          </div>
        </div>
      </div>
    </aside>

    <!-- SHOP MAIN RESULTS -->
    <div class="shop-main">
      <div class="shop-toolbar">
        <div class="shop-toolbar__count">
          <strong data-shop-shown>{Math.min(16, products.length)}</strong> of <span data-shop-total>{products.length}</span> pieces
        </div>
        <div class="shop-toolbar__right">
          <button class="filter-toggle" data-filter-open>
            <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
              <path d="M1 3h14M4 8h8M6 13h4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
            </svg> 
            Filters
          </button>
          
          <div class="shop-sort">
            <select data-sort aria-label="Sort">
              <option value="featured">Featured</option>
              <option value="price-asc">Price: Low to High</option>
              <option value="price-desc">Price: High to Low</option>
              <option value="name">Alphabetical</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Active Filter Chips Box -->
      <div class="shop-active" data-active-chips></div>
      
      <!-- Catalog Grid -->
      <div class="shop-grid" id="shopGrid">
        {products.map((product) => (
          <ProductCard 
            product={product} 
            class="shop-pc" 
          />
        ))}
      </div>
      
      <!-- Empty State -->
      <div class="shop-empty" data-shop-empty>
        <p>No products match your selected filters. Try removing some filters to explore more pieces.</p>
      </div>

      <!-- Load More Button -->
      <div class="shop-more" data-more-container>
        <div class="shop-more__bar">
          <div class="shop-more__fill" data-more-fill style="width: 80%"></div>
        </div>
        <div class="shop-more__text">
          Showing <strong data-shop-shown>{Math.min(16, products.length)}</strong> of <span data-shop-total>{products.length}</span> pieces
        </div>
        <button class="btn-dark shop-more__btn" data-load-more>Load More Pieces</button>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER CTA -->
  <section class="news" id="newsletter" aria-label="Newsletter">
    <div class="news__inner">
      <div class="news__card reveal">
        <span class="news__ghost" aria-hidden="true">Arden</span>
        <div class="news__left">
          <span class="news__eyebrow">The Maison Letter</span>
          <h2 class="news__title">Considered style, <em>in your inbox.</em></h2>
          <p class="news__sub">Be first to see new collections, atelier stories and seasonal lookbooks — thoughtfully
            sent, never noisy.</p>
        </div>
        <div class="news__right">
          <form class="news__form" onsubmit="return false;">
            <input class="news__input" type="email" placeholder="Your email address" aria-label="Email" required />
            <button class="news__btn" type="submit">Subscribe</button>
          </form>
          <div class="news__benefits">
            <span class="news__benefit"><svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"
                  stroke-linejoin="round" />
              </svg> Early Access</span>
            <span class="news__benefit"><svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"
                  stroke-linejoin="round" />
              </svg> Member Events</span>
            <span class="news__benefit"><svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"
                  stroke-linejoin="round" />
              </svg> Seasonal Lookbooks</span>
          </div>
          <p class="news__note">By subscribing you agree to our Privacy Policy. Unsubscribe anytime.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const grid = document.getElementById('shopGrid');
  if (grid) {
    const cards = Array.from(grid.querySelectorAll('.shop-pc')) as HTMLElement[];
    const STEP = 8;
    const rangeInput = document.querySelector('[data-price-range]') as HTMLInputElement;
    const initialPriceMax = rangeInput ? parseInt(rangeInput.max, 10) : 900;

    const state = {
      cat: 'all',
      color: new Set<string>(),
      size: new Set<string>(),
      material: new Set<string>(),
      stock: new Set<string>(),
      price: initialPriceMax,
      sort: 'featured',
      shown: 16
    };

    const LABELS: Record<string, string> = { in: 'In Stock', pre: 'Pre-Order' };

    // Toggle filter groups open/close
    document.querySelectorAll('.fgroup__toggle').forEach(t => {
      t.addEventListener('click', () => t.closest('.fgroup')?.classList.toggle('is-open'));
    });

    // Helper: check intersection between filter set and space-separated list
    function inter(setObj: Set<string>, listStr: string) {
      if (!listStr) return false;
      // Values are '|'-joined so multi-word colours ("light blue") stay intact.
      const list = listStr.split('|');
      return Array.from(setObj).some(x => list.includes(x));
    }

    // Helper: evaluate if card matches all current filters
    function matches(c: HTMLElement) {
      if (state.cat !== 'all' && c.dataset.fcat !== state.cat) return false;
      if (state.color.size && !inter(state.color, c.dataset.color || '')) return false;
      if (state.size.size && !inter(state.size, c.dataset.size || '')) return false;
      if (state.material.size && !inter(state.material, c.dataset.material || '')) return false;
      if (state.stock.size && !state.stock.has(c.dataset.stock || '')) return false;
      if (parseFloat(c.dataset.pnum || '0') > state.price) return false;
      
      // Match gender from URL parameter behind the scenes if active
      if ((state as any).gender && (state as any).gender !== 'all') {
        const genderVal = (state as any).gender;
        const cardGender = (c.dataset.cat || '').toLowerCase(); // e.g. "women · outerwear"
        if (!cardGender.includes(genderVal) && genderVal !== 'unisex') return false;
      }
      return true;
    }

    // Render logic: filter, sort and slice product cards
    function render() {
      let arr = cards.filter(matches);

      // Sorting
      if (state.sort === 'price-asc') {
        arr.sort((a, b) => parseFloat(a.dataset.pnum || '0') - parseFloat(b.dataset.pnum || '0'));
      } else if (state.sort === 'price-desc') {
        arr.sort((a, b) => parseFloat(b.dataset.pnum || '0') - parseFloat(a.dataset.pnum || '0'));
      } else if (state.sort === 'name') {
        arr.sort((a, b) => (a.dataset.name || '').localeCompare(b.dataset.name || ''));
      }

      // Hide all first
      cards.forEach(c => {
        c.classList.add('pc--hidden');
        c.style.order = '';
      });

      // Show matching cards up to shown limit
      arr.forEach((c, idx) => {
        c.style.order = String(idx);
        if (idx < state.shown) {
          c.classList.remove('pc--hidden');
        }
      });

      const visible = Math.min(state.shown, arr.length);
      const total = arr.length;

      // Update counters
      document.querySelectorAll('[data-shop-shown]').forEach(e => e.textContent = String(visible));
      document.querySelectorAll('[data-shop-total]').forEach(e => e.textContent = String(total));

      // Progress bar fill
      const fill = document.querySelector('[data-more-fill]') as HTMLElement;
      if (fill) {
        fill.style.width = (total ? (visible / total * 100) : 0) + '%';
      }

      // Hide Load More if fully loaded
      const moreBtn = document.querySelector('[data-load-more]') as HTMLElement;
      if (moreBtn) {
        moreBtn.classList.toggle('is-done', visible >= total);
      }

      // Empty state
      const emptyState = document.querySelector('[data-shop-empty]') as HTMLElement;
      if (emptyState) {
        emptyState.classList.toggle('is-shown', total === 0);
      }

      renderChips();
      writeUrl();
    }

    // Mirror the active filter state into the URL (shareable + survives reload).
    function writeUrl() {
      const p = new URLSearchParams();
      if (state.cat !== 'all') p.set('category', state.cat);
      if (state.color.size) p.set('color', Array.from(state.color).join(','));
      if (state.size.size) p.set('size', Array.from(state.size).join(','));
      if (state.material.size) p.set('material', Array.from(state.material).join(','));
      if (state.stock.size) p.set('stock', Array.from(state.stock).join(','));
      if (state.price < initialPriceMax) p.set('price', String(state.price));
      if (state.sort !== 'featured') p.set('sort', state.sort);
      if ((state as any).gender && (state as any).gender !== 'all') p.set('gender', (state as any).gender);
      const qs = p.toString();
      history.replaceState(null, '', qs ? `?${qs}` : window.location.pathname);
    }

    // Render filter chips
    function renderChips() {
      const box = document.querySelector('[data-active-chips]') as HTMLElement;
      if (!box) return;

      const X = '<svg width="9" height="9" viewBox="0 0 10 10" fill="none"><path d="M1 1l8 8M9 1L1 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>';
      const chips: [string, string, string][] = [];

      if (state.cat !== 'all') chips.push(['cat', state.cat, state.cat]);
      state.color.forEach(c => chips.push(['color', c, c]));
      state.size.forEach(s => chips.push(['size', s, s.toUpperCase()]));
      state.material.forEach(m => chips.push(['material', m, m]));
      state.stock.forEach(s => chips.push(['stock', s, LABELS[s] || s]));
      if (state.price < initialPriceMax) chips.push(['price', '', 'Up to €' + state.price]);

      box.innerHTML = chips
        .map(([g, v, label]) => `<span class="achip">${label}<button data-chip-group="${g}" data-chip-value="${v}" aria-label="Remove">${X}</button></span>`)
        .join('');
    }

    // Bind event listeners to filters: Category pills
    document.querySelectorAll('.fpill[data-group="cat"]').forEach(p => {
      const btn = p as HTMLButtonElement;
      btn.addEventListener('click', () => {
        const val = btn.dataset.value;
        if (!val) return;
        state.cat = val;
        document.querySelectorAll('.fpill[data-group="cat"]').forEach(x => x.classList.toggle('is-active', x === btn));
        state.shown = 16;
        render();
      });
    });

    // Size & Availability filter pills (multiple selection)
    document.querySelectorAll('.fpill[data-group="size"], .fpill[data-group="stock"]').forEach(p => {
      const btn = p as HTMLButtonElement;
      btn.addEventListener('click', () => {
        const group = btn.dataset.group;
        const val = btn.dataset.value;
        if (!group || !val) return;
        const set = (state as any)[group] as Set<string>;
        btn.classList.toggle('is-active');
        if (btn.classList.contains('is-active')) {
          set.add(val);
        } else {
          set.delete(val);
        }
        state.shown = 16;
        render();
      });
    });

    // Color Swatches
    document.querySelectorAll('.fswatch').forEach(s => {
      const sw = s as HTMLElement;
      sw.addEventListener('click', () => {
        const val = sw.dataset.value;
        if (!val) return;

        sw.classList.toggle('is-active');
        if (sw.classList.contains('is-active')) {
          state.color.add(val);
        } else {
          state.color.delete(val);
        }
        state.shown = 16;
        render();
      });
    });

    // Material checkboxes
    document.querySelectorAll('.fcheck input').forEach(ch => {
      const input = ch as HTMLInputElement;
      input.addEventListener('change', () => {
        const val = input.dataset.value;
        if (!val) return;

        if (input.checked) {
          state.material.add(val);
        } else {
          state.material.delete(val);
        }
        state.shown = 16;
        render();
      });
    });

    // Price range slider
    const range = document.querySelector('[data-price-range]') as HTMLInputElement;
    const readout = document.querySelector('[data-price-readout]') as HTMLElement;
    if (range) {
      range.addEventListener('input', () => {
        state.price = parseFloat(range.value);
        if (readout) readout.textContent = '€' + range.value;
        state.shown = 16;
        render();
      });
    }

    // Sort selection change
    const sortSel = document.querySelector('[data-sort]') as HTMLSelectElement;
    if (sortSel) {
      sortSel.addEventListener('change', () => {
        state.sort = sortSel.value;
        render();
      });
    }

    // Load More action
    const moreBtn = document.querySelector('[data-load-more]');
    if (moreBtn) {
      moreBtn.addEventListener('click', () => {
        state.shown += STEP;
        render();
      });
    }

    // Active filter chips click to remove
    const chipsBox = document.querySelector('[data-active-chips]');
    if (chipsBox) {
      chipsBox.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const b = target.closest('[data-chip-group]') as HTMLElement;
        if (!b) return;

        const group = b.dataset.chipGroup;
        const val = b.dataset.chipValue;
        if (!group) return;

        if (group === 'cat') {
          state.cat = 'all';
          document.querySelectorAll('.fpill[data-group="cat"]').forEach(x => {
            x.classList.toggle('is-active', (x as HTMLElement).dataset.value === 'all');
          });
        } else if (group === 'color') {
          state.color.delete(val || '');
          document.querySelectorAll('.fswatch').forEach(x => {
            if ((x as HTMLElement).dataset.value === val) x.classList.remove('is-active');
          });
        } else if (group === 'material') {
          state.material.delete(val || '');
          document.querySelectorAll('.fcheck input').forEach(x => {
            const input = x as HTMLInputElement;
            if (input.dataset.value === val) input.checked = false;
          });
        } else if (group === 'price') {
          state.price = initialPriceMax;
          if (range) range.value = String(initialPriceMax);
          if (readout) readout.textContent = '€' + initialPriceMax;
        } else {
          const set = (state as any)[group] as Set<string>;
          set.delete(val || '');
          document.querySelectorAll(`.fpill[data-group="${group}"]`).forEach(x => {
            if ((x as HTMLElement).dataset.value === val) x.classList.remove('is-active');
          });
        }
        state.shown = 16;
        render();
      });
    }

    // Clear all filters
    document.querySelectorAll('[data-clear-filters]').forEach(b => {
      b.addEventListener('click', () => {
        state.cat = 'all';
        state.color.clear();
        state.size.clear();
        state.material.clear();
        state.stock.clear();
        state.price = initialPriceMax;
        state.shown = 16;

        document.querySelectorAll('.fpill[data-group="cat"]').forEach(x => {
          x.classList.toggle('is-active', (x as HTMLElement).dataset.value === 'all');
        });
        document.querySelectorAll('.fpill[data-group="size"], .fpill[data-group="stock"]').forEach(x => {
          x.classList.remove('is-active');
        });
        document.querySelectorAll('.fswatch').forEach(x => x.classList.remove('is-active'));
        document.querySelectorAll('.fcheck input').forEach(x => {
          (x as HTMLInputElement).checked = false;
        });
        if (range) range.value = String(initialPriceMax);
        if (readout) readout.textContent = '€' + initialPriceMax;
        render();
      });
    });

    // Mobile filters drawer open/close
    const filtersSidebar = document.getElementById('filters');
    const fov = document.querySelector('[data-filter-overlay]');

    const openFilters = () => {
      filtersSidebar?.classList.add('is-open');
      fov?.classList.add('is-open');
      document.body.classList.add('no-scroll');
    };

    const closeFilters = () => {
      filtersSidebar?.classList.remove('is-open');
      fov?.classList.remove('is-open');
      document.body.classList.remove('no-scroll');
    };

    document.querySelectorAll('[data-filter-open]').forEach(b => b.addEventListener('click', openFilters));
    document.querySelectorAll('[data-filter-close]').forEach(b => b.addEventListener('click', closeFilters));
    if (fov) fov.addEventListener('click', closeFilters);

    // Reflect all filter UI classes/inputs from the current state.
    function syncFilterUI() {
      document.querySelectorAll('.fpill[data-group="cat"]').forEach(x => x.classList.toggle('is-active', (x as HTMLElement).dataset.value === state.cat));
      document.querySelectorAll('.fpill[data-group="size"]').forEach(x => x.classList.toggle('is-active', state.size.has((x as HTMLElement).dataset.value || '')));
      document.querySelectorAll('.fpill[data-group="stock"]').forEach(x => x.classList.toggle('is-active', state.stock.has((x as HTMLElement).dataset.value || '')));
      document.querySelectorAll('.fswatch').forEach(x => x.classList.toggle('is-active', state.color.has((x as HTMLElement).dataset.value || '')));
      document.querySelectorAll('.fcheck input').forEach(x => { const i = x as HTMLInputElement; i.checked = state.material.has(i.dataset.value || ''); });
      if (range) range.value = String(state.price);
      if (readout) readout.textContent = '€' + state.price;
      if (sortSel) sortSel.value = state.sort;
    }

    // Hydrate filter state from the URL (?category, ?color, ?size, …, ?gender).
    function applyUrl() {
      const params = new URLSearchParams(window.location.search);
      const csv = (k: string) => new Set((params.get(k) || '').split(',').filter(Boolean));
      state.cat = (params.get('category') || 'all').toLowerCase();
      state.color = csv('color');
      state.size = csv('size');
      state.material = csv('material');
      state.stock = csv('stock');
      const priceP = params.get('price');
      state.price = priceP ? parseFloat(priceP) : initialPriceMax;
      state.sort = params.get('sort') || 'featured';
      const gender = params.get('gender');
      if (gender) (state as any).gender = gender.toLowerCase(); else delete (state as any).gender;
      state.shown = 16;
      syncFilterUI();
    }

    applyUrl();
    render();

    // Back/forward re-applies the filter state.
    window.addEventListener('popstate', () => { applyUrl(); render(); });
  }
</script>

