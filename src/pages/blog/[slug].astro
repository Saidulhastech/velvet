---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

import authorAvatar from '../../assets/images/Product Image 17.png';

const { slug } = Astro.params;
const entry = await getEntry('blog', slug || '');
if (!entry) {
  return Astro.redirect('/404');
}
const { Content } = await render(entry);

// Fetch other posts for related and navigation
const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));
const currentIndex = sortedPosts.findIndex(p => p.id === entry.id);
const prevPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
const nextPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;

const relatedPosts = allPosts
  .filter(p => p.id !== entry.id)
  .slice(0, 3);

// Dynamic glob for resolving images
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.{jpeg,jpg,png,gif,webp,WebP}', { eager: true });

const isFeaturedArticle = entry.id === 'building-a-wardrobe-that-lasts-a-decade';
const featureImgPath = isFeaturedArticle 
  ? '/src/assets/images/post-feature image.png' 
  : `/src/assets/images/${entry.data.image}`;
---

<BaseLayout title={entry.data.title} description={entry.data.excerpt}>
  <div class="post-progress" data-progress></div>

  <!-- POST HERO -->
  <section class="post-hero">
    <div class="post-hero__inner">
      <div class="post-hero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; 
        <a href="/blog">Journal</a> &nbsp;/&nbsp; 
        <span>{entry.data.category}</span>
      </div>
      <span class="post-hero__tag">{entry.data.category}</span>
      <h1 class="post-hero__title">{entry.data.title}</h1>
      <p class="post-hero__sub">{entry.data.excerpt}</p>
      <div class="post-hero__meta">
        <Image class="post-hero__avatar" src={authorAvatar} alt="Hélène Arden" />
        <div class="post-hero__byline">
          <div class="post-hero__author">By Hélène Arden</div>
          <div class="post-hero__date">{entry.data.date} · {entry.data.readTime}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURE IMAGE -->
  <div class="post-feature">
    {images[featureImgPath] && (
      <Image src={images[featureImgPath].default} alt={entry.data.title} loading="eager" width={1440} height={720} style="aspect-ratio: 16/8; object-fit: cover;" />
    )}
  </div>

  <!-- BODY -->
  <div class="post-wrap">
    <div class="post-share">
      <span class="post-share__label">Share</span>
      <a href="#" aria-label="Share on Instagram">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
          <rect x="2.5" y="2.5" width="15" height="15" rx="4" stroke="currentColor" stroke-width="1.3" />
          <circle cx="10" cy="10" r="3.5" stroke="currentColor" stroke-width="1.3" />
          <circle cx="14.5" cy="5.5" r="1" fill="currentColor" />
        </svg>
      </a>
      <a href="#" aria-label="Share on Pinterest">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
          <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.3" />
          <path d="M8 15l2-7m0 0a2.5 2.5 0 1 1 2.4 1.7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
        </svg>
      </a>
      <a href="#" aria-label="Copy link">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
          <path d="M8 12a3 3 0 0 0 4 0l3-3a3 3 0 0 0-4-4l-1 1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M12 8a3 3 0 0 0-4 0l-3 3a3 3 0 0 0 4 4l1-1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>

    <article class="post-body">
      <Content />

      <div class="post-tags">
        <a href="/blog">Wardrobe</a>
        <a href="/blog">Investment Pieces</a>
        <a href="/blog">Care</a>
        <a href="/blog">Slow Fashion</a>
      </div>

      <div class="post-author">
        <Image class="post-author__avatar" src={authorAvatar} alt="Hélène Arden" />
        <div>
          <div class="post-author__name">Hélène Arden</div>
          <div class="post-author__role">Founder &amp; Creative Director</div>
          <p class="post-author__bio">Hélène founded Maison Arden in Paris in 2014 with a single cashmere coat and a belief that fewer, finer things are worth keeping. She writes on craft, materials and dressing with intention.</p>
        </div>
      </div>

      <nav class="post-nav">
        {prevPost ? (
          <a href={`/blog/${prevPost.id}`}>
            <div class="post-nav__dir">← Previous</div>
            <div class="post-nav__t">{prevPost.data.title}</div>
          </a>
        ) : (
          <a href="/blog" style="visibility: hidden;">
            <div class="post-nav__dir">← Journal</div>
          </a>
        )}
        {nextPost ? (
          <a href={`/blog/${nextPost.id}`}>
            <div class="post-nav__dir">Next →</div>
            <div class="post-nav__t">{nextPost.data.title}</div>
          </a>
        ) : (
          <a href="/blog" style="visibility: hidden;">
            <div class="post-nav__dir">Journal →</div>
          </a>
        )}
      </nav>
    </article>
  </div>

  <!-- RELATED -->
  <section class="post-related">
    <div class="post-related__inner">
      <div class="post-related__head reveal">
        <span class="eyebrow eyebrow--center">Keep Reading</span>
        <h2 class="section-title">Related <em>Stories</em></h2>
      </div>
      <div class="post-related__grid">
        {relatedPosts.map((post, idx) => {
          const imagePath = `/src/assets/images/${post.data.image}`;
          return (
            <article class={`bcard reveal d${idx + 1}`}>
              <a href={`/blog/${post.id}`} class="bcard__media">
                <span class="bcard__tag">{post.data.category}</span>
                {images[imagePath] && (
                  <Image src={images[imagePath]()} alt={post.data.title} loading="lazy" />
                )}
              </a>
              <div class="bcard__body">
                <div class="bcard__meta">{post.data.category} · {post.data.readTime}</div>
                <h3 class="bcard__title">{post.data.title}</h3>
                <p class="bcard__excerpt">{post.data.excerpt}</p>
                <a href={`/blog/${post.id}`} class="bcard__btn">
                  Read Article 
                  <svg width="13" height="9" viewBox="0 0 14 10" fill="none">
                    <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
                  </svg>
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- NEWSLETTER CTA -->
  <section class="news" id="newsletter" aria-label="Newsletter">
    <div class="news__inner">
      <div class="news__card reveal">
        <span class="news__ghost" aria-hidden="true">Arden</span>
        <div class="news__left">
          <span class="news__eyebrow">The Maison Letter</span>
          <h2 class="news__title">Considered style, <em>in your inbox.</em></h2>
          <p class="news__sub">Be first to see new collections, atelier stories and seasonal lookbooks — thoughtfully sent, never noisy.</p>
        </div>
        <div class="news__right">
          <form class="news__form" onsubmit="return false;">
            <input class="news__input" type="email" placeholder="Your email address" aria-label="Email" required />
            <button class="news__btn" type="submit">Subscribe</button>
          </form>
          <div class="news__benefits">
            <span class="news__benefit">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Early Access
            </span>
            <span class="news__benefit">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Member Events
            </span>
            <span class="news__benefit">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Seasonal Lookbooks
            </span>
          </div>
          <p class="news__note">By subscribing you agree to our Privacy Policy. Unsubscribe anytime.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Reading progress and copy link features
  const bar = document.querySelector('[data-progress]') as HTMLElement | null;
  const body = document.querySelector('.post-body');
  if (bar && body) {
    const update = () => {
      const r = body.getBoundingClientRect();
      const total = r.height - window.innerHeight + 120;
      const passed = Math.min(Math.max(-r.top + 120, 0), total);
      bar.style.width = (total > 0 ? (passed / total * 100) : 0) + '%';
    };
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
  }

  /* Copy link */
  const copy = document.querySelector('.post-share a[aria-label="Copy link"]');
  if (copy) {
    copy.addEventListener('click', e => {
      e.preventDefault();
      if (navigator.clipboard) {
        navigator.clipboard.writeText(window.location.href);
      }
    });
  }
</script>

<style>
  /* ============================ BLOG DETAILS PAGE ============================ */
  .post-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    width: 0;
    background: var(--lux-accent-lime);
    z-index: 60;
    transition: width .1s linear;
  }

  .post-hero {
    background: var(--lux-light-surface);
    border-bottom: 1px solid var(--lux-light-border);
  }

  .post-hero__inner {
    max-width: 800px;
    margin: 0 auto;
    padding: clamp(36px, 4.5vw, 64px) var(--gutter) clamp(30px, 3.5vw, 48px);
    text-align: center;
  }

  .post-hero__crumb {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--lux-on-light-soft);
    margin-bottom: 22px;
  }

  .post-hero__crumb a {
    color: var(--lux-on-light-soft);
    transition: color .2s var(--ease);
  }

  .post-hero__crumb a:hover {
    color: var(--lux-on-light);
  }

  .post-hero__crumb span {
    color: var(--lux-secondary-olive);
  }

  .post-hero__tag {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--lux-text-primary);
    background: var(--lux-primary-dark);
    padding: 7px 14px;
    margin-bottom: 20px;
  }

  .post-hero__title {
    font-family: var(--font-display);
    font-size: clamp(34px, 5vw, 62px);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -1.4px;
    color: var(--lux-on-light);
    margin: 0;
  }

  .post-hero__sub {
    font-size: clamp(15px, 1.2vw, 19px);
    line-height: 1.7;
    color: var(--lux-on-light-soft);
    margin: 20px auto 0;
    max-width: 56ch;
  }

  .post-hero__meta {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-top: 28px;
  }

  .post-hero__avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    object-fit: cover;
    background: var(--lux-light-bg);
  }

  .post-hero__byline {
    text-align: left;
  }

  .post-hero__author {
    font-size: 13px;
    font-weight: 600;
    color: var(--lux-on-light);
  }

  .post-hero__date {
    font-size: 12px;
    color: var(--lux-on-light-soft);
    margin-top: 2px;
  }

  .post-feature {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(120px, 3.5vw, 48px) var(--gutter) 0;
  }

  .post-feature img {
    width: 100%;
    aspect-ratio: 16/8;
    object-fit: cover;
    display: block;
  }

  .post-wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding: clamp(40px, 5vw, 72px) var(--gutter) var(--section-y);
    display: grid;
    grid-template-columns: 52px 1fr;
    gap: clamp(20px, 4vw, 52px);
    align-items: start;
  }

  .post-share {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .post-share__label {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--lux-on-light-soft);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    margin: 0 auto 6px;
  }

  .post-share a {
    width: 40px;
    height: 40px;
    border: 1px solid var(--lux-light-border-strong);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--lux-on-light);
    transition: background .25s var(--ease), color .25s var(--ease), border-color .25s var(--ease);
  }

  .post-share a:hover {
    background: var(--lux-primary-dark);
    color: var(--lux-text-primary);
    border-color: var(--lux-primary-dark);
  }

  .post-body {
    max-width: 840px;
  }

  /* Target dynamic markdown elements compiled by Astro */
  .post-body :global(p),
  .post-body :global(ul),
  .post-body :global(ol) {
    font-size: clamp(16px, 1.15vw, 18px);
    line-height: 1.85;
    color: var(--lux-on-light-soft);
    margin: 0 0 24px;
  }

  .post-body :global(p strong) {
    color: var(--lux-on-light);
    font-weight: 600;
  }

  .post-body :global(.post-lead) {
    font-size: clamp(18px, 1.4vw, 21px) !important;
    line-height: 1.7 !important;
    color: var(--lux-on-light) !important;
  }

  .post-body :global(p.has-drop::first-letter) {
    float: left;
    font-family: var(--font-display);
    font-size: 68px;
    line-height: .72;
    padding: 8px 14px 0 0;
    color: var(--lux-secondary-olive);
    font-weight: 500;
  }

  .post-body :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(26px, 2.6vw, 36px);
    font-weight: 500;
    letter-spacing: -.6px;
    color: var(--lux-on-light);
    margin: clamp(34px, 4vw, 52px) 0 14px;
    line-height: 1.1;
  }

  .post-body :global(h3) {
    font-family: var(--font-display);
    font-size: clamp(21px, 2vw, 26px);
    font-weight: 500;
    color: var(--lux-on-light);
    margin: 30px 0 10px;
  }

  .post-body :global(.post-quote) {
    margin: clamp(32px, 4vw, 46px) 0;
    padding-left: 26px;
    border-left: 2px solid var(--lux-accent-lime);
  }

  .post-body :global(.post-quote p) {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(23px, 2.6vw, 32px);
    line-height: 1.35;
    letter-spacing: -.4px;
    color: var(--lux-on-light);
    margin: 0;
  }

  .post-body :global(.post-quote cite) {
    display: block;
    font-family: var(--font-body);
    font-style: normal;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--lux-on-light-soft);
    margin-top: 16px;
  }

  .post-body :global(.post-figure) {
    margin: clamp(32px, 4vw, 46px) 0;
  }

  .post-body :global(.post-figure img) {
    width: 100%;
    aspect-ratio: 3/2;
    object-fit: cover;
    display: block;
  }

  .post-body :global(.post-figure figcaption) {
    font-size: 12px;
    color: var(--lux-on-light-soft);
    text-align: center;
    margin-top: 12px;
    font-style: italic;
  }

  .post-body :global(ul.post-list) {
    list-style: none;
    padding: 0;
  }

  .post-body :global(ul.post-list li) {
    position: relative;
    padding-left: 26px;
    margin-bottom: 12px;
  }

  .post-body :global(ul.post-list li::before) {
    content: "";
    position: absolute;
    left: 0;
    top: 11px;
    width: 8px;
    height: 1px;
    background: var(--lux-secondary-olive);
  }

  .post-body :global(.post-key) {
    background: var(--lux-light-surface);
    border: 1px solid var(--lux-light-border);
    padding: clamp(24px, 2.6vw, 34px);
    margin: clamp(32px, 4vw, 46px) 0;
  }

  .post-body :global(.post-key__title) {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--lux-on-light);
    margin-bottom: 16px;
  }

  .post-body :global(.post-key__title svg) {
    color: var(--lux-secondary-olive);
  }

  .post-body :global(.post-key ul) {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-body :global(.post-key li) {
    display: flex;
    gap: 11px;
    align-items: flex-start;
    font-size: 14px;
    line-height: 1.6;
    color: var(--lux-on-light-soft);
    margin-bottom: 11px;
  }

  .post-body :global(.post-key li svg) {
    color: var(--lux-secondary-olive);
    flex-shrink: 0;
    margin-top: 3px;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: clamp(32px, 4vw, 44px) 0 0;
    padding-top: 26px;
    border-top: 1px solid var(--lux-light-border);
  }

  .post-tags a {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .5px;
    color: var(--lux-on-light-soft);
    border: 1px solid var(--lux-light-border-strong);
    padding: 8px 15px;
    transition: border-color .2s var(--ease), color .2s var(--ease);
  }

  .post-tags a:hover {
    border-color: var(--lux-primary-dark);
    color: var(--lux-on-light);
  }

  .post-author {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    margin-top: 34px;
    padding: clamp(24px, 2.6vw, 32px);
    border: 1px solid var(--lux-light-border);
    background: var(--lux-light-surface);
  }

  .post-author__avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    background: var(--lux-light-bg);
  }

  .post-author__name {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 500;
    color: var(--lux-on-light);
  }

  .post-author__role {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--lux-secondary-olive);
    margin-top: 3px;
  }

  .post-author__bio {
    font-size: 14px;
    line-height: 1.7;
    color: var(--lux-on-light-soft);
    margin: 12px 0 0;
  }

  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 24px;
  }

  .post-nav a {
    border: 1px solid var(--lux-light-border);
    background: var(--lux-light-elevated);
    padding: 22px 24px;
    transition: border-color .3s var(--ease), transform .3s var(--ease);
  }

  .post-nav a:hover {
    border-color: var(--lux-light-border-strong);
    transform: translateY(-3px);
  }

  .post-nav__dir {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--lux-on-light-soft);
  }

  .post-nav__t {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 500;
    color: var(--lux-on-light);
    margin-top: 8px;
    line-height: 1.2;
  }

  .post-nav a:last-child {
    text-align: right;
  }

  .post-related {
    background: var(--lux-light-surface);
    border-top: 1px solid var(--lux-light-border);
  }

  .post-related__inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: var(--section-y) var(--gutter);
  }

  .post-related__head {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    margin-bottom: clamp(32px, 4vw, 48px);
  }

  .post-related__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(20px, 2.4vw, 34px);
  }

  /* Related Grid Cards */
  .bcard {
    display: flex;
    flex-direction: column;
    background: var(--lux-light-elevated);
    border: 1px solid var(--lux-light-border);
    border-radius: 0;
    overflow: hidden;
    transition: transform .5s var(--ease), box-shadow .5s var(--ease), border-color .5s var(--ease);
  }

  .bcard:hover {
    transform: translateY(-8px);
    box-shadow: 0 40px 80px -50px rgba(48, 56, 44, .5);
    border-color: var(--lux-light-border-strong);
  }

  .bcard__media {
    position: relative;
    aspect-ratio: 5/4;
    overflow: hidden;
    background: var(--lux-light-surface);
  }

  .bcard__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.1s var(--ease);
  }

  .bcard:hover .bcard__media img {
    transform: scale(1.07);
  }

  .bcard__tag {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 2;
    background: rgba(23, 26, 21, .78);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    color: var(--lux-accent-lime);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.4px;
    text-transform: uppercase;
