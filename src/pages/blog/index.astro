---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { getShopifyArticles } from '~/lib/shopify/client';
import { shopifyImageUrl, shopifySrcset } from '~/lib/shopify/image-url';

// Newest-first (already sorted by the Shopify query) — the first is "featured".
const sortedPosts = await getShopifyArticles(Astro.locals.market);
const featuredPost = sortedPosts[0];
const gridPosts = featuredPost ? sortedPosts.slice(1) : [];

// Category chips generated from whatever categories actually exist on the posts.
const categories = [...new Set(sortedPosts.map(p => p.category))];
---

<BaseLayout title="The Journal" description="Style notes, care guides and stories from the atelier — a slower way to think about what we wear.">
  <!-- HERO -->
  <section class="shop-hero">
    <div class="shop-hero__inner">
      <div class="shop-hero__crumb"><a href="/">Home</a> &nbsp;/&nbsp; <span>Journal</span></div>
      <h1 class="shop-hero__title">The <em>Journal</em></h1>
      <p class="shop-hero__sub">Style notes, care guides and stories from the atelier — a slower way to think about what we wear.</p>
    </div>
  </section>

  <!-- BLOG LISTING -->
  <section class="blog">
    <div class="blog__inner">
      <!-- Featured -->
      {featuredPost && (
        <article class="blogf reveal">
          <a href={`/blog/${featuredPost.handle}`} class="blogf__media">
            <span class="blogf__badge">Featured</span>
            {featuredPost.image && (
              <img
                src={shopifyImageUrl(featuredPost.image, 1100, 756)}
                srcset={shopifySrcset(featuredPost.image, [700, 1100, 1600])}
                sizes="(min-width: 880px) 55vw, 100vw"
                alt={featuredPost.title}
                width="1100"
                height="756"
                loading="eager"
              />
            )}
            <div class="blogf__frame" aria-hidden="true"></div>
          </a>
          <div class="blogf__body">
            <span class="blogf__tag">{featuredPost.category}</span>
            <div class="blogf__meta">Editorial · {featuredPost.readTime} · {featuredPost.date}</div>
            <h2 class="blogf__title"><a href={`/blog/${featuredPost.handle}`}>{featuredPost.title}</a></h2>
            <p class="blogf__excerpt">{featuredPost.excerpt}</p>
            <a href={`/blog/${featuredPost.handle}`} class="btn-dark">
              Read the Story
              <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
                <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
            </a>
          </div>
        </article>
      )}

      <!-- Bar -->
      <div class="blog__bar reveal">
        <span class="blog__bar-title">All Stories</span>
        <div class="blog__cats" data-blog-cats>
          <button class="blog__cat is-active" data-filter="all">All</button>
          {categories.map((cat) => (
            <button class="blog__cat" data-filter={cat.toLowerCase()}>{cat}</button>
          ))}
        </div>
      </div>

      <!-- Grid -->
      <div class="blog__grid" data-blog-grid>
        {gridPosts.map((art, idx) => (
          <article class={`bcard reveal d${(idx % 3) + 1}`} data-cat={art.category.toLowerCase()}>
            <a href={`/blog/${art.handle}`} class="bcard__media">
              <span class="bcard__tag">{art.category}</span>
              {art.image && (
                <img
                  src={shopifyImageUrl(art.image, 480, 384)}
                  srcset={shopifySrcset(art.image, [480, 960])}
                  sizes="(min-width: 880px) 33vw, 50vw"
                  alt={art.title}
                  width="480"
                  height="384"
                  loading="lazy"
                />
              )}
            </a>
            <div class="bcard__body">
              <div class="bcard__meta">{art.category} · {art.readTime}</div>
              <h3 class="bcard__title"><a href={`/blog/${art.handle}`}>{art.title}</a></h3>
              <p class="bcard__excerpt">{art.excerpt}</p>
              <a href={`/blog/${art.handle}`} class="bcard__btn">
                Read Article
                <svg width="13" height="9" viewBox="0 0 14 10" fill="none">
                  <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
      <div class="blog__empty" data-blog-empty>No stories in this category yet.</div>
    </div>
  </section>

  <!-- NEWSLETTER CTA -->
  <section class="news" id="newsletter" aria-label="Newsletter">
    <div class="news__inner">
      <div class="news__card reveal">
        <span class="news__ghost" aria-hidden="true">Arden</span>
        <div class="news__left">
          <span class="news__eyebrow">The Maison Letter</span>
          <h2 class="news__title">Considered style, <em>in your inbox.</em></h2>
          <p class="news__sub">Be first to see new collections, atelier stories and seasonal lookbooks — thoughtfully sent, never noisy.</p>
        </div>
        <div class="news__right">
          <form class="news__form" onsubmit="return false;">
            <input class="news__input" type="email" placeholder="Your email address" aria-label="Email" required />
            <button class="news__btn" type="submit">Subscribe</button>
          </form>
          <div class="news__benefits">
            <span class="news__benefit">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Early Access
            </span>
            <span class="news__benefit">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Member Events
            </span>
            <span class="news__benefit">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Seasonal Lookbooks
            </span>
          </div>
          <p class="news__note">By subscribing you agree to our Privacy Policy. Unsubscribe anytime.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Category filtering logic
  const cats = Array.from(document.querySelectorAll('[data-blog-cats] .blog__cat'));
  const cards = Array.from(document.querySelectorAll('[data-blog-grid] .bcard'));
  const empty = document.querySelector('[data-blog-empty]');

  cats.forEach(c => {
    c.addEventListener('click', () => {
      const filter = c.getAttribute('data-filter');
      
      cats.forEach(x => x.classList.toggle('is-active', x === c));
      
      let shown = 0;
      cards.forEach(card => {
        const cardCat = card.getAttribute('data-cat');
        const ok = filter === 'all' || cardCat === filter;
        card.classList.toggle('is-hidden', !ok);
        if (ok) shown++;
      });
      
      if (empty) {
        empty.classList.toggle('is-shown', shown === 0);
      }
    });
  });
</script>

<style>
  /* ============================ BLOG PAGE ============================ */
  .shop-hero { 
    background: var(--lux-light-surface); 
    border-bottom: 1px solid var(--lux-light-border); 
  }
  .shop-hero__inner { 
    max-width: var(--maxw); 
    margin: 0 auto; 
    padding: clamp(40px,5vw,76px) var(--gutter) clamp(34px,4vw,56px); 
    text-align: center; 
  }
  .shop-hero__crumb { 
    font-size: 11px; 
    font-weight: 500; 
    letter-spacing: 1px; 
    text-transform: uppercase; 
    color: var(--lux-on-light-soft); 
    margin-bottom: 16px; 
  }
  .shop-hero__crumb a { 
    color: var(--lux-on-light-soft); 
    transition: color .2s var(--ease); 
  }
  .shop-hero__crumb a:hover { 
    color: var(--lux-on-light); 
  }
  .shop-hero__crumb span { 
    color: var(--lux-secondary-olive); 
  }
  .shop-hero__title { 
    font-family: var(--font-display); 
    font-size: clamp(40px,5vw,72px); 
    font-weight: 500; 
    line-height: 1; 
    letter-spacing: -1.5px; 
    color: var(--lux-on-light); 
  }
  .shop-hero__title em { 
    font-style: italic; 
    color: var(--lux-secondary-olive); 
  }
  .shop-hero__sub { 
    font-size: clamp(14px,1.05vw,16px); 
    line-height: 1.7; 
    color: var(--lux-on-light-soft); 
    max-width: 58ch; 
    margin: 16px auto 0; 
  }

  .blog { 
    background: var(--lux-light-bg); 
  }
  .blog__inner { 
    max-width: var(--maxw); 
    margin: 0 auto; 
    padding: clamp(40px,5vw,72px) var(--gutter) var(--section-y); 
  }

  .blogf { 
    display: grid; 
    grid-template-columns: 1.15fr 0.85fr; 
    gap: clamp(32px,4vw,64px); 
    align-items: center; 
    margin-bottom: clamp(44px,5vw,72px); 
  }
  .blogf__media { 
    position: relative; 
    aspect-ratio: 16/11; 
    overflow: hidden; 
    background: var(--lux-light-surface); 
  }
  .blogf__media img { 
    width: 100%; 
    height: 100%; 
    object-fit: cover; 
    transition: transform 1.2s var(--ease); 
  }
  .blogf:hover .blogf__media img { 
    transform: scale(1.04); 
  }
  .blogf__frame { 
    position: absolute; 
    inset: 16px; 
    border: 1px solid rgba(244,245,239,.4); 
    pointer-events: none; 
  }
  .blogf__frame::before { 
    content: ""; 
    position: absolute; 
    top: -1px; 
    left: -1px; 
    width: 20px; 
    height: 20px; 
    border-top: 1px solid var(--lux-accent-lime); 
    border-left: 1px solid var(--lux-accent-lime); 
  }
  .blogf__badge { 
    position: absolute; 
    top: 16px; 
    left: 16px; 
    z-index: 2; 
    background: var(--lux-primary-dark); 
    color: var(--lux-accent-lime); 
    font-size: 10px; 
    font-weight: 700; 
    letter-spacing: 1.4px; 
    text-transform: uppercase; 
    padding: 7px 14px; 
  }
  .blogf__tag { 
    font-size: 11px; 
    font-weight: 600; 
    letter-spacing: 1.4px; 
    text-transform: uppercase; 
    color: var(--lux-secondary-olive); 
  }
  .blogf__meta { 
    font-size: 12px; 
    font-weight: 500; 
    letter-spacing: .8px; 
    text-transform: uppercase; 
    color: var(--lux-on-light-soft); 
    margin: 14px 0 12px; 
  }
  .blogf__title {
    font-family: var(--font-display);
    font-size: clamp(30px,3.6vw,50px);
    font-weight: 500;
    line-height: 1.08;
    letter-spacing: -1px;
    color: var(--lux-on-light);
  }
  .blogf__title a {
    color: inherit;
    transition: color .3s var(--ease);
  }
  .blogf__title a:hover {
    color: var(--lux-secondary-olive);
  }
  .blogf__excerpt { 
    font-size: clamp(15px,1.1vw,17px); 
    line-height: 1.75; 
    color: var(--lux-on-light-soft); 
    margin: 18px 0 26px; 
    max-width: 52ch; 
  }

  .blog__bar { 
    display: flex; 
    align-items: center; 
    justify-content: space-between; 
    gap: 20px; 
    flex-wrap: wrap; 
    padding-bottom: 22px; 
    margin-bottom: 30px; 
    border-bottom: 1px solid var(--lux-light-border); 
  }
  .blog__bar-title { 
    font-size: 12px; 
    font-weight: 600; 
    letter-spacing: 1.4px; 
    text-transform: uppercase; 
    color: var(--lux-on-light); 
  }
  .blog__cats { 
    display: flex; 
    flex-wrap: wrap; 
    gap: 8px; 
  }
  .blog__cat { 
    font-size: 12px; 
    font-weight: 600; 
    letter-spacing: .4px; 
    color: var(--lux-on-light-soft); 
    border: 1px solid var(--lux-light-border-strong); 
    background: transparent; 
    padding: 8px 16px; 
    cursor: pointer; 
    transition: background .25s var(--ease), color .25s var(--ease), border-color .25s var(--ease); 
  }
  .blog__cat:hover { 
    border-color: var(--lux-primary-dark); 
    color: var(--lux-on-light); 
  }
  .blog__cat.is-active { 
    background: var(--lux-primary-dark); 
    color: var(--lux-text-primary); 
    border-color: var(--lux-primary-dark); 
  }

  .blog__grid { 
    display: grid; 
    grid-template-columns: repeat(3, 1fr); 
    gap: clamp(20px, 2.4vw, 34px); 
  }
  .blog__empty { 
    text-align: center; 
    padding: 50px 0; 
    color: var(--lux-on-light-soft); 
    display: none; 
  }
  .blog__empty.is-shown { 
    display: block; 
  }

  /* Grid Card style (.bcard) */
  .bcard {
    display: flex;
    flex-direction: column;
    background: var(--lux-light-elevated);
    border: 1px solid var(--lux-light-border);
    border-radius: 0;
    overflow: hidden;
    transition: transform .5s var(--ease), box-shadow .5s var(--ease), border-color .5s var(--ease);
  }

  .bcard:hover {
    transform: translateY(-8px);
    box-shadow: 0 40px 80px -50px rgba(48, 56, 44, .5);
    border-color: var(--lux-light-border-strong);
  }

  .bcard__media {
    position: relative;
    aspect-ratio: 5/4;
    overflow: hidden;
    background: var(--lux-light-surface);
  }

  .bcard__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.1s var(--ease);
  }

  .bcard:hover .bcard__media img {
    transform: scale(1.07);
  }

  .bcard__tag {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 2;
    background: rgba(23, 26, 21, .78);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    color: var(--lux-accent-lime);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    padding: 7px 13px;
    border-radius: 0;
  }

  .bcard__body {
    padding: clamp(22px, 2vw, 30px);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .bcard__meta {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--lux-on-light-soft);
    margin-bottom: 12px;
  }

  .bcard__title {
    font-family: var(--font-display);
    font-size: clamp(22px, 1.9vw, 27px);
    font-weight: 500;
    line-height: 1.18;
    letter-spacing: -.4px;
    color: var(--lux-on-light);
    margin: 0;
  }

  .bcard__title a {
    color: inherit;
    transition: color .3s var(--ease);
  }

  .bcard__title a:hover {
    color: var(--lux-secondary-olive);
  }

  .bcard__excerpt {
    font-size: 14px;
    line-height: 1.65;
    color: var(--lux-on-light-soft);
    margin: 12px 0 22px;
    flex: 1;
  }

  .bcard__btn {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 13px 24px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    background: transparent;
    color: var(--lux-on-light);
    border: 1px solid var(--lux-light-border-strong);
    transition: background .3s var(--ease), color .3s var(--ease), border-color .3s var(--ease), gap .3s var(--ease);
  }

  .bcard__btn:hover {
    background: var(--lux-primary-dark);
    color: var(--lux-text-primary);
    border-color: var(--lux-primary-dark);
    gap: 14px;
  }

  .bcard__btn svg {
    transition: transform .3s var(--ease);
  }

  .bcard:hover .bcard__btn svg {
    transform: translateX(3px);
  }

  .bcard.is-hidden { 
    display: none; 
  }

  @media (max-width: 880px) { 
    .blogf { 
      grid-template-columns: 1fr; 
    } 
    .blogf__media { 
      order: -1; 
    } 
    .blog__grid { 
      grid-template-columns: 1fr 1fr; 
    } 
  }
  @media (max-width: 560px) { 
    .blog__grid { 
      grid-template-columns: 1fr; 
    } 
  }

  /* ============================ NEWSLETTER ============================ */
  .news {
    background: var(--lux-light-bg);
  }

  .news__inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 50px) clamp(56px, 10vw, 140px) clamp(20px, 5vw, 50px);
  }

  .news__card {
    position: relative;
    overflow: hidden;
    background: var(--lux-bg-dark);
    border-radius: 0;
    padding: clamp(40px, 5vw, 80px) clamp(28px, 5vw, 80px);
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: clamp(36px, 5vw, 72px);
    align-items: center;
  }

  .news__card::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(0deg, rgba(231, 236, 120, .04) 0, rgba(231, 236, 120, .04) 1px, transparent 1px, transparent 44px), repeating-linear-gradient(90deg, rgba(231, 236, 120, .04) 0, rgba(231, 236, 120, .04) 1px, transparent 1px, transparent 44px);
    pointer-events: none;
  }

  .news__ghost {
    position: absolute;
    right: -20px;
    bottom: -60px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(140px, 18vw, 260px);
    color: var(--lux-accent-lime);
    opacity: .05;
    pointer-events: none;
    line-height: 1;
  }

  .news__left {
    position: relative;
    z-index: 1;
  }

  .news__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.9px;
    text-transform: uppercase;
    color: var(--lux-text-secondary);
    margin-bottom: 18px;
  }

  .news__eyebrow::before {
    content: "";
    width: 30px;
    height: 1px;
    background: var(--lux-accent-lime);
  }

  .news__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(32px, 3.6vw, 52px);
    line-height: 1.05;
    letter-spacing: -1.2px;
    color: var(--lux-text-primary);
    margin: 0;
  }

  .news__title em {
    font-style: italic;
    color: var(--lux-accent-lime);
  }

  .news__sub {
    font-size: clamp(14px, 1.05vw, 16px);
    line-height: 1.7;
    color: var(--lux-text-secondary);
    margin: 18px 0 0;
    max-width: 46ch;
  }

  .news__right {
    position: relative;
    z-index: 1;
  }

  .news__form {
    display: flex;
    gap: 10px;
    background: rgba(241, 242, 234, .06);
    border: 1px solid var(--lux-border);
    border-radius: 0;
    padding: 6px 6px 6px 22px;
  }

  .news__input {
    flex: 1;
    background: none;
    border: none;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--lux-text-primary);
    outline: none;
  }

  .news__input::placeholder {
    color: var(--lux-text-secondary);
  }

  .news__btn {
    flex-shrink: 0;
    background: var(--lux-accent-lime);
    color: var(--lux-bg-dark);
    border: none;
    border-radius: 0;
    padding: 14px 28px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    transition: background .28s var(--ease);
  }

  .news__btn:hover {
    background: var(--lux-accent-hover);
  }

  .news__benefits {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 26px;
    margin-top: 22px;
  }

  .news__benefit {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--lux-text-secondary);
  }

  .news__benefit svg {
    color: var(--lux-accent-lime);
  }

  .news__note {
    font-size: 12px;
    color: var(--lux-text-secondary);
    margin: 16px 0 0;
    opacity: .8;
  }

  @media (max-width: 820px) {
    .news__inner {
      padding: 0 var(--gutter) var(--section-y) var(--gutter);
    }
    .news__card {
      grid-template-columns: 1fr;
      gap: 30px;
    }
  }

  @media (max-width: 460px) {
    .news__form {
      flex-direction: column;
      border-radius: 0;
      padding: 14px;
    }

    .news__btn {
      padding: 14px;
    }
  }
</style>
