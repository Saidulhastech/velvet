---
import BaseLayout from '../components/layout/BaseLayout.astro';

// Real 404 status, whether hit directly or via Astro.rewrite('/404') from a
// dynamic route whose entry was not found.
Astro.response.status = 404;
---

<BaseLayout
  title="Page Not Found"
  description="The page you were looking for could not be found. Explore the Maison Arden collection."
>
  <section class="nf">
    <div class="nf__inner">
      <span class="nf__eyebrow">Error 404</span>
      <h1 class="nf__title">This page has <em>slipped away</em></h1>
      <p class="nf__sub">
        The page you were looking for is no longer here — it may have been moved,
        renamed, or is simply out of season. Let us guide you back.
      </p>

      <form class="nf__search" method="get" action="/search" role="search">
        <svg width="18" height="18" viewBox="0 0 22 22" fill="none">
          <circle cx="9.5" cy="9.5" r="7" stroke="currentColor" stroke-width="1.4"></circle>
          <path d="m14.5 14.5 5.5 5.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"></path>
        </svg>
        <input
          type="search"
          name="q"
          placeholder="Search the collection…"
          autocomplete="off"
          aria-label="Search products"
          required
        />
        <button type="submit" class="btn-dark nf__search-btn">Search</button>
      </form>

      <div class="nf__links">
        <a class="btn-dark" href="/">Return Home</a>
        <a class="btn-ghost" href="/shop">Browse the Collection</a>
      </div>

      <nav class="nf__quick" aria-label="Popular pages">
        <a href="/shop">Shop</a>
        <a href="/blog">Journal</a>
        <a href="/about">Our Story</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
  .nf {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(64px, 12vw, 160px) var(--gutter);
    display: flex;
    justify-content: center;
    text-align: center;
  }
  .nf__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    max-width: 620px;
    width: 100%;
  }
  .nf__eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2.4px;
    text-transform: uppercase;
    color: var(--lux-secondary-olive);
  }
  .nf__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(34px, 7vw, 60px);
    line-height: 1.05;
    color: var(--lux-on-light);
    margin: 0;
  }
  .nf__title em {
    font-style: italic;
  }
  .nf__sub {
    font-size: 14px;
    line-height: 1.6;
    color: var(--lux-on-light-soft);
    max-width: 460px;
    margin: 0;
  }
  .nf__search {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 6px 6px 6px 18px;
    border: 1px solid var(--lux-light-border-strong);
    background: var(--lux-light-surface);
    width: 100%;
    max-width: 480px;
    margin-top: 8px;
    transition: border-color .3s var(--ease);
  }
  .nf__search:focus-within {
    border-color: var(--lux-secondary-olive);
  }
  .nf__search svg {
    color: var(--lux-on-light-soft);
    flex-shrink: 0;
  }
  .nf__search input {
    flex-grow: 1;
    min-width: 0;
    width: 100%;
    border: none;
    background: transparent;
    font-size: 13px;
    color: var(--lux-on-light);
    outline: none;
    font-family: var(--font-body);
  }
  .nf__search-btn {
    padding: 12px 24px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    flex-shrink: 0;
  }
  .nf__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
    margin-top: 8px;
  }
  .nf__links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 30px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
  }
  .btn-ghost {
    border: 1px solid var(--lux-light-border-strong);
    color: var(--lux-on-light);
    background: transparent;
    transition: background .3s var(--ease), color .3s var(--ease);
  }
  .btn-ghost:hover {
    background: var(--lux-on-light);
    color: var(--lux-text-primary);
  }
  .nf__quick {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 22px;
    margin-top: 18px;
    padding-top: 22px;
    border-top: 1px solid var(--lux-light-border);
    width: 100%;
    max-width: 480px;
  }
  .nf__quick a {
    font-size: 12px;
    letter-spacing: .5px;
    color: var(--lux-on-light-soft);
    transition: color .25s var(--ease);
  }
  .nf__quick a:hover {
    color: var(--lux-secondary-olive);
  }

  @media (max-width: 420px) {
    .nf__links {
      flex-direction: column;
      width: 100%;
    }
    .nf__links a {
      width: 100%;
    }
  }
</style>
