---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

// Import local images
import imgAbout1 from '../assets/images/About Image 01.png';
import imgAbout2 from '../assets/images/About Image 02.png';
import imgHelene from '../assets/images/Product Image 17.png';
import imgLucien from '../assets/images/Product Image 1.png';
import imgInes from '../assets/images/Product Image 18.png';
import imgTheo from '../assets/images/Product Image 16.png';

import { render } from 'astro:content';

// Import materials and ethos collections
const ethosList = await getCollection('ethos');
const renderedEthos = await Promise.all(
  ethosList.map(async (item) => {
    const { Content } = await render(item);
    return { ...item, Content };
  })
);
const sortedEthos = renderedEthos.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

// Resolve icons or static fields for ethos items
const ethosIcons = [
  // SVG markup or placeholder for circular swatch index
  `<circle cx="6" cy="6" r="2.4" stroke="currentColor" stroke-width="1.3" /><circle cx="6" cy="18" r="2.4" stroke="currentColor" stroke-width="1.3" /><path d="M8 7.4 20 17.5M8 16.6 20 6.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />`,
  `<path d="M5 19C5 11 11 5 19 5c0 8-6 14-14 14z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" /><path d="M6 18C9.5 14.5 13 11.5 16.5 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />`,
  `<path d="M9 4 7.5 20M16.5 4 15 20M4 9h16M3.5 15h16" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />`,
  `<path d="M12 20S4 14.5 4 9a3.8 3.8 0 0 1 8-1 3.8 3.8 0 0 1 8 1c0 5.5-8 11-8 11z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />`
];

const team = [
  { name: 'Hélène Arden', role: 'Founder & Creative Director', image: imgHelene, delay: '' },
  { name: 'Lucien Marchetti', role: 'Head of Tailoring', image: imgLucien, delay: 'd1' },
  { name: 'Inès Lavigne', role: 'Atelier Director', image: imgInes, delay: 'd2' },
  { name: 'Théo Brunet', role: 'Sustainability Lead', image: imgTheo, delay: 'd3' }
];

const journey = [
  { year: '2014', chapter: 'Chapter I', title: 'A maison is born', text: 'Hélène Arden founds the house in Paris VIᵉ with a single made-to-order cashmere coat and a short, word-of-mouth waiting list.' },
  { year: '2017', chapter: 'Chapter II', title: 'The first boutique', text: 'Our flagship opens on Rue de Sèvres — part shop, part atelier, with the workroom kept in full view of the floor.' },
  { year: '2020', chapter: 'Chapter III', title: 'Numbered runs', text: 'Small-batch production is formalised — every piece numbered, and seasonal markdowns ended for good.' },
  { year: '2023', chapter: 'Chapter IV', title: 'Fully traceable', text: 'Every material is mapped to its mill and farm, and our lifetime repair service launches across all boutiques.' },
  { year: '2026', chapter: 'Chapter V · Today', title: 'The same belief', text: 'Three boutiques, thirty-four countries, and the principle we began with — fewer, finer things, made to be kept.' }
];
---

<BaseLayout title="Our Story">
  <!-- BREADCRUMB / HERO -->
  <section class="shop-hero">
    <div class="shop-hero__inner">
      <div class="shop-hero__crumb"><a href="/">Home</a> &nbsp;/&nbsp; <span>About</span></div>
      <h1 class="shop-hero__title">Our <em>Maison</em></h1>
      <p class="shop-hero__sub">A Paris house built on restraint, craft and longevity — designing fewer pieces, and making them to be kept.</p>
    </div>
  </section>

  <!-- PHILOSOPHY -->
  <section class="ct-wrap">
    <div class="ab-phil reveal">
      <span class="ab-phil__rule" aria-hidden="true"></span>
      <span class="ab-phil__eyebrow">Our Philosophy</span>
      <p class="ab-phil__quote">We design for the wardrobe that lasts — pieces meant to be worn for years, <em>not seasons.</em></p>
      <p class="ab-phil__lede">Maison Arden began with a simple frustration: that true quality had quietly disappeared behind logos and fast turnover. We make considered garments — in small numbers, from honest materials, by people we know by name.</p>
      <span class="ab-phil__sign">Hélène Arden<small>Founder &amp; Creative Director</small></span>
      <div class="ab-phil__keywords">
        <span>Fewer, finer</span><i class="ab-phil__dot" aria-hidden="true"></i><span>Made to be kept</span><i class="ab-phil__dot" aria-hidden="true"></i><span>Honest by default</span>
      </div>
    </div>
  </section>

  <!-- HERITAGE SPLIT -->
  <section class="ab-beginning">
    <div class="ct-wrap">
      <div class="ab-split">
        <div class="ab-split__visual reveal">
          <div class="ab-split__media">
            <Image src={imgAbout1} alt="An Atelier Arden coat" width={520} height={650} loading="lazy" />
            <span class="ab-split__tag">The Atelier · Paris VIᵉ</span>
          </div>
        </div>
        <div class="ab-split__body reveal d1">
          <div class="ct-head" style="margin-bottom:2px;">
            <span class="ct-eyebrow">Our Beginning</span>
            <h2 class="ct-title">From a single coat.</h2>
          </div>
          <p>In 2014, founder Hélène Arden returned to Paris with a single cashmere coat she'd spent two years perfecting. There was no marketing, no sale — just a waiting list of people who understood what they were holding.</p>
          <p>A decade later, that same principle guides everything we make. Every piece begins as a problem worth solving, refined until nothing more can be removed, then made in runs small enough to keep our standards uncompromised.</p>
          <span class="ab-sign">Hélène Arden<small>Founder &amp; Creative Director</small></span>
          <a href="/shop" class="btn-ghost" style="align-self:flex-start;margin-top:10px;">
            Explore the Collection
            <svg class="arrow" width="13" height="9" viewBox="0 0 14 10" fill="none">
              <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- VALUES (RENDERED FROM ETHOS CONTENT COLLECTION) -->
  <section class="ct-wrap">
    <div class="ct-head ct-head--center reveal">
      <span class="ct-eyebrow">What we stand for</span>
      <h2 class="ct-title">Four quiet <em>principles.</em></h2>
      <p class="ct-lede">They sound simple. Holding to them is the hard part — and the point.</p>
    </div>
    
    <div class="ab-values reveal">
      {sortedEthos.map((item, idx) => (
        <div class="ab-value">
          <span class="ab-value__num">{item.data.index}</span>
          <span class="ab-value__icon">
            <svg width="19" height="19" viewBox="0 0 24 24" fill="none" set:html={ethosIcons[idx % ethosIcons.length]} />
          </span>
          <h3 class="ab-value__title">{item.data.title}</h3>
          <div class="ab-value__text"><item.Content /></div>
          <span class="ab-value__tag">{item.data.tag}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- STATS BAND (dark) -->
  <section class="ab-stats" aria-label="Maison Arden in numbers">
    <div class="ab-stats__inner">
      <div class="ab-stats__head reveal">
        <span class="ab-stats__eyebrow">By the numbers</span>
        <h2 class="ab-stats__title">A decade of <em>restraint.</em></h2>
      </div>
      <div class="ab-stats__row">
        <div class="ab-stat reveal">
          <span class="ab-stat__mark" aria-hidden="true"></span>
          <span class="ab-stat__num">2014</span>
          <span class="ab-stat__label">Founded in Paris</span>
          <span class="ab-stat__desc">The year it began</span>
        </div>
        <div class="ab-stat reveal d1">
          <span class="ab-stat__mark" aria-hidden="true"></span>
          <span class="ab-stat__num" data-count="12">0</span>
          <span class="ab-stat__label">Atelier artisans</span>
          <span class="ab-stat__desc">Across two ateliers</span>
        </div>
        <div class="ab-stat reveal d2">
          <span class="ab-stat__mark" aria-hidden="true"></span>
          <span class="ab-stat__num" data-count="34" data-suffix="+">0</span>
          <span class="ab-stat__label">Countries served</span>
          <span class="ab-stat__desc">Shipped worldwide</span>
        </div>
        <div class="ab-stat reveal d3">
          <span class="ab-stat__mark" aria-hidden="true"></span>
          <span class="ab-stat__num" data-count="100" data-suffix="%">0</span>
          <span class="ab-stat__label">Traceable materials</span>
          <span class="ab-stat__desc">Mill to garment</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CRAFTSMANSHIP SPLIT (reversed) -->
  <section class="ct-wrap">
    <div class="ab-split ab-split--rev">
      <div class="ab-split__visual reveal">
        <div class="ab-split__media">
          <Image src={imgAbout2} alt="Cashmere being finished by hand" width={520} height={650} loading="lazy" />
          <span class="ab-split__tag">By Hand · Not by Machine</span>
        </div>
      </div>
      <div class="ab-split__body reveal d1">
        <div class="ct-head" style="margin-bottom:2px;">
          <span class="ct-eyebrow">How it's made</span>
          <h2 class="ct-title">The slow way, on purpose.</h2>
        </div>
        <p>A single Atelier coat passes through eleven pairs of hands over three weeks. Nothing about it is fast, because nothing good ever is — and we keep production within a day's travel of Paris, so we can stand in the room where our clothes are made.</p>
        
        <div class="ab-process">
          <div class="ab-process__item">
            <span class="ab-process__num">01</span>
            <div>
              <h4 class="ab-process__t">Drafted &amp; rested</h4>
              <p class="ab-process__d">Patterns drawn by hand; fabric relaxed a full 48 hours before a single cut.</p>
            </div>
          </div>
          <div class="ab-process__item">
            <span class="ab-process__num">02</span>
            <div>
              <h4 class="ab-process__t">Cut individually</h4>
              <p class="ab-process__d">Every panel cut one at a time, matched grain to grain — never stacked.</p>
            </div>
          </div>
          <div class="ab-process__item">
            <span class="ab-process__num">03</span>
            <div>
              <h4 class="ab-process__t">Pressed &amp; re-pressed</h4>
              <p class="ab-process__d">Seams shaped with heat and patience until the line falls exactly right.</p>
            </div>
          </div>
          <div class="ab-process__item">
            <span class="ab-process__num">04</span>
            <div>
              <h4 class="ab-process__t">Signed &amp; numbered</h4>
              <p class="ab-process__d">Inspected, numbered, and recorded before it ever leaves the atelier.</p>
            </div>
          </div>
        </div>
        
        <a href="/shop" class="btn-ghost" style="align-self:flex-start;margin-top:12px;">
          Shop New Arrivals 
          <svg class="arrow" width="13" height="9" viewBox="0 0 14 10" fill="none">
            <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
          </svg>
        </a>
      </div>
    </div>
  </section>


  <!-- THE JOURNEY -->
  <section class="ct-wrap">
    <div class="ct-head ct-head--center reveal">
      <span class="ct-eyebrow">The journey</span>
      <h2 class="ct-title">A decade, in <em>five chapters.</em></h2>
    </div>
    
    <div class="ab-journey">
      {journey.map((row) => (
        <article class="ab-jrow reveal">
          <span class="ab-jrow__year">{row.year}</span>
          <div class="ab-jrow__body">
            <span class="ab-jrow__kicker">{row.chapter}</span>
            <h3 class="ab-jrow__title">{row.title}</h3>
            <p class="ab-jrow__text">{row.text}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- PEOPLE -->
  <section class="abp">
    <div class="abp__inner">
      <div class="abp__head reveal">
        <span class="eyebrow eyebrow--center">The Hands Behind It</span>
        <h2 class="section-title">Our <em>People</em></h2>
      </div>
      <div class="abp__grid">
        {team.map((member) => (
          <div class={`abp__card reveal ${member.delay}`}>
            <div class="abp__media">
              <Image src={member.image} alt={member.name} width={280} height={350} loading="lazy" />
            </div>
            <div class="abp__name">{member.name}</div>
            <div class="abp__role">{member.role}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- NEWSLETTER CTA -->
  <section class="news" id="newsletter" aria-label="Newsletter">
    <div class="news__inner">
      <div class="news__card reveal">
        <span class="news__ghost" aria-hidden="true">Arden</span>
        <div class="news__left">
          <span class="news__eyebrow">The Maison Letter</span>
          <h2 class="news__title">Considered style, <em>in your inbox.</em></h2>
          <p class="news__sub">Be first to see new collections, atelier stories and seasonal lookbooks — thoughtfully sent, never noisy.</p>
        </div>
        <div class="news__right">
          <form class="news__form" onsubmit="return false;">
            <input class="news__input" type="email" placeholder="Your email address" aria-label="Email" required />
            <button class="news__btn" type="submit">Subscribe</button>
          </form>
          <div class="news__benefits">
            <span class="news__benefit">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Early Access
            </span>
            <span class="news__benefit">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Member Events
            </span>
            <span class="news__benefit">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Seasonal Lookbooks
            </span>
          </div>
          <p class="news__note">By subscribing you agree to our Privacy Policy. Unsubscribe anytime.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  (function () {
    'use strict';
    // Reveal animations
    const rev = Array.from(document.querySelectorAll('.reveal'));
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((es) => es.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      }), { threshold: .15 });
      rev.forEach(r => io.observe(r));
    } else rev.forEach(r => r.classList.add('in'));

    // Counter animation
    const nums = Array.from(document.querySelectorAll('[data-count]'));
    if (!nums.length) return;
    function run(el) {
      const target = +el.dataset.count, dur = 1400, t0 = performance.now();
      (function step(t) {
        const p = Math.min((t - t0) / dur, 1);
        el.textContent = Math.round(target * (1 - Math.pow(1 - p, 3))) + (el.dataset.suffix || '');
        if (p < 1) requestAnimationFrame(step);
      })(performance.now());
    }
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((es) => es.forEach(e => {
        if (e.isIntersecting) { run(e.target); io.unobserve(e.target); }
      }), { threshold: .5 });
      nums.forEach(n => io.observe(n));
    } else nums.forEach(run);
  })();
</script>

<style>
  /* ============ INTERNAL PAGE HERO ============ */
  .shop-hero {
    background: var(--lux-light-surface);
    border-bottom: 1px solid var(--lux-light-border);
  }

  .shop-hero__inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(40px,5vw,76px) var(--gutter) clamp(34px,4vw,56px);
    text-align: center;
  }

  .shop-hero__crumb {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--lux-on-light-soft);
    margin-bottom: 16px;
  }

  .shop-hero__crumb a {
    color: var(--lux-on-light-soft);
    transition: color .2s var(--ease);
  }

  .shop-hero__crumb a:hover {
    color: var(--lux-on-light);
  }

  .shop-hero__crumb span {
    color: var(--lux-secondary-olive);
  }

  .shop-hero__title {
    font-family: var(--font-display);
    font-size: clamp(40px,5vw,72px);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -1.5px;
    color: var(--lux-on-light);
  }

  .shop-hero__title em {
    font-style: italic;
    color: var(--lux-secondary-olive);
  }

  .shop-hero__sub {
    font-size: clamp(14px,1.05vw,16px);
    line-height: 1.7;
    color: var(--lux-on-light-soft);
    max-width: 58ch;
    margin: 16px auto 0;
  }

  /* ============ COMMON GRID & LAYOUTS ============ */
  .ct-wrap {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: var(--section-y) var(--gutter);
  }

  .ct-head {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: clamp(34px, 4.5vw, 56px);
  }

  .ct-head--center {
    align-items: center;
    text-align: center;
    max-width: 580px;
    margin-left: auto;
    margin-right: auto;
  }

  .ct-eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.9px;
    text-transform: uppercase;
    color: var(--lux-on-light-soft);
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }

  .ct-eyebrow::before {
    content: "";
    width: 28px;
    height: 1px;
    background: var(--lux-primary-dark);
  }

  .ct-head--center .ct-eyebrow {
    justify-content: center;
  }

  .ct-title {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 56px);
    font-weight: 500;
    letter-spacing: -1.2px;
    color: var(--lux-on-light);
    margin: 0;
    line-height: 1.04;
  }

  .ct-title em {
    font-style: italic;
    color: var(--lux-secondary-olive);
  }

  .ct-lede {
    font-size: 15px;
    line-height: 1.7;
    color: var(--lux-on-light-soft);
    margin: 0;
    max-width: 48ch;
  }

  .ct-head--center .ct-lede {
    margin: 0 auto;
  }

  /* ============ PHILOSOPHY & STATEMENT ============ */
  .ab-phil {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .ab-phil__rule {
    width: 1px;
    height: 66px;
    background: linear-gradient(var(--lux-secondary-olive), transparent);
    margin-bottom: 30px;
  }

  .ab-phil__eyebrow {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 3.4px;
    text-transform: uppercase;
    color: var(--lux-secondary-olive);
    margin-bottom: 40px;
  }

  .ab-phil__quote {
    font-family: var(--font-display);
    font-size: clamp(30px, 4.3vw, 56px);
    font-weight: 500;
    font-style: italic;
    line-height: 1.3;
    letter-spacing: -1px;
    color: var(--lux-on-light);
    margin: 0;
    max-width: 36ch;
  }

  .ab-phil__quote em {
    font-style: italic;
    color: var(--lux-secondary-olive);
  }

  .ab-phil__lede {
    font-size: 15.5px;
    line-height: 1.95;
    color: var(--lux-on-light-soft);
    margin: 38px auto 0;
    max-width: 92ch;
  }

  .ab-phil__sign {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 23px;
    color: var(--lux-secondary-olive);
    line-height: 1;
    margin-top: 38px;
  }

  .ab-phil__sign small {
    display: block;
    font-family: var(--font-body);
    font-style: normal;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--lux-on-light-soft);
    margin-top: 9px;
  }

  .ab-phil__keywords {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 18px;
    margin-top: 48px;
    padding-top: 30px;
    border-top: 1px solid var(--lux-light-border);
    width: min(520px, 100%);
  }

  .ab-phil__keywords span {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--lux-on-light-soft);
  }

  .ab-phil__dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--lux-accent-lime);
    flex-shrink: 0;
  }

  /* ============ BTN-GHOST ARROW ============ */
  .btn-ghost .arrow {
    transition: transform .3s var(--ease);
  }

  .btn-ghost:hover .arrow {
    transform: translateX(4px);
  }

  /* ============ HERITAGE SPLIT ============ */
  .ab-beginning {
    background: var(--lux-light-surface);
    border-top: 1px solid var(--lux-light-border);
    border-bottom: 1px solid var(--lux-light-border);
  }

  .ab-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 6vw, 96px);
    align-items: center;
  }

  .ab-split__visual {
    position: relative;
  }

  .ab-split__visual::before {
    content: "";
    position: absolute;
    inset: 0;
    border: 1px solid var(--lux-secondary-olive);
    transform: translate(22px, 22px);
    z-index: 0;
    transition: transform .55s var(--ease);
    pointer-events: none;
  }

  .ab-split--rev .ab-split__visual {
    order: 2;
  }

  .ab-split--rev .ab-split__visual::before {
    transform: translate(-22px, 22px);
  }

  .ab-split__visual:hover::before {
    transform: translate(14px, 14px);
  }

  .ab-split--rev .ab-split__visual:hover::before {
    transform: translate(-14px, 14px);
  }

  .ab-split__media {
    position: relative;
    z-index: 1;
    aspect-ratio: 4/5;
    overflow: hidden;
    background: var(--lux-light-border-strong);
  }

  .ab-split__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.3s var(--ease);
  }

  .ab-split__media:hover img {
    transform: scale(1.05);
  }

  .ab-split__tag {
    position: absolute;
    left: 0;
    bottom: 28px;
    z-index: 2;
    background: var(--lux-light-elevated);
    color: var(--lux-on-light);
