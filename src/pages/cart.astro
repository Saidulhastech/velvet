---
import BaseLayout from '../components/layout/BaseLayout.astro';
import ProductCard from '../components/product/ProductCard.astro';
import { getShopifyProducts } from '../lib/shopify/client';
import { resolveCartExtras } from '../lib/cart-extras';
import { formatMoney } from '../lib/money';

const market = Astro.locals.market;
const products = await getShopifyProducts(market);
// Take the first 4 products for cross-sell
const crossSellProducts = products.slice(0, 4);

// Resolve real gift-wrap + protection products (by handle) for this market.
// When configured in the store, the toggles become real paid Shopify lines;
// when not, the template falls back to its original decorative markup so the
// shipped (mock) design is unchanged.
const EXTRAS = await resolveCartExtras(market);

const protectionPlans = EXTRAS.protection.show
  ? EXTRAS.protection.plans
      .filter((p) => p.id !== 'none' && p.variantId)
      .map((p) => ({
        variantId: p.variantId,
        name: p.name,
        best: p.best,
        priceLabel: p.price ? formatMoney(p.price) : '',
      }))
  : [];
const PROTECT_ON = protectionPlans.length > 0;

const giftWrap = EXTRAS.giftWrap;
const GIFTWRAP_ON = giftWrap.show && !!giftWrap.variantId;
const giftWrapPriceLabel = giftWrap.price ? formatMoney(giftWrap.price) : '';

// Client bootstrap for the real-extras wiring (empty/nulls in fallback mode).
const extrasData = JSON.stringify({
  giftMessageMax: giftWrap.messageMaxLength ?? 200,
  protection: protectionPlans.map((p) => ({ variantId: p.variantId, name: p.name })),
  giftWrap: GIFTWRAP_ON ? { variantId: giftWrap.variantId, label: giftWrap.label } : null,
});
---

<BaseLayout
  title="Shopping Bag"
  description="Review your Maison Arden selections, choose shipping options, and proceed to secure checkout."
  noindex
>
  <!-- HERO -->
  <section class="shop-hero">
    <div class="shop-hero__inner">
      <div class="shop-hero__crumb"><a href="/">Home</a> &nbsp;/&nbsp; <a href="/shop">Shop</a> &nbsp;/&nbsp; <span>Shopping Bag</span></div>
      <h1 class="shop-hero__title">Shopping <em>Bag</em></h1>
      <p class="shop-hero__sub">Review your selection before checkout. Items are reserved for you for a limited time.</p>
    </div>
  </section>

  <!-- CART LAYOUT -->
  <section class="cart-layout" aria-label="Shopping bag" data-cart-root data-extras={extrasData}>
    <div class="cart-main">
      <!-- Shipping Progress indicator -->
      <div class="cart-ship">
        <p class="cart-ship__text" data-ship-text>
          <!-- Hydrated via JS -->
        </p>
        <div class="cart-ship__track">
          <span class="cart-ship__fill" data-ship-fill style="width: 0%"></span>
        </div>
      </div>

      <!-- Items List Header -->
      <div class="cart-thead">
        <span>Product</span>
        <span>Price</span>
        <span>Quantity</span>
        <span>Total</span>
      </div>

      <!-- Cart Items List Container -->
      <div class="citems" id="cartItems">
        <!-- Populated via JS -->
      </div>

      <!-- Empty Cart State -->
      <div class="cart-empty" id="cartEmpty">
        <svg width="52" height="52" viewBox="0 0 52 52" fill="none">
          <path d="M7 17h38L41 43H11L7 17z" stroke="currentColor" stroke-width="1.2" />
          <path d="M18 17v-4a8 8 0 0 1 16 0v4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
        </svg>
        <p class="cart-empty__title">Your bag is empty.</p>
        <p class="cart-empty__desc">Explore the collection and find your next considered piece.</p>
        <a href="/shop" class="btn-dark">
          Browse the Collection 
          <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
            <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
          </svg>
        </a>
      </div>

      <!-- Order Options Header -->
      <div class="copt-shead">
        <span class="copt-shead__label">Order Options</span>
        <span class="copt-shead__line"></span>
      </div>

      <!-- Shipping Options -->
      <div class="copt">
        <div class="copt__title-row">
          <span class="copt__icon">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
              <path d="M1 6h9v8H1z" stroke="currentColor" stroke-width="1.3" />
              <path d="M10 8h4l3 3v3h-7z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />
              <circle cx="5" cy="15" r="1.6" stroke="currentColor" stroke-width="1.3" />
              <circle cx="14" cy="15" r="1.6" stroke="currentColor" stroke-width="1.3" />
            </svg>
          </span>
          <div>
            <div class="copt__h">Shipping Method</div>
            <div class="copt__hsub">Choose how fast you would like your order</div>
          </div>
        </div>
        
        <div class="optcards" data-opt-group="ship">
          <div class="optcard is-active" data-val="0" data-label="Standard Courier">
            <span class="optcard__radio"></span>
            <div class="optcard__main">
              <div class="optcard__title">Standard Courier</div>
              <div class="optcard__sub">3–5 business days</div>
            </div>
            <span class="optcard__price optcard__price--free">Free</span>
          </div>
          <div class="optcard" data-val="14" data-label="Express Air">
            <span class="optcard__radio"></span>
            <div class="optcard__main">
              <div class="optcard__title">Express Air</div>
              <div class="optcard__sub">1–2 business days</div>
            </div>
            <span class="optcard__price">+€14</span>
          </div>
          <div class="optcard" data-val="29" data-label="Same-Day Rush">
            <span class="optcard__radio"></span>
            <div class="optcard__main">
              <div class="optcard__title">Same-Day Rush</div>
              <div class="optcard__sub">Order before 2pm · select cities</div>
            </div>
            <span class="optcard__price">+€29</span>
          </div>
          <div class="optcard" data-val="0" data-label="Boutique Pickup">
            <span class="optcard__radio"></span>
            <div class="optcard__main">
              <div class="optcard__title">Boutique Pickup</div>
              <div class="optcard__sub">Ready in 2 hours · Paris flagship</div>
            </div>
            <span class="optcard__price optcard__price--free">Free</span>
          </div>
        </div>
      </div>

      <!-- Additional Options Split -->
      <div class="copt-cols">
        <div class="copt-col">
          <!-- Delivery Date Preference -->
          <div class="copt">
            <div class="copt__title-row">
              <span class="copt__icon">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                  <rect x="2" y="3.5" width="16" height="14" stroke="currentColor" stroke-width="1.3" />
                  <path d="M2 7.5h16M6.5 1.5v4M13.5 1.5v4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
                </svg>
              </span>
              <div>
                <div class="copt__h">Delivery Date</div>
                <div class="copt__hsub">Pick a preferred day</div>
              </div>
            </div>
            <input class="copt__date" type="date" aria-label="Preferred delivery date">
            <p class="copt__hint">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2" />
                <path d="M8 5v3.5l2 1.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Leave blank for the earliest available date. We&rsquo;ll confirm your delivery window by email.
            </p>
          </div>

          <!-- Order Notes -->
          <div class="copt">
            <div class="copt__title-row">
              <span class="copt__icon">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                  <path d="M3 3h14v11H7l-4 3z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />
                  <path d="M6 7h8M6 10h5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
                </svg>
              </span>
              <div>
                <div class="copt__h">Order Notes</div>
                <div class="copt__hsub">Delivery instructions</div>
              </div>
            </div>
            <textarea class="copt__note" id="orderNote" placeholder="Leave a note for our team — buzzer code, drop-off spot, anything else…"></textarea>
          </div>
        </div>

        <div class="copt-col">
          <!-- Protection Plan -->
          <div class="copt">
            <div class="copt__title-row">
              <span class="copt__icon">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                  <path d="M10 1.5l7 2.5v5c0 4-3 7.5-7 9-4-1.5-7-5-7-9v-5l7-2.5z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />
                  <path d="M7 10l2 2 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <div>
                <div class="copt__h">Protection Plan</div>
                <div class="copt__hsub">Repairs, damage &amp; care</div>
              </div>
            </div>
            
            {PROTECT_ON ? (
              <div class="optcards" data-opt-group="protect" data-protect-real>
                <div class="optcard is-active" data-variant="" data-label="No coverage">
                  <span class="optcard__radio"></span>
                  <div class="optcard__main">
                    <div class="optcard__title">No coverage</div>
                  </div>
                  <span class="optcard__price optcard__price--free">Free</span>
                </div>
                {protectionPlans.map((p) => (
                  <div class="optcard" data-variant={p.variantId} data-label={p.name}>
                    <span class="optcard__radio"></span>
                    <div class="optcard__main">
                      <div class="optcard__title">{p.name}{p.best ? <span class="optcard__best"> · Best value</span> : ''}</div>
                    </div>
                    {p.priceLabel ? <span class="optcard__price">{p.priceLabel}</span> : ''}
                  </div>
                ))}
              </div>
            ) : (
              <div class="optcards" data-opt-group="protect">
                <div class="optcard is-active" data-val="0" data-label="No coverage">
                  <span class="optcard__radio"></span>
                  <div class="optcard__main">
                    <div class="optcard__title">No coverage</div>
                  </div>
                  <span class="optcard__price optcard__price--free">Free</span>
                </div>
                <div class="optcard" data-val="49" data-label="2-Year Care">
                  <span class="optcard__radio"></span>
                  <div class="optcard__main">
                    <div class="optcard__title">2-Year Care</div>
                  </div>
                  <span class="optcard__price">+€49</span>
                </div>
                <div class="optcard" data-val="79" data-label="3-Year Care">
                  <span class="optcard__radio"></span>
                  <div class="optcard__main">
                    <div class="optcard__title">3-Year Care</div>
                  </div>
                  <span class="optcard__price">+€79</span>
                </div>
              </div>
            )}
          </div>

          <!-- Gift Options -->
          <div class="copt">
            <div class="copt__title-row">
              <span class="copt__icon">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                  <rect x="3" y="8" width="14" height="9" stroke="currentColor" stroke-width="1.3" />
                  <path d="M3 8h14M10 8v9" stroke="currentColor" stroke-width="1.3" />
                  <path d="M10 8C7.5 8 6 6.5 6.7 5S10 5 10 8c0-3 2.6-3.6 3.3-2S12.5 8 10 8z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />
                </svg>
              </span>
              <div>
                <div class="copt__h">Gift Wrap</div>
                <div class="copt__hsub">Ivory box · satin ribbon · card</div>
              </div>
            </div>
            
            <div class="copt__gift">
              <div class="copt__gift-main">
                <div class="copt__gift-title">Add gift wrapping <b>+{GIFTWRAP_ON && giftWrapPriceLabel ? giftWrapPriceLabel : '€12'}</b></div>
                <div class="copt__gift-sub">Hand-finished with a written message card.</div>
              </div>
              <label class="gw-switch">
                <input type="checkbox" data-gift />
                <span class="gw-switch__slider"></span>
              </label>
            </div>
            <div class="copt__giftmsg" data-gift-msg>
              <textarea class="copt__note" data-gift-message maxlength={giftWrap.messageMaxLength ?? 200} placeholder="Your gift message (optional)…" style="margin-top:12px;min-height:64px;"></textarea>
            </div>
          </div>
        </div>
      </div>

      <!-- Saved for Later Section -->
      <div class="cart-saved" id="cartSaved" style="display:none">
        <h2 class="cart-saved__title">Saved for Later</h2>
        <div id="savedList">
          <!-- Hydrated via JS -->
        </div>
      </div>
    </div>

    <!-- Summary Column -->
    <aside class="csum" aria-label="Order summary">
      <div class="csum__head">
        <span class="csum__eyebrow">Order Summary</span>
        <h2 class="csum__title">Your Total</h2>
      </div>
      <div class="csum__lines">
        <div class="csum-row">
          <span>Subtotal (<span data-sum-count>0</span> items)</span>
          <span data-sum-sub>€0</span>
        </div>
        <div class="csum-row csum-row--discount" data-sum-disc-row>
          <span>Discount <span data-disc-code></span></span>
          <span data-sum-disc>−€0</span>
        </div>
        <div class="csum-row csum-row--free" data-sum-ship-row>
          <span>Shipping</span>
          <span data-sum-ship>Complimentary</span>
        </div>
        <div class="csum-row csum-row--addon" data-sum-prot-row style="display:none">
          <span>Protection <span data-prot-label></span></span>
          <span data-sum-prot>+€0</span>
        </div>
        <div class="csum-row csum-row--addon" data-sum-gift-row style="display:none">
          <span>Gift Wrapping</span>
          <span data-sum-gift>+€12</span>
        </div>
        <div class="csum-row">
          <span>Duties &amp; Taxes</span>
          <span>At checkout</span>
        </div>
        <div class="csum-divider"></div>
        <div class="csum-row csum-row--total">
          <span>Estimated Total</span>
          <span data-sum-total>€0</span>
        </div>
      </div>

      <!-- Coupon Code Apply -->
      <div class="csum__coupon">
        <div class="csum__coupon-wrap">
          <input class="csum__coupon-input" type="text" id="couponInput" placeholder="Coupon or gift card code" />
          <button class="csum__coupon-btn" data-coupon-apply>Apply</button>
        </div>
        <p class="csum__coupon-msg" data-coupon-msg></p>
      </div>

      <!-- Checkout Actions -->
      <div class="csum__cta">
        <a href="#" class="btn-dark csum__checkout" id="checkoutBtn">
          Proceed to Checkout 
          <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
            <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
          </svg>
        </a>
        <span class="csum__express-label">or express checkout</span>
        <div class="csum__express">
          <button type="button" id="expressApplePay">&#63743; Pay</button>
          <button type="button" id="expressGooglePay">G Pay</button>
        </div>
      </div>

      <!-- Trust Badges -->
      <div class="csum__trust">
        <span class="csum__trust-item">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <rect x="2" y="7" width="12" height="7" rx="1" stroke="currentColor" />
            <path d="M4.5 7V5a3.5 3.5 0 0 1 7 0v2" stroke="currentColor" stroke-linecap="round" />
          </svg> 
          SSL secure checkout
        </span>
        <span class="csum__trust-item">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M2 8l3 3 9-9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
          </svg> 
          Free returns within 30 days
        </span>
        <span class="csum__trust-item">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M8 1l2 4.5 5 .5-3.7 3.3L12 14 8 11.5 4 14l.7-4.7L1 6l5-.5L8 1z" stroke="currentColor" stroke-linejoin="round" />
          </svg> 
          Lifetime repairs included
        </span>
      </div>
      <p class="csum__note">Taxes &amp; duties calculated at checkout. All prices in EUR.</p>
    </aside>
  </section>

  <!-- CROSS-SELL -->
  <section class="xsell" aria-label="You may also like">
    <div class="xsell__inner">
      <div class="xsell__head">
        <div class="reveal">
          <span class="eyebrow">Add to Your Order</span>
          <h2 class="section-title" style="margin-top:14px;">You May Also <em>Like</em></h2>
        </div>
        <a href="/shop" class="btn-dark reveal d1">
          View All 
          <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
            <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
          </svg>
        </a>
      </div>
      <div class="xsell__grid">
        {crossSellProducts.map((p, idx) => (
          <ProductCard product={p} delayClass={`d${idx + 1}`} />
        ))}
      </div>
    </div>
  </section>

  <!-- NEWSLETTER CTA -->
  <section class="news" id="newsletter" aria-label="Newsletter">
    <div class="news__inner">
      <div class="news__card reveal">
        <span class="news__ghost" aria-hidden="true">Arden</span>
        <div class="news__left">
          <span class="news__eyebrow">The Maison Letter</span>
          <h2 class="news__title">Considered style, <em>in your inbox.</em></h2>
          <p class="news__sub">Be first to see new collections, atelier stories and seasonal lookbooks — thoughtfully sent, never noisy.</p>
        </div>
        <div class="news__right">
          <form class="news__form" onsubmit="return false;">
            <input class="news__input" type="email" placeholder="Your email address" aria-label="Email" required />
            <button class="news__btn" type="submit">Subscribe</button>
          </form>
          <div class="news__benefits">
            <span class="news__benefit">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Early Access
            </span>
            <span class="news__benefit">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Member Events
            </span>
            <span class="news__benefit">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Seasonal Lookbooks
            </span>
          </div>
          <p class="news__note">By subscribing you agree to our Privacy Policy. Unsubscribe anytime.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import {
    persistedCartItems,
    persistedSavedItems,
    cartDiscount,
    appliedDiscounts,
    cartNote,
    cartCurrency,
    updateCartQuantity,
    removeFromCart,
    saveForLater,
    moveToBag,
    removeFromSaved,
    applyDiscount,
    updateCartNote,
    setCartAttributes,
    addExtraLine,
    removeExtraLine,
    checkout
  } from '../stores/cart';

  // Real gift-wrap / protection config injected by the server. In fallback mode
  // (no configured products) protection[] is empty and giftWrap is null, so the
  // toggles keep their original decorative-only behavior.
  const rootEl = document.querySelector('[data-cart-root]') as HTMLElement | null;
  const EXTRAS = (() => {
    try { return JSON.parse(rootEl?.dataset.extras || '{}'); }
    catch { return { giftMessageMax: 200, protection: [], giftWrap: null }; }
  })() as { giftMessageMax: number; protection: { variantId: string; name: string }[]; giftWrap: { variantId: string; label: string } | null };

  const GIFTWRAP_VID = EXTRAS.giftWrap?.variantId || '';
  const PROTECT_VIDS = new Set((EXTRAS.protection || []).map((p) => p.variantId));
  // Variant gids that are "extras" — hidden from the visible bag list and
  // excluded from the product subtotal (they show as their own summary rows).
  const EXTRA_VIDS = new Set<string>([...PROTECT_VIDS, ...(GIFTWRAP_VID ? [GIFTWRAP_VID] : [])]);

  const $ = (s: string, c: HTMLElement | Document = document) => c.querySelector(s);
  const $$ = (s: string, c: HTMLElement | Document = document) => Array.from(c.querySelectorAll(s));

  const itemsBox = document.getElementById('cartItems');
  const savedBox = document.getElementById('savedList');
  const savedWrap = document.getElementById('cartSaved');
  const emptyEl = document.getElementById('cartEmpty');
  const checkoutBtn = document.getElementById('checkoutBtn');

  const SHIPPING_THRESHOLD = 1800;
  let currentDiscount = 0;
  let activeDiscountCode: string | null = null;
  let currentNoteText = '';

  const state = { ship: 0, shipLabel: 'Standard Courier', protect: 0, protLabel: '', gift: false };
  const GIFT_COST = 12;

  // Active currency, synced from the authoritative Shopify cart (falls back to
  // EUR until the first sync / in mock mode). Amounts are already localized by
  // @inContext on the server — only the symbol/format needs to follow the cart.
  let currentCurrency = 'EUR';
  function formatEur(n: number) {
    const rounded = Math.round(n);
    try {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: currentCurrency,
        minimumFractionDigits: 0,
        maximumFractionDigits: 0,
      }).format(rounded);
    } catch {
      return '€' + rounded.toLocaleString('en-US');
    }
  }

  const MINUS_SVG = '<svg width="10" height="10" viewBox="0 0 10 10"><path d="M2 5h6" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>';
  const PLUS_SVG = '<svg width="10" height="10" viewBox="0 0 10 10"><path d="M5 2v6M2 5h6" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>';

  // Render dynamic list of items in the cart
  function renderCartItems(allItems: any[]) {
    if (!itemsBox || !emptyEl) return;

    // Hide gift-wrap / protection lines from the visible bag — they show only
    // as their own summary rows.
    const items = allItems.filter((i) => !EXTRA_VIDS.has(i.id));

    if (items.length === 0) {
      itemsBox.innerHTML = '';
      emptyEl.classList.add('is-shown');
      return;
    }

    emptyEl.classList.remove('is-shown');

    itemsBox.innerHTML = items.map((item) => {
      // Resolve path
      const imgUrl = (item.image && typeof item.image === 'string')
        ? (/^https?:\/\//.test(item.image) || item.image.startsWith('/src/')
          ? item.image
          : item.image.startsWith('Images/')
            ? `/src/assets/images/${item.image.split('/').pop()}`
            : `/src/assets/images/${item.image}`)
        : '';

      return `
        <div class="citem" data-id="${item.id}" data-color="${item.color || ''}" data-size="${item.size || ''}" data-price="${item.price}">
          <div class="citem__media">
            ${item.badge ? `<span class="citem__badge">${item.badge}</span>` : ''}
            <img src="${imgUrl}" alt="${item.name}">
          </div>
          <div class="citem__info">
            <span class="citem__sub">${item.category || 'Maison Arden'}</span>
            <h3 class="citem__name"><a href="/products/${item.description || item.id}">${item.name}</a></h3>
            <div class="citem__meta">
              ${item.color ? `<span class="citem__chip">${item.color}</span>` : ''}
              ${item.size ? `<span class="citem__chip">Size ${item.size}</span>` : ''}
            </div>
            <div class="citem__links">
              <button class="citem__link" data-save>Save for Later</button>
              <button class="citem__link citem__link--remove" data-remove>Remove</button>
            </div>
          </div>
          <span class="citem__price">${formatEur(item.price)}</span>
          <div class="cstepper">
            <button class="cstepper__btn" data-minus aria-label="Decrease">${MINUS_SVG}</button>
            <span class="cstepper__val">${item.quantity}</span>
            <button class="cstepper__btn" data-plus aria-label="Increase">${PLUS_SVG}</button>
          </div>
          <span class="citem__total">${formatEur(item.price * item.quantity)}</span>
        </div>
      `;
    }).join('');

    // Attach row triggers
    const rows = $$( '.citem', itemsBox );
    rows.forEach(row => {
      const id = row.getAttribute('data-id') || '';
      const color = row.getAttribute('data-color') || undefined;
      const size = row.getAttribute('data-size') || undefined;
      const item = items.find(i => i.id === id && i.color === color && i.size === size);

      if (!item) return;

      // Minus
      $('[data-minus]', row)?.addEventListener('click', () => {
        updateCartQuantity(id, color, size, item.quantity - 1);
      });

      // Plus
      $('[data-plus]', row)?.addEventListener('click', () => {
        updateCartQuantity(id, color, size, item.quantity + 1);
      });

      // Remove
      $('[data-remove]', row)?.addEventListener('click', () => {
        const itemRow = row as HTMLElement;
        itemRow.style.transition = 'opacity 0.3s, transform 0.3s';
        itemRow.style.opacity = '0';
        itemRow.style.transform = 'translateX(16px)';
        setTimeout(() => {
          removeFromCart(id, color, size);
        }, 300);
      });

      // Save for later
      $('[data-save]', row)?.addEventListener('click', () => {
        const itemRow = row as HTMLElement;
        itemRow.style.transition = 'opacity 0.2s';
        itemRow.style.opacity = '0';
        setTimeout(() => {
          saveForLater(id, color, size);
        }, 200);
      });
    });
  }

  // Render Saved Items list
  function renderSavedItems(savedItems: any[]) {
    if (!savedBox || !savedWrap) return;

    if (savedItems.length === 0) {
      savedBox.innerHTML = '';
      savedWrap.style.display = 'none';
      return;
    }

    savedWrap.style.display = 'block';

    savedBox.innerHTML = savedItems.map((item) => {
      const imgUrl = (item.image && typeof item.image === 'string')
        ? (/^https?:\/\//.test(item.image) || item.image.startsWith('/src/')
          ? item.image
          : item.image.startsWith('Images/')
            ? `/src/assets/images/${item.image.split('/').pop()}`
            : `/src/assets/images/${item.image}`)
        : '';

      return `
        <div class="csaved" data-id="${item.id}" data-color="${item.color || ''}" data-size="${item.size || ''}">
          <div class="csaved__media"><img src="${imgUrl}" alt="${item.name}"></div>
          <div class="csaved__info">
            <div class="csaved__name">${item.name}</div>
            <div class="csaved__meta">${item.category || 'Maison'} ${item.color ? `· ${item.color}` : ''} ${item.size ? `· Size ${item.size}` : ''}</div>
          </div>
          <span class="csaved__price">${formatEur(item.price)}</span>
          <div style="display: flex; gap: 10px; align-items: center;">
            <button class="csaved__move" data-move-to-bag>Move to Bag</button>
            <button class="citem__link citem__link--remove" data-remove-saved style="font-size: 11px;">Remove</button>
          </div>
        </div>
      `;
    }).join('');

    // Attach saved items click handlers
    const savedRows = $$('.csaved', savedBox);
    savedRows.forEach(row => {
      const id = row.getAttribute('data-id') || '';
      const color = row.getAttribute('data-color') || undefined;
      const size = row.getAttribute('data-size') || undefined;

      // Move to Bag
      $('[data-move-to-bag]', row)?.addEventListener('click', () => {
        moveToBag(id, color, size);
      });

      // Remove saved item
      $('[data-remove-saved]', row)?.addEventListener('click', () => {
        const itemRow = row as HTMLElement;
        itemRow.style.transition = 'opacity 0.2s';
        itemRow.style.opacity = '0';
        setTimeout(() => {
          removeFromSaved(id, color, size);
        }, 200);
      });
    });
  }

  // Recalculate summary details
  function recomputeSummary(allItems: any[]) {
    // Product lines only — gift-wrap / protection are shown as their own rows.
    const productItems = allItems.filter((i) => !EXTRA_VIDS.has(i.id));
    let sub = 0;
    let count = 0;
    productItems.forEach(item => {
      count += item.quantity;
      sub += item.price * item.quantity;
    });

    // Extras: prefer the real Shopify lines (authoritative price) when present,
    // else fall back to the decorative local state (unconfigured store).
    const protectLine = allItems.find((i) => PROTECT_VIDS.has(i.id));
    const giftLine = GIFTWRAP_VID ? allItems.find((i) => i.id === GIFTWRAP_VID) : undefined;

    const protectAmount = protectLine ? protectLine.price * protectLine.quantity : state.protect;
    const protectLabel = protectLine ? (protectLine.name || state.protLabel) : state.protLabel;
    const giftAmount = giftLine ? giftLine.price * giftLine.quantity : (state.gift ? GIFT_COST : 0);
    const giftOn = giftLine ? true : state.gift;

    const disc = currentDiscount;
    const total = Math.max(sub - disc, 0) + state.ship + protectAmount + giftAmount;

    // Subtotal values
    const sumCountEl = $('[data-sum-count]');
    const sumSubEl = $('[data-sum-sub]');
    const sumTotalEl = $('[data-sum-total]');

    if (sumCountEl) sumCountEl.textContent = String(count);
    if (sumSubEl) sumSubEl.textContent = formatEur(sub);
    if (sumTotalEl) sumTotalEl.textContent = formatEur(total);

    // Coupon Discount row
    const discRow = $('[data-sum-disc-row]');
    const discVal = $('[data-sum-disc]');
    const discCodeSpan = $('[data-disc-code]');
    if (discRow && discVal) {
      if (activeDiscountCode) {
        discRow.classList.add('is-shown');
        discVal.textContent = '−' + formatEur(disc);
        if (discCodeSpan) discCodeSpan.textContent = '(' + activeDiscountCode + ')';
      } else {
        discRow.classList.remove('is-shown');
      }
    }

    // Shipping fee row
    const shipRow = $('[data-sum-ship-row]');
    const shipVal = $('[data-sum-ship]');
    if (shipRow && shipVal) {
      if (state.ship > 0) {
        shipRow.classList.remove('csum-row--free');
        shipVal.textContent = '+' + formatEur(state.ship);
      } else {
        shipRow.classList.add('csum-row--free');
        shipVal.textContent = 'Complimentary';
      }
    }

    // Protection fee row
    const protRow = $('[data-sum-prot-row]');
    const protVal = $('[data-sum-prot]');
    const protLabelSpan = $('[data-prot-label]');
    if (protRow && protVal) {
      if (protectAmount > 0) {
        (protRow as HTMLElement).style.display = 'flex';
        protVal.textContent = '+' + formatEur(protectAmount);
        if (protLabelSpan) protLabelSpan.textContent = protectLabel ? '(' + protectLabel + ')' : '';
      } else {
        (protRow as HTMLElement).style.display = 'none';
      }
    }

    // Gift wrapping fee row
    const giftRow = $('[data-sum-gift-row]');
    const giftVal = $('[data-sum-gift]');
    if (giftRow && giftVal) {
      if (giftOn) {
        (giftRow as HTMLElement).style.display = 'flex';
        giftVal.textContent = '+' + formatEur(giftAmount);
      } else {
        (giftRow as HTMLElement).style.display = 'none';
      }
    }

    // Shipping progress bar recalculations
    const progressFill = $('[data-ship-fill]');
    const progressText = $('[data-ship-text]');
    if (progressFill && progressText) {
      const pct = Math.min((sub / SHIPPING_THRESHOLD) * 100, 100);
      (progressFill as HTMLElement).style.width = pct + '%';

      const rem = Math.max(SHIPPING_THRESHOLD - sub, 0);
      if (rem <= 0) {
        progressText.innerHTML = `<svg width="15" height="13" viewBox="0 0 16 14" fill="none"><path d="M2 7l3 3 9-9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg> You qualify for <strong>complimentary standard shipping</strong>`;
      } else {
        progressText.innerHTML = `<svg width="15" height="13" viewBox="0 0 16 14" fill="none"><rect x="1" y="3" width="9" height="7" stroke="currentColor" stroke-width="1.1"/><path d="M10 5h2.5l2 2v3H10z" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round"/><circle cx="4" cy="11" r="1.4" stroke="currentColor" stroke-width="1.1"/><circle cx="12" cy="11" r="1.4" stroke="currentColor" stroke-width="1.1"/></svg> You are <strong>${formatEur(rem)}</strong> away from complimentary standard shipping`;
      }
    }
  }

  // Subscribe to persistent cart items store changes
  persistedCartItems.subscribe((items) => {
    renderCartItems(items);
    recomputeSummary(items);
  });

  // Subscribe to persistent saved items store changes
  persistedSavedItems.subscribe((savedItems) => {
    renderSavedItems(savedItems);
  });

  // Build the full cart-attribute set (wholesale replace) from the current
  // gift + protection selection. Uses live DOM/store state so it's correct
  // whenever a toggle changes.
  function buildAttributes() {
    const attrs: { key: string; value: string }[] = [];
    const giftBox = document.querySelector('[data-gift]') as HTMLInputElement | null;
    const giftLine = GIFTWRAP_VID ? persistedCartItems.get().find((i) => i.id === GIFTWRAP_VID) : undefined;
    if (giftLine || giftBox?.checked) {
      attrs.push({ key: 'Gift Wrap', value: 'Yes' });
      const msg = (document.querySelector('[data-gift-message]') as HTMLTextAreaElement | null)?.value.trim();
      if (msg) attrs.push({ key: 'Gift Message', value: msg });
    }
    const protCard = document.querySelector('[data-opt-group="protect"] .optcard.is-active');
    const protName = protCard?.getAttribute('data-label') || '';
    const protVariant = protCard?.getAttribute('data-variant') || '';
    if (protVariant && protName && protName !== 'No coverage') {
      attrs.push({ key: 'Protection Plan', value: protName });
    }
    return attrs;
  }

  // Setup options selection listeners
  $$('[data-opt-group]').forEach(group => {
    const groupName = group.getAttribute('data-opt-group');
    const isRealProtect = groupName === 'protect' && group.hasAttribute('data-protect-real');
    const cards = $$('.optcard', group);
    cards.forEach(card => {
      card.addEventListener('click', async () => {
        cards.forEach(c => c.classList.remove('is-active'));
        card.classList.add('is-active');
        const label = card.getAttribute('data-label') || '';

        if (groupName === 'ship') {
          state.ship = parseInt(card.getAttribute('data-val') || '0', 10);
          state.shipLabel = label;
          recomputeSummary(persistedCartItems.get());
        } else if (isRealProtect) {
          // Real paid tiers: swap the protection line, then persist the plan name.
          const variantId = card.getAttribute('data-variant') || '';
          const current = persistedCartItems.get().find((i) => PROTECT_VIDS.has(i.id));
          if (current && current.id !== variantId) await removeExtraLine(current.id);
          if (variantId && (!current || current.id !== variantId)) await addExtraLine(variantId, 1);
          await setCartAttributes(buildAttributes());
        } else if (groupName === 'protect') {
          // Fallback decorative mode (no configured protection product).
          state.protect = parseInt(card.getAttribute('data-val') || '0', 10);
          state.protLabel = label;
          recomputeSummary(persistedCartItems.get());
        }
      });
    });
  });

  // Gift checkbox wrapping message drawer
  const giftCheckbox = $('[data-gift]');
  const giftMsgBlock = $('[data-gift-msg]');
  const giftMsgArea = $('[data-gift-message]') as HTMLTextAreaElement | null;
  if (giftCheckbox) {
    giftCheckbox.addEventListener('change', async (e) => {
      const checked = (e.target as HTMLInputElement).checked;
      if (giftMsgBlock) giftMsgBlock.classList.toggle('is-open', checked);

      if (GIFTWRAP_VID) {
        // Real paid gift-wrap line + gift attributes.
        if (checked) await addExtraLine(GIFTWRAP_VID, 1);
        else await removeExtraLine(GIFTWRAP_VID);
        await setCartAttributes(buildAttributes());
      } else {
        // Fallback decorative mode.
        state.gift = checked;
        recomputeSummary(persistedCartItems.get());
      }
    });
  }
  // Persist the gift message (debounced) when real gift-wrap is active.
  if (giftMsgArea && GIFTWRAP_VID) {
    let giftMsgTimer: any;
    giftMsgArea.addEventListener('input', () => {
      clearTimeout(giftMsgTimer);
      giftMsgTimer = setTimeout(() => {
        if ((giftCheckbox as HTMLInputElement | null)?.checked) setCartAttributes(buildAttributes());
      }, 600);
    });
  }

  // Apply Coupon code action
  const couponBtn = $('[data-coupon-apply]') as HTMLButtonElement | null;
  const couponInp = $('#couponInput') as HTMLInputElement | null;
  const couponMsg = $('[data-coupon-msg]');
  if (couponBtn && couponInp) {
    couponBtn.addEventListener('click', async () => {
      const code = couponInp.value.trim().toUpperCase();
      if (couponMsg) {
        couponMsg.className = 'csum__coupon-msg';
        couponMsg.textContent = '';
      }
      couponBtn.disabled = true;
      const originalText = couponBtn.textContent;
      couponBtn.textContent = 'Applying...';
      try {
        // applyDiscount syncs the cart before resolving, so appliedDiscounts +
        // any Shopify userError are authoritative here — no timing guess needed.
        const res = await applyDiscount(code ? [code] : []);
        const applied = appliedDiscounts.get();
        const userErr = (res.userErrors && res.userErrors[0]) || null;
        if (code && applied.includes(code)) {
          if (couponInp) couponInp.value = '';
          if (couponMsg) {
            couponMsg.textContent = 'Coupon applied successfully!';
            couponMsg.classList.add('is-success');
          }
        } else if (couponMsg) {
          couponMsg.textContent = userErr ? userErr.message : 'Invalid or expired code.';
          couponMsg.classList.add('is-error');
        }
      } catch {
        if (couponMsg) {
          couponMsg.textContent = 'Error applying code. Please try again.';
          couponMsg.classList.add('is-error');
        }
      } finally {
        couponBtn.disabled = false;
        couponBtn.textContent = originalText;
      }
    });
  }

  // Order notes action
  const orderNote = $('#orderNote') as HTMLTextAreaElement | null;
  if (orderNote) {
    let noteTimeout: any;
    orderNote.addEventListener('input', () => {
      clearTimeout(noteTimeout);
      noteTimeout = setTimeout(() => {
        updateCartNote(orderNote.value);
      }, 600);
    });
  }

  // Real Shopify checkout trigger — re-fetches the cart to avoid a stale/expired
  // checkoutUrl before redirecting (see store checkout()).
  if (checkoutBtn) {
    checkoutBtn.addEventListener('click', async (e) => {
      e.preventDefault();
      const hasProducts = persistedCartItems.get().some((i) => !EXTRA_VIDS.has(i.id));
      if (!hasProducts) {
        alert('Your bag is empty.');
        return;
      }
      const btn = checkoutBtn as HTMLAnchorElement;
      btn.style.pointerEvents = 'none';
      btn.style.opacity = '0.7';
      try {
        await checkout();
      } finally {
        btn.style.pointerEvents = '';
        btn.style.opacity = '';
      }
    });
  }

  const expressPay = (platform: string) => {
    const currentItems = persistedCartItems.get();
    if (currentItems.length === 0) {
      alert('Your bag is empty.');
      return;
    }
    alert(`Processing express payment via ${platform}.`);
    persistedCartItems.set([]);
    window.location.href = '/';
  }

  document.getElementById('expressApplePay')?.addEventListener('click', () => expressPay('Apple Pay'));
  document.getElementById('expressGooglePay')?.addEventListener('click', () => expressPay('Google Pay'));

  // Subscribe to Shopify cost and notes details
  cartDiscount.subscribe(val => {
    currentDiscount = val;
    recomputeSummary(persistedCartItems.get());
  });

  appliedDiscounts.subscribe(codes => {
    activeDiscountCode = codes[0] || null;
    recomputeSummary(persistedCartItems.get());
  });

  cartNote.subscribe(val => {
    currentNoteText = val;
    const noteArea = $('#orderNote') as HTMLTextAreaElement | null;
    if (noteArea && !noteArea.matches(':focus')) {
      noteArea.value = val;
    }
  });

  // Re-render money in the authoritative cart currency once it syncs.
  cartCurrency.subscribe(code => {
    currentCurrency = code || 'EUR';
    recomputeSummary(persistedCartItems.get());
  });
</script>

