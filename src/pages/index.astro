---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Hero from '../components/sections/index/Hero.astro';
import Philosophy from '../components/sections/index/Philosophy.astro';
import Categories from '../components/sections/index/Categories.astro';
import ProductCard from '../components/product/ProductCard.astro';
import ShopTheLook from '../components/sections/index/ShopTheLook.astro';
import Showcase from '../components/sections/index/Showcase.astro';
import Testimonials from '../components/sections/index/Testimonials.astro';
import Journal from '../components/sections/index/Journal.astro';
import { Image } from 'astro:assets';

// Import campaign image
import imgCampaign from '../assets/images/Campaign section image.png';

// Import product catalog from Shopify client
import { getShopifyProducts } from '../lib/shopify/client';

const productsList = await getShopifyProducts(Astro.locals.market);

// Map specific products to homepage sections (matching Luxury Homepage.html)
const newArrivals = [
  productsList.find(p => p.handle === 'sand-linen-blazer' || p.id === 'p1'),
  productsList.find(p => p.handle === 'camel-wool-overcoat' || p.id === 'p2'),
  productsList.find(p => p.handle === 'pleated-wide-trouser' || p.id === 'p3'),
  productsList.find(p => p.handle === 'ribbed-wool-knit' || p.id === 'p4'),
  productsList.find(p => p.handle === 'relaxed-denim-jacket' || p.id === 'p5'),
  productsList.find(p => p.handle === 'silk-slip-dress' || p.id === 'p15'),
  productsList.find(p => p.handle === 'two-piece-tailored-suit' || p.id === 'p7'),
  productsList.find(p => p.handle === 'cropped-wool-cardigan' || p.id === 'p8')
].filter(Boolean);

if (newArrivals.length === 0) {
  newArrivals.push(...productsList.slice(0, 8));
}

const icons = [
  productsList.find(p => p.handle === 'wide-leg-linen-trouser' || p.id === 'p9'),
  productsList.find(p => p.handle === 'belted-cotton-trench' || p.id === 'p6'),
  productsList.find(p => p.handle === 'structured-linen-blazer' || p.id === 'p11'),
  productsList.find(p => p.handle === 'cashmere-turtleneck' || p.id === 'p12')
].filter(Boolean);

if (icons.length === 0) {
  icons.push(...productsList.slice(8, 12));
}

// Only show a New Arrivals tab when at least one of the featured products
// actually matches it — mirrors the client-side filter below so a tab like
// "Accessories" never sits there clickable-but-always-empty when the store
// has no real category data behind it.
const catOf = (p: (typeof newArrivals)[number]) => (p?.category || '').toLowerCase();
const hasWomenArrivals = newArrivals.some(p => catOf(p).includes('women') || catOf(p).includes('unisex'));
const hasMenArrivals = newArrivals.some(p => catOf(p).includes('men') || catOf(p).includes('unisex'));
const hasAccessoriesArrivals = newArrivals.some(p => catOf(p).includes('accessories') || catOf(p).includes('bags'));
---

<BaseLayout title="Quiet Luxury, Considered Wardrobe" description="Maison Arden — quiet luxury fashion. A considered wardrobe of tailoring, outerwear and knitwear in refined natural materials, finished by hand.">
  <!-- 1. Hero Panel -->
  <Hero />

  <!-- 2. Philosophy & Marquee Promises -->
  <Philosophy />

  <!-- 3. Explore Categories -->
  <Categories />

  <!-- 4. New Arrivals Grid -->
  <section class="prod" id="new-arrivals" aria-label="New arrivals">
    <div class="prod__inner">
      <div class="prod__head">
        <div class="reveal">
          <span class="eyebrow">Just Arrived</span>
          <h2 class="section-title" style="margin-top:14px;">New <em>Arrivals</em></h2>
        </div>
        <div class="prod__tabs reveal d1" role="tablist">
          <button class="prod__tab is-active" role="tab" data-filter="all">All</button>
          {hasWomenArrivals && <button class="prod__tab" role="tab" data-filter="women">Women</button>}
          {hasMenArrivals && <button class="prod__tab" role="tab" data-filter="men">Men</button>}
          {hasAccessoriesArrivals && <button class="prod__tab" role="tab" data-filter="accessories">Accessories</button>}
        </div>
      </div>

      <div class="prod__grid">
        {newArrivals.map((product, idx) => {
          const delays = ['', 'd1', 'd2', 'd3', '', 'd1', 'd2', 'd3'];
          return (
            <ProductCard
              product={product}
              delayClass={delays[idx]}
            />
          );
        })}
      </div>

      <p class="prod__empty" data-prod-empty hidden>No pieces in this category yet.</p>

      <div class="prod__foot reveal">
        <a href="/shop" class="btn-dark">
          View All New Arrivals 
          <svg width="13" height="9" viewBox="0 0 14 10" fill="none">
            <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- 5. Shop The Look Edit -->
  <ShopTheLook />

  <!-- 6. Icons Grid (Most Loved) -->
  <section class="best" id="best-sellers" aria-label="Most loved">
    <div class="best__inner">
      <div class="best__head best__head--row">
        <div class="reveal">
          <span class="eyebrow">Most Loved</span>
          <h2 class="section-title" style="margin-top:14px;">The <em>Icons</em></h2>
        </div>
        <a href="/shop" class="btn-dark reveal d1">
          View All Products 
          <svg width="13" height="9" viewBox="0 0 14 10" fill="none">
            <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
          </svg>
        </a>
      </div>
      
      <div class="best__grid">
        {icons.map((product, idx) => {
          const delays = ['', 'd1', 'd2', 'd3'];
          return (
            <ProductCard 
              product={product} 
              delayClass={delays[idx]} 
            />
          );
        })}
      </div>
    </div>
  </section>

  <!-- 7. Showcase Slider -->
  <Showcase />

  <!-- 8. Seasonal Campaign -->
  <section class="camp" id="campaign" aria-label="Resort 2026 campaign">
    <div class="camp__media">
      <Image src={imgCampaign} alt="Resort 2026 campaign" width={1440} height={700} loading="lazy" />
    </div>
    <div class="camp__overlay"></div>
    <div class="camp__frame" aria-hidden="true"></div>
    <span class="camp__vlabel">Côte d'Azur · 2026</span>
    <div class="camp__inner">
      <div class="camp__content reveal">
        <span class="camp__num">N°02</span>
        <span class="camp__eyebrow">The Seasonal Campaign</span>
        <h2 class="camp__title">An Ode to <em>Stillness</em></h2>
        <p class="camp__desc">Captured at first light along the Riviera — a study in restraint, natural fibres, and the quiet confidence of a wardrobe built to last.</p>
        <div class="camp__cta">
          <a href="/shop" class="btn-primary">
            Discover the Campaign 
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
              <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
            </svg>
          </a>
          <a href="#showcase" class="btn-ghost-d">
            <span class="play">
              <svg width="7" height="8" viewBox="0 0 7 8" fill="currentColor">
                <path d="M0 0l7 4-7 4z" />
              </svg>
            </span> 
            Watch the Film
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 9. Testimonials & Press -->
  <Testimonials />

  <!-- 10. The Journal Notes -->
  <Journal />

  <!-- 11. Newsletter Card -->
  <section class="news" id="newsletter" aria-label="Newsletter">
    <div class="news__inner">
      <div class="news__card reveal">
        <span class="news__ghost" aria-hidden="true">Arden</span>
        <div class="news__left">
          <span class="news__eyebrow">The Maison Letter</span>
          <h2 class="news__title">Considered style, <em>in your inbox.</em></h2>
          <p class="news__sub">Be first to see new collections, atelier stories and seasonal lookbooks — thoughtfully sent, never noisy.</p>
        </div>
        <div class="news__right">
          <form class="news__form" onsubmit="return false;">
            <input class="news__input" type="email" placeholder="Your email address" aria-label="Email" required />
            <button class="news__btn" type="submit">Subscribe</button>
          </form>
          <div class="news__benefits">
            <span class="news__benefit">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Early Access
            </span>
            <span class="news__benefit">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Member Events
            </span>
            <span class="news__benefit">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Seasonal Lookbooks
            </span>
          </div>
          <p class="news__note">By subscribing you agree to our Privacy Policy. Unsubscribe anytime.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Dynamic client-side filtering for New Arrivals section tabs
  const tabs = Array.from(document.querySelectorAll('.prod__tab')) as HTMLButtonElement[];
  const cards = Array.from(document.querySelectorAll('#new-arrivals .pc')) as HTMLElement[];
  const emptyState = document.querySelector('[data-prod-empty]') as HTMLElement | null;

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      // Toggle active classes on tabs
      tabs.forEach(t => t.classList.remove('is-active'));
      tab.classList.add('is-active');

      const filter = tab.dataset.filter || 'all';
      let visibleCount = 0;

      cards.forEach(card => {
        const cat = (card.dataset.cat || '').toLowerCase();
        let visible = true;

        if (filter === 'women') visible = cat.includes('women') || cat.includes('unisex');
        else if (filter === 'men') visible = cat.includes('men') || cat.includes('unisex');
        else if (filter === 'accessories') visible = cat.includes('accessories') || cat.includes('bags');

        card.style.display = visible ? '' : 'none';
        if (visible) visibleCount++;
      });

      if (emptyState) emptyState.hidden = visibleCount > 0;
    });
  });
</script>

<style>
  /* ============ NEW ARRIVALS & BEST SELLERS WRAPPERS ============ */
  .prod,
  .best {
    background: var(--lux-light-bg);
  }

  .prod__inner,
  .best__inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: var(--section-y) var(--gutter);
  }

  .prod__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: clamp(28px, 3vw, 44px);
  }

  .prod__tabs {
    display: flex;
    gap: 0;
    flex-wrap: wrap;
  }

  .prod__tab {
    background: none;
    border: none;
    padding: 9px 0;
    margin-right: 24px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--lux-on-light-soft);
    position: relative;
    transition: color .25s var(--ease);
    cursor: pointer;
  }

  .prod__tab::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: var(--lux-primary-dark);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .3s var(--ease);
  }

  .prod__tab:hover {
    color: var(--lux-on-light);
  }

  .prod__tab.is-active {
    color: var(--lux-on-light);
  }

  .prod__tab.is-active::after {
    transform: scaleX(1);
  }

  .best__head {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    margin-bottom: clamp(36px, 4vw, 56px);
  }

  .best__head--row {
    flex-direction: row;
    align-items: flex-end;
    justify-content: space-between;
    text-align: left;
    gap: 24px;
  }

  @media (max-width: 600px) {
    .best__head--row {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  .prod__grid,
  .best__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(16px, 1.8vw, 28px);
  }

  .prod__foot {
    text-align: center;
    margin-top: clamp(40px, 4.5vw, 64px);
  }

  .prod__empty {
    text-align: center;
    font-size: 14px;
    color: var(--lux-on-light-soft);
    padding: 40px 0;
  }

  @media (max-width:900px) {
    .prod__grid,
    .best__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width:460px) {
    .prod__grid,
    .best__grid {
      gap: 14px;
    }
  }

  /* ============ CAMPAIGN SECTION ============ */
  .camp {
    position: relative;
    min-height: clamp(520px, 82vh, 820px);
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--lux-bg-dark);
    margin-top: 150px;
  }

  .camp__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .camp__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    filter: saturate(.7) contrast(1.05) brightness(.62);
    transform: scale(1.04);
    transition: transform 2s var(--ease);
  }

  .camp:hover .camp__media img {
    transform: scale(1.09);
  }

  .camp__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(100deg, rgba(23, 26, 21, .9) 0%, rgba(23, 26, 21, .66) 40%, rgba(23, 26, 21, .28) 72%, rgba(23, 26, 21, .08) 100%);
  }

  .camp__frame {
    position: absolute;
    inset: clamp(18px, 2.2vw, 34px);
    z-index: 2;
    border: 1px solid rgba(231, 236, 120, .16);
    pointer-events: none;
  }

  .camp__frame::before {
    content: "";
    position: absolute;
    top: -1px;
    left: -1px;
    width: 20px;
    height: 20px;
    border-top: 1px solid var(--lux-accent-lime);
    border-left: 1px solid var(--lux-accent-lime);
  }

  .camp__frame::after {
    content: "";
    position: absolute;
    bottom: -1px;
    right: -1px;
    width: 20px;
    height: 20px;
    border-bottom: 1px solid var(--lux-accent-lime);
    border-right: 1px solid var(--lux-accent-lime);
  }

  .camp__vlabel {
    position: absolute;
    right: clamp(28px, 3vw, 50px);
    top: 50%;
    z-index: 3;
    transform: translateY(-50%);
    writing-mode: vertical-rl;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--lux-text-secondary);
    opacity: .6;
  }

  .camp__inner {
    position: relative;
    z-index: 3;
    max-width: var(--maxw);
    width: 100%;
    margin: 0 auto;
    padding: clamp(56px, 8vw, 120px) var(--gutter);
  }

  .camp__content {
    max-width: 620px;
  }

  .camp__num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 22px;
    color: var(--lux-accent-lime);
  }

  .camp__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-top: 14px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--lux-text-soft);
  }

  .camp__eyebrow::before {
    content: "";
    width: 30px;
    height: 1px;
    background: var(--lux-accent-lime);
  }

  .camp__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(46px, 6vw, 84px);
    line-height: 1;
    letter-spacing: -2px;
    color: var(--lux-text-primary);
    margin: 18px 0 0;
  }

  .camp__title em {
    font-style: italic;
    color: var(--lux-text-soft);
  }

  .camp__desc {
    font-size: clamp(15px, 1.1vw, 18px);
    line-height: 1.75;
    color: var(--lux-text-secondary);
    max-width: 46ch;
    margin: 24px 0 0;
  }

  .camp__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 38px;
  }

  .btn-ghost-d {
    display: inline-flex;
    align-items: center;
    gap: 11px;
    padding: 16px 32px;
    background: transparent;
    color: var(--lux-text-primary);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    border: 1px solid var(--lux-border);
    transition: color .3s var(--ease), border-color .3s var(--ease);
  }

  .btn-ghost-d:hover {
    color: var(--lux-accent-lime);
    border-color: var(--lux-accent-lime);
  }

  .btn-ghost-d .play {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border: 1px solid currentColor;
    border-radius: 50%;
  }

  @media (max-width:768px) {
    .camp__vlabel {
      display: none;
    }

    .camp__overlay {
      background: linear-gradient(to top, rgba(23, 26, 21, .94), rgba(23, 26, 21, .5));
    }

    .btn-primary,
    .btn-ghost-d {
      flex: 1 1 auto;
      justify-content: center;
    }
  }

  /* ============ NEWSLETTER CTA ============ */
  .news__inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 50px 140px 50px;
  }

  .news__card {
    position: relative;
    overflow: hidden;
    background: var(--lux-bg-dark);
    border-radius: 0;
    padding: clamp(40px, 5vw, 80px) clamp(28px, 5vw, 80px);
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: clamp(36px, 5vw, 72px);
    align-items: center;
  }

  .news__card::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(0deg, rgba(231, 236, 120, .04) 0, rgba(231, 236, 120, .04) 1px, transparent 1px, transparent 44px), repeating-linear-gradient(90deg, rgba(231, 236, 120, .04) 0, rgba(231, 236, 120, .04) 1px, transparent 1px, transparent 44px);
    pointer-events: none;
  }

  .news__ghost {
    position: absolute;
    right: -20px;
    bottom: -60px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(140px, 18vw, 260px);
    color: var(--lux-accent-lime);
    opacity: .05;
    pointer-events: none;
    line-height: 1;
  }

  .news__left {
    position: relative;
    z-index: 1;
  }

  .news__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.9px;
    text-transform: uppercase;
    color: var(--lux-text-secondary);
    margin-bottom: 18px;
  }

  .news__eyebrow::before {
    content: "";
    width: 30px;
    height: 1px;
    background: var(--lux-accent-lime);
  }

  .news__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(32px, 3.6vw, 52px);
    line-height: 1.05;
    letter-spacing: -1.2px;
    color: var(--lux-text-primary);
    margin: 0;
  }

  .news__title em {
    font-style: italic;
    color: var(--lux-accent-lime);
  }

  .news__sub {
    font-size: clamp(14px, 1.05vw, 16px);
    line-height: 1.7;
    color: var(--lux-text-secondary);
    margin: 18px 0 0;
    max-width: 46ch;
  }

  .news__right {
    position: relative;
    z-index: 1;
  }

  .news__form {
    display: flex;
    gap: 10px;
    background: rgba(241, 242, 234, .06);
    border: 1px solid var(--lux-border);
    border-radius: 0;
    padding: 6px 6px 6px 22px;
  }

  .news__input {
    flex: 1;
    background: none;
    border: none;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--lux-text-primary);
    outline: none;
  }

  .news__input::placeholder {
    color: var(--lux-text-secondary);
  }

  .news__btn {
    flex-shrink: 0;
    background: var(--lux-accent-lime);
    color: var(--lux-bg-dark);
    border: none;
    border-radius: 0;
    padding: 14px 28px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    transition: background .28s var(--ease);
  }

  .news__btn:hover {
    background: var(--lux-accent-hover);
  }

  .news__benefits {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 26px;
    margin-top: 22px;
  }

  .news__benefit {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--lux-text-secondary);
  }

  .news__benefit svg {
    color: var(--lux-accent-lime);
  }

  .news__note {
    font-size: 12px;
    color: var(--lux-text-secondary);
    margin: 16px 0 0;
    opacity: .8;
  }

  @media (max-width: 820px) {
    .news__inner {
      padding: 0 var(--gutter) var(--section-y) var(--gutter);
    }
    .news__card {
      grid-template-columns: 1fr;
      gap: 30px;
    }
  }

  @media (max-width: 460px) {
    .news__form {
      flex-direction: column;
      border-radius: 0;
      padding: 14px;
    }

    .news__btn {
      padding: 14px;
    }
  }
</style>
