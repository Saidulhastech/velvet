---
// Dynamic Shopify online-store pages (policies, size guide, FAQ, etc.) by handle.
// SSR — resolves the page from Shopify at request time; 404s when absent.
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { getPage } from '../../lib/shopify';

const { handle } = Astro.params;
const page = handle ? await getPage(handle) : null;
if (!page) {
  return Astro.redirect('/404');
}

const crumbTitle = page.title;
---

<BaseLayout title={page.seo?.title || page.title} description={page.seo?.description || page.bodySummary || ''}>
  <section class="legal">
    <div class="legal__inner">
      <div class="legal__crumb"><a href="/">Home</a> &nbsp;/&nbsp; <span>{crumbTitle}</span></div>
      <h1 class="legal__title" set:html={page.title.replace(/\b(\w+)$/, '<em>$1</em>')}></h1>

      <div class="legal__body" set:html={page.body}></div>
    </div>
  </section>
</BaseLayout>

<style>
  .legal {
    max-width: 820px;
    margin: 0 auto;
    padding: clamp(48px, 6vw, 96px) var(--gutter) clamp(64px, 8vw, 120px);
  }

  .legal__crumb {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--lux-on-light-soft);
    margin-bottom: 22px;
  }

  .legal__crumb a { color: var(--lux-on-light-soft); transition: color .2s var(--ease); }
  .legal__crumb a:hover { color: var(--lux-on-light); }
  .legal__crumb span { color: var(--lux-secondary-olive); }

  .legal__title {
    font-family: var(--font-display);
    font-size: clamp(34px, 4.5vw, 60px);
    font-weight: 500;
    line-height: 1.02;
    letter-spacing: -1.2px;
    color: var(--lux-on-light);
    margin: 0 0 40px;
  }

  .legal__title :global(em) { font-style: italic; color: var(--lux-secondary-olive); }

  .legal__body {
    font-size: clamp(14px, 1.05vw, 16px);
    line-height: 1.8;
    color: var(--lux-on-light-soft);
  }

  .legal__body :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(19px, 2vw, 24px);
    font-weight: 500;
    color: var(--lux-on-light);
    margin: 40px 0 14px;
  }

  .legal__body :global(h3) {
    font-size: 16px;
    font-weight: 600;
    color: var(--lux-on-light);
    margin: 28px 0 10px;
  }

  .legal__body :global(p) { margin: 0 0 18px; }
  .legal__body :global(ul),
  .legal__body :global(ol) { margin: 0 0 18px; padding-left: 22px; }
  .legal__body :global(li) { margin-bottom: 8px; }
  .legal__body :global(a) { color: var(--lux-secondary-olive); text-decoration: underline; }
  .legal__body :global(img) { max-width: 100%; height: auto; margin: 24px 0; }
</style>
