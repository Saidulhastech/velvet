---
// Collections index — every Shopify collection as a landing card.
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { getShopifyCollections } from '../../lib/shopify/client';

const collections = await getShopifyCollections(Astro.locals.market);
---

<BaseLayout title="Collections" description="Explore Maison Arden by collection — curated edits of considered pieces.">
  <section class="shop-hero">
    <div class="shop-hero__inner">
      <div class="shop-hero__crumb"><a href="/">Home</a> &nbsp;/&nbsp; <span>Collections</span></div>
      <h1 class="shop-hero__title">Our <em>Collections</em></h1>
      <p class="shop-hero__sub">Curated edits of the wardrobe — explore by theme, season and category.</p>
    </div>
  </section>

  <section class="cols" aria-label="Collections">
    <div class="cols__inner">
      {collections.length > 0 ? (
        <div class="cols__grid">
          {collections.map((c) => (
            <a class="ccard reveal" href={`/collections/${c.handle}`}>
              <div class="ccard__media">
                {c.image ? (
                  <img src={c.image} alt={c.title} loading="lazy" />
                ) : (
                  <div class="ccard__ph"><span>{c.title}</span></div>
                )}
                <span class="ccard__count">{c.count > 0 ? `${c.count}${c.count >= 250 ? '+' : ''} pieces` : 'View'}</span>
              </div>
              <div class="ccard__body">
                <h2 class="ccard__title">{c.title}</h2>
                {c.description && <p class="ccard__desc">{c.description}</p>}
                <span class="ccard__link">Explore
                  <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="cols-empty">
          <p class="cols-empty__title">No collections found.</p>
          <p class="cols-empty__desc">Browse the full wardrobe instead.</p>
          <a href="/shop" class="btn-dark">Shop the Collection
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
          </a>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .shop-hero { background: var(--lux-light-surface); border-bottom: 1px solid var(--lux-light-border); }
  .shop-hero__inner { max-width: var(--maxw); margin: 0 auto; padding: clamp(40px,5vw,72px) var(--gutter) clamp(34px,4vw,56px); text-align: center; }
  .shop-hero__crumb { font-size: 11px; font-weight: 500; letter-spacing: 1px; text-transform: uppercase; color: var(--lux-on-light-soft); margin-bottom: 16px; }
  .shop-hero__crumb a { color: var(--lux-on-light-soft); transition: color .2s var(--ease); }
  .shop-hero__crumb a:hover { color: var(--lux-on-light); }
  .shop-hero__crumb span { color: var(--lux-secondary-olive); }
  .shop-hero__title { font-family: var(--font-display); font-size: clamp(40px,5vw,72px); font-weight: 500; line-height: 1; letter-spacing: -1.5px; color: var(--lux-on-light); }
  .shop-hero__title em { font-style: italic; color: var(--lux-secondary-olive); }
  .shop-hero__sub { font-size: clamp(14px,1.05vw,16px); line-height: 1.7; color: var(--lux-on-light-soft); max-width: 56ch; margin: 16px auto 0; }

  .cols__inner { max-width: var(--maxw); margin: 0 auto; padding: clamp(40px,5vw,72px) var(--gutter) clamp(64px,8vw,110px); }
  .cols__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(18px,2vw,32px); }
  @media (max-width: 900px) { .cols__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .cols__grid { grid-template-columns: 1fr; } }

  .ccard { display: flex; flex-direction: column; text-decoration: none; color: inherit; }
  .ccard__media { position: relative; aspect-ratio: 4/5; overflow: hidden; background: var(--lux-light-surface); }
  .ccard__media img { width: 100%; height: 100%; object-fit: cover; transition: transform 1.1s var(--ease); }
  .ccard:hover .ccard__media img { transform: scale(1.06); }
  .ccard__ph { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: var(--lux-primary-dark); }
  .ccard__ph span { font-family: var(--font-display); font-style: italic; font-size: clamp(20px,2.4vw,30px); color: var(--lux-accent-lime); text-align: center; padding: 0 16px; }
  .ccard__count { position: absolute; top: 12px; left: 12px; padding: 5px 11px; background: var(--lux-light-elevated); color: var(--lux-on-light); font-size: 9px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; }
  .ccard__body { padding-top: 16px; display: flex; flex-direction: column; gap: 8px; }
  .ccard__title { font-family: var(--font-display); font-size: clamp(18px,1.6vw,22px); font-weight: 500; color: var(--lux-on-light); margin: 0; }
  .ccard__desc { font-size: 13px; line-height: 1.6; color: var(--lux-on-light-soft); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .ccard__link { display: inline-flex; align-items: center; gap: 8px; font-size: 11px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: var(--lux-secondary-olive); margin-top: 2px; }

  .cols-empty { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 10px; padding: clamp(48px,8vw,110px) 0; color: var(--lux-on-light-soft); }
  .cols-empty__title { font-family: var(--font-display); font-size: 22px; color: var(--lux-on-light); }
  .cols-empty .btn-dark { margin-top: 14px; }
</style>
