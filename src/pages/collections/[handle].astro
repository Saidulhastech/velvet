---
// Collection landing — products in a Shopify collection, mapped to the legacy
// card shape and rendered in velvet's grid. SSR, market-aware.
import BaseLayout from '../../components/layout/BaseLayout.astro';
import ProductCard from '../../components/product/ProductCard.astro';
import { getShopifyCollection } from '../../lib/shopify/client';

const { handle } = Astro.params;
const collection = handle ? await getShopifyCollection(handle, Astro.locals.market) : null;
if (!collection) {
  return Astro.redirect('/404');
}
const products = collection.products;
---

<BaseLayout title={collection.title} description={collection.description || `Shop the ${collection.title} collection at Maison Arden.`}>
  <section class="shop-hero">
    <div class="shop-hero__inner">
      <div class="shop-hero__crumb"><a href="/">Home</a> &nbsp;/&nbsp; <a href="/collections">Collections</a> &nbsp;/&nbsp; <span>{collection.title}</span></div>
      <h1 class="shop-hero__title">{collection.title}</h1>
      {collection.description && <p class="shop-hero__sub">{collection.description}</p>}
    </div>
  </section>

  <section class="col" aria-label={`${collection.title} products`}>
    <div class="col__inner">
      <div class="col__bar"><span class="col__count">{products.length} {products.length === 1 ? 'piece' : 'pieces'}</span></div>

      {products.length > 0 ? (
        <div class="shop-grid">
          {products.map((product, idx) => (
            <ProductCard product={product} delayClass={`d${(idx % 4) + 1}`} />
          ))}
        </div>
      ) : (
        <div class="col-empty">
          <p class="col-empty__title">Nothing here yet.</p>
          <p class="col-empty__desc">This collection has no products right now.</p>
          <a href="/shop" class="btn-dark">Browse the Collection
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
          </a>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .shop-hero { background: var(--lux-light-surface); border-bottom: 1px solid var(--lux-light-border); }
  .shop-hero__inner { max-width: var(--maxw); margin: 0 auto; padding: clamp(40px,5vw,72px) var(--gutter) clamp(34px,4vw,56px); text-align: center; }
  .shop-hero__crumb { font-size: 11px; font-weight: 500; letter-spacing: 1px; text-transform: uppercase; color: var(--lux-on-light-soft); margin-bottom: 16px; }
  .shop-hero__crumb a { color: var(--lux-on-light-soft); transition: color .2s var(--ease); }
  .shop-hero__crumb a:hover { color: var(--lux-on-light); }
  .shop-hero__crumb span { color: var(--lux-secondary-olive); }
  .shop-hero__title { font-family: var(--font-display); font-size: clamp(40px,5vw,72px); font-weight: 500; line-height: 1; letter-spacing: -1.5px; color: var(--lux-on-light); }
  .shop-hero__sub { font-size: clamp(14px,1.05vw,16px); line-height: 1.7; color: var(--lux-on-light-soft); max-width: 56ch; margin: 16px auto 0; }

  .col__inner { max-width: var(--maxw); margin: 0 auto; padding: clamp(32px,4vw,56px) var(--gutter) clamp(64px,8vw,110px); }
  .col__bar { margin-bottom: 26px; }
  .col__count { font-size: 12px; letter-spacing: .6px; text-transform: uppercase; color: var(--lux-on-light-soft); }

  .shop-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(16px,1.8vw,30px); }
  @media (max-width: 900px) { .shop-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .shop-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; } }

  .col-empty { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 10px; padding: clamp(48px,8vw,110px) 0; color: var(--lux-on-light-soft); }
  .col-empty__title { font-family: var(--font-display); font-size: 22px; color: var(--lux-on-light); }
  .col-empty .btn-dark { margin-top: 14px; }
</style>
