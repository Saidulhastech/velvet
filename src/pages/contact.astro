---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { Image } from 'astro:assets';

// Import images
import imgBout1 from '../assets/images/ct-bout__overlay image 01.png';
import imgBout2 from '../assets/images/ct-bout__overlay image 02.png';
import imgBout3 from '../assets/images/ct-bout__overlay image 03.png';

const boutiques = [
  {
    city: 'Paris',
    address: '18 Rue Saint-Honoré, 75001',
    hours: 'Mon–Sat · 10am–7pm CET',
    badge: 'Flagship',
    num: '01',
    image: imgBout1,
    delay: ''
  },
  {
    city: 'London',
    address: '9 Mount Street, Mayfair W1K',
    hours: 'Mon–Sat · 10am–6pm GMT',
    num: '02',
    image: imgBout2,
    delay: 'd1'
  },
  {
    city: 'Milan',
    address: 'Via Montenapoleone 12, 20121',
    hours: 'Mon–Sat · 10am–7pm CET',
    num: '03',
    image: imgBout3,
    delay: 'd2'
  }
];

const faqItems = [
  {
    cat: 'shipping',
    q: 'How long does delivery take?',
    a: 'Standard courier arrives within 3–5 business days and Express Air within 1–2. Orders placed before 2pm CET ship the same day, with complimentary carbon-neutral delivery worldwide.'
  },
  {
    cat: 'returns',
    q: 'What is your returns policy?',
    a: 'We offer complimentary returns within 30 days of delivery. Items should be unworn with original tags. Refunds are issued to your original payment method within 5 business days of receipt.'
  },
  {
    cat: 'sizing',
    q: 'How do I choose the right size?',
    a: 'Each product page includes a detailed size guide with measurements. For tailoring or in-between sizes, our specialists are happy to advise — just select "Product & Sizing" in the form above.'
  },
  {
    cat: 'sizing',
    q: 'Can I book a private appointment?',
    a: 'Yes — private styling appointments are available at all boutiques. Select "Private Appointment" in the form above or call your nearest atelier directly.'
  },
  {
    cat: 'care',
    q: 'How should I care for my pieces?',
    a: 'Each garment includes detailed care guidance. In general, store knitwear folded, steam to refresh, and use a specialist dry cleaner for tailoring. Complimentary lifetime repairs are included on every piece.'
  },
  {
    cat: 'shipping',
    q: 'Do you offer gift wrapping?',
    a: 'Yes. Add complimentary gift wrapping at checkout — ivory tissue, a satin ribbon and a hand-written message card, presented in our signature box.'
  },
  {
    cat: 'returns',
    q: 'Can I amend or cancel my order?',
    a: 'Orders can be amended or cancelled within one hour of placing them. Contact client care as soon as possible and we\'ll do everything we can before your order enters fulfilment.'
  }
];
---

<BaseLayout title="Contact Us">
  <!-- HERO -->
  <section class="shop-hero">
    <div class="shop-hero__inner">
      <div class="shop-hero__crumb"><a href="/">Home</a> &nbsp;/&nbsp; <span>Contact</span></div>
      <h1 class="shop-hero__title">Get in <em>Touch</em></h1>
      <p class="shop-hero__sub">Questions about an order, a fitting, or a private appointment? Our client care team replies within one business day.</p>
    </div>
  </section>

  <!-- FORM + INFO -->
  <section class="ct-grid" aria-label="Contact">
    <form class="ct-form" id="contactForm" novalidate>
      <span class="ct-form__eyebrow">Send a Message</span>
      <h2 class="ct-form__title">We’d love to hear from you</h2>
      <p class="ct-form__lede">Complete the form and a member of our atelier team will be in touch shortly.</p>
      
      <div class="ct-assure">
        <span class="ct-assure__item">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <circle cx="8" cy="8" r="6.5" stroke="currentColor" />
            <path d="M8 5v3.2l2 1.3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
          </svg> 
          Replies within 1 business day
        </span>
        <span class="ct-assure__item">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <rect x="2.5" y="7" width="11" height="6.5" rx="1" stroke="currentColor" />
            <path d="M5 7V5a3 3 0 0 1 6 0v2" stroke="currentColor" stroke-linecap="round" />
          </svg> 
          Private &amp; secure
        </span>
        <span class="ct-assure__item">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <circle cx="8" cy="6" r="2.6" stroke="currentColor" />
            <path d="M3 13.5c1-2.6 2.8-3.8 5-3.8s4 1.2 5 3.8" stroke="currentColor" stroke-linecap="round" />
          </svg> 
          Real specialists, not bots
        </span>
      </div>
      
      <div class="ct-fgrid">
        <div class="ct-field">
          <label class="ct-label" for="ctName">Full Name</label>
          <input class="ct-input" id="ctName" required />
        </div>
        <div class="ct-field">
          <label class="ct-label" for="ctEmail">Email</label>
          <input class="ct-input" type="email" id="ctEmail" placeholder="you@email.com" required />
        </div>
        <div class="ct-field">
          <label class="ct-label" for="ctPhone">Phone <span style="text-transform:none;font-weight:400;letter-spacing:0;color:var(--lux-on-light-soft)">(optional)</span></label>
          <input class="ct-input" type="tel" id="ctPhone" />
        </div>
        <div class="ct-field">
          <label class="ct-label" for="ctTopic">Topic</label>
          <select class="ct-select" id="ctTopic">
            <option>Order &amp; Delivery</option>
            <option>Product &amp; Sizing</option>
            <option>Private Appointment</option>
            <option>Repairs &amp; Care</option>
            <option>Press &amp; Partnerships</option>
            <option>Something Else</option>
          </select>
        </div>
        <div class="ct-field ct-field--full">
          <label class="ct-label">Preferred reply</label>
          <div class="ct-pills" data-pref>
            <button type="button" class="ct-pill is-active" data-pref-val="Email">
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
                <rect x="2" y="3.5" width="12" height="9" stroke="currentColor" />
                <path d="M2.5 4.5L8 8.5l5.5-4" stroke="currentColor" />
              </svg> 
              Email
            </button>
            <button type="button" class="ct-pill" data-pref-val="Phone">
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
                <path d="M5 2.5H3.2a.8.8 0 0 0-.8.9c0 5.6 4.6 10.2 10.2 10.2a.8.8 0 0 0 .9-.8V11l-2.7-.9-1.3 1.3a7.5 7.5 0 0 1-3.8-3.8L6.9 6.2 6 3.5z" stroke="currentColor" stroke-linejoin="round" />
              </svg> 
              Phone Call
            </button>
          </div>
        </div>
        <div class="ct-field ct-field--full">
          <label class="ct-label" for="ctMsg">Message</label>
          <textarea class="ct-textarea" id="ctMsg" maxlength="600" placeholder="How can we help?" required></textarea>
          <span class="ct-count"><span data-count>0</span> / 600</span>
        </div>
      </div>
      
      <div class="ct-actions">
        <button type="submit" class="btn-dark ct-send">
          Send Message 
          <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
            <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
          </svg>
        </button>
        <p class="ct-form__msg" data-ct-msg></p>
      </div>
    </form>

    <aside class="ct-info">
      <h2 class="ct-info__title">Client Care</h2>
      <p class="ct-info__intro">Our specialists are here Monday to Saturday to help with orders, styling and appointments — however you prefer to reach us.</p>
      <div class="ct-info__list">
        <a class="ct-info__item" href="mailto:client@maisonarden.com">
          <span class="ct-info__icon">
            <svg width="17" height="17" viewBox="0 0 18 18" fill="none">
              <rect x="2" y="3.5" width="14" height="11" stroke="currentColor" stroke-width="1.2" />
              <path d="M2.5 4.5L9 9l6.5-4.5" stroke="currentColor" stroke-width="1.2" />
            </svg>
          </span>
          <span class="ct-info__txt">
            <span class="ct-info__label">Email Us</span>
            <span class="ct-info__val">client@maisonarden.com</span>
          </span>
        </a>
        
        <a class="ct-info__item" href="tel:+33100000000">
          <span class="ct-info__icon">
            <svg width="17" height="17" viewBox="0 0 18 18" fill="none">
              <path d="M5 2.5H3a1 1 0 0 0-1 1c0 6.6 5.4 12 12 12a1 1 0 0 0 1-1v-2l-3.2-1.1-1.6 1.6a9 9 0 0 1-4.6-4.6L7.6 6.7 6.5 3.5 5 2.5z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" />
            </svg>
          </span>
          <span class="ct-info__txt">
            <span class="ct-info__label">Call Us</span>
            <span class="ct-info__val">+33 1 00 00 00 00</span>
          </span>
        </a>
        
        <div class="ct-info__item">
          <span class="ct-info__icon">
            <svg width="17" height="17" viewBox="0 0 18 18" fill="none">
              <path d="M9 1.5C6.2 1.5 4 3.7 4 6.5c0 3.6 5 10 5 10s5-6.4 5-10c0-2.8-2.2-5-5-5z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" />
              <circle cx="9" cy="6.5" r="1.8" stroke="currentColor" stroke-width="1.2" />
            </svg>
          </span>
          <span class="ct-info__txt">
            <span class="ct-info__label">Flagship Atelier</span>
            <span class="ct-info__val">18 Rue Saint-Honoré, 75001 Paris</span>
          </span>
        </div>
        
        <div class="ct-info__item">
          <span class="ct-info__icon">
            <svg width="17" height="17" viewBox="0 0 18 18" fill="none">
              <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.2" />
              <path d="M9 5v4.2l2.6 1.6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <span class="ct-info__txt">
            <span class="ct-info__label">Opening Hours</span>
            <span class="ct-info__val">Mon–Sat · 10am–7pm CET<br />Sunday · By appointment</span>
          </span>
        </div>
      </div>
      
      <div class="ct-info__divider"></div>
      <div class="ct-info__soc-label">Follow the Maison</div>
      <div class="ct-soc">
        <a href="#" aria-label="Instagram">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
            <rect x="2.5" y="2.5" width="15" height="15" rx="4" stroke="currentColor" stroke-width="1.3" />
            <circle cx="10" cy="10" r="3.5" stroke="currentColor" stroke-width="1.3" />
            <circle cx="14.5" cy="5.5" r="1" fill="currentColor" />
          </svg>
        </a>
        <a href="#" aria-label="Pinterest">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
            <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.3" />
            <path d="M8 15l2-7m0 0a2.5 2.5 0 1 1 2.4 1.7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
          </svg>
        </a>
        <a href="#" aria-label="TikTok">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
            <path d="M11 3v9.5a3 3 0 1 1-3-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
            <path d="M11 5.5c.6 1.5 1.8 2.4 3.5 2.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
          </svg>
        </a>
      </div>
    </aside>
  </section>

  <!-- DEPARTMENTS -->
  <section class="ct-dept" aria-label="Departments">
    <div class="ct-dept__inner">
      <div class="ct-dept__head reveal">
        <span class="eyebrow eyebrow--center">Reach the Right Team</span>
        <h2 class="section-title">By <em>Department</em></h2>
      </div>
      <div class="ct-dept__grid">
        <div class="ct-deptcard reveal">
          <div class="ct-deptcard__icon">
            <svg width="20" height="20" viewBox="0 0 22 22" fill="none">
              <circle cx="11" cy="8" r="3.5" stroke="currentColor" stroke-width="1.3" />
              <path d="M3 19c1.3-4 4.2-6 8-6s6.7 2 8 6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
            </svg>
          </div>
          <div class="ct-deptcard__title">Client Care</div>
          <p class="ct-deptcard__desc">Orders, sizing, returns and lifetime repairs.</p>
          <a href="mailto:client@maisonarden.com" class="ct-deptcard__link">client@maisonarden.com</a>
        </div>
        
        <div class="ct-deptcard reveal d1">
          <div class="ct-deptcard__icon">
            <svg width="20" height="20" viewBox="0 0 22 22" fill="none">
              <rect x="3" y="4" width="16" height="14" stroke="currentColor" stroke-width="1.3" />
              <path d="M3 8h16M7 12h6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
            </svg>
          </div>
          <div class="ct-deptcard__title">Press &amp; Media</div>
          <p class="ct-deptcard__desc">Editorial requests, imagery and interviews.</p>
          <a href="mailto:press@maisonarden.com" class="ct-deptcard__link">press@maisonarden.com</a>
        </div>
        
        <div class="ct-deptcard reveal d2">
          <div class="ct-deptcard__icon">
            <svg width="20" height="20" viewBox="0 0 22 22" fill="none">
              <path d="M4 8l7-4 7 4v8l-7 4-7-4z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />
            </svg>
          </div>
          <div class="ct-deptcard__title">Wholesale</div>
          <p class="ct-deptcard__desc">Stockist and partnership enquiries.</p>
          <a href="mailto:partners@maisonarden.com" class="ct-deptcard__link">partners@maisonarden.com</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAP -->
  <section class="ct-map" aria-label="Our flagship">
    <div class="ct-map__inner">
      <div class="ct-map__head reveal">
        <div>
          <span class="eyebrow">Visit Us</span>
          <h2 class="section-title" style="margin-top:14px;">Find the <em>Atelier</em></h2>
        </div>
        <a href="https://www.google.com/maps?q=18+Rue+Saint-Honor%C3%A9+Paris" target="_blank" rel="noopener" class="btn-dark reveal d1">
          Get Directions 
          <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
            <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
          </svg>
        </a>
      </div>
      
      <div class="ct-map__frame reveal">
        <iframe src="https://www.google.com/maps?q=18+Rue+Saint-Honor%C3%A9+Paris&output=embed" loading="lazy" title="Maison Arden Paris flagship"></iframe>
        <div class="ct-map__card">
          <div class="ct-map__eyebrow">Paris Flagship</div>
          <h3 class="ct-map__title">18 Rue Saint-Honoré</h3>
          <p class="ct-map__addr">75001 Paris, France<br />Open Mon–Sat, 10am–7pm CET</p>
          <a href="tel:+33100000000" class="ct-map__link">
            Call the Boutique 
            <svg width="13" height="9" viewBox="0 0 14 10" fill="none">
              <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- BOUTIQUES -->
  <section class="ct-bouts" aria-label="Boutiques">
    <div class="ct-bouts__inner">
      <div class="ct-bouts__head reveal">
        <span class="eyebrow eyebrow--center">Worldwide</span>
        <h2 class="section-title">Our <em>Boutiques</em></h2>
        <p style="font-size:14px;color:var(--lux-on-light-soft);max-width:48ch;margin:4px auto 0;line-height:1.7">Book a private appointment or visit us in person — our specialists are ready to help you find the perfect piece.</p>
      </div>
      
      <div class="ct-bouts__grid">
        {boutiques.map((bout) => (
          <a href="#" class:list={['ct-bout reveal', bout.delay]}>
            <div class="ct-bout__media">
              {bout.badge && <span class="ct-bout__badge">{bout.badge}</span>}
              <span class="ct-bout__num">{bout.num}</span>
              <div class="ct-bout__overlay"></div>
              <Image src={bout.image} alt={`${bout.city} boutique`} width={360} height={480} loading="lazy" />
            </div>
            <div class="ct-bout__body">
              <div class="ct-bout__city">{bout.city}</div>
              <p class="ct-bout__addr">{bout.address}</p>
              <p class="ct-bout__hours">{bout.hours}</p>
              <span class="ct-bout__link">
                Book a Visit 
                <svg width="13" height="9" viewBox="0 0 14 10" fill="none">
                  <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Accordion -->
  <section class="faq2" aria-label="Frequently asked questions">
    <div class="faq2__inner">
      <header class="faq2__head reveal">
        <span class="eyebrow eyebrow--center">Help Centre</span>
        <h2 class="section-title">Frequently <em>Asked</em></h2>
        <p class="faq2__sub">Everything you need to know about ordering, delivery and caring for your Maison Arden pieces.</p>
      </header>
      
      <div class="faq2__cats reveal d1" data-faq-cats>
        <button class="faq2__cat is-active" data-filter="all">All</button>
        <button class="faq2__cat" data-filter="shipping">Shipping</button>
        <button class="faq2__cat" data-filter="returns">Returns</button>
        <button class="faq2__cat" data-filter="sizing">Sizing</button>
        <button class="faq2__cat" data-filter="care">Care</button>
      </div>
      
      <div class="faq2__list reveal d1" data-faq-list>
        {faqItems.map((item) => (
          <div class="faq2__item" data-cat={item.cat}>
            <button class="faq2__q">
              <span class="faq2__num"></span>
              <span class="faq2__qtext">{item.q}</span>
              <span class="faq2__ic" aria-hidden="true"></span>
            </button>
            <div class="faq2__a">
              <div class="faq2__a-in">
                <p>{item.a}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
      
      <div class="faq2__cta reveal">
        <span class="faq2__cta-text">Still have a question?</span>
        <a href="mailto:client@maisonarden.com" class="btn-dark">
          Contact Client Care 
          <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
            <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER CTA -->
  <section class="news" id="newsletter" aria-label="Newsletter">
    <div class="news__inner">
      <div class="news__card reveal">
        <span class="news__ghost" aria-hidden="true">Arden</span>
        <div class="news__left">
          <span class="news__eyebrow">The Maison Letter</span>
          <h2 class="news__title">Considered style, <em>in your inbox.</em></h2>
          <p class="news__sub">Be first to see new collections, atelier stories and seasonal lookbooks — thoughtfully sent, never noisy.</p>
        </div>
        <div class="news__right">
          <form class="news__form" onsubmit="return false;">
            <input class="news__input" type="email" placeholder="Your email address" aria-label="Email" required />
            <button class="news__btn" type="submit">Subscribe</button>
          </form>
          <div class="news__benefits">
            <span class="news__benefit">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Early Access
            </span>
            <span class="news__benefit">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Member Events
            </span>
            <span class="news__benefit">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Seasonal Lookbooks
            </span>
          </div>
          <p class="news__note">By subscribing you agree to our Privacy Policy. Unsubscribe anytime.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Char counter for contact form message
  const msgEl = document.querySelector('#ctMsg') as HTMLTextAreaElement;
  const cnt = document.querySelector('[data-count]') as HTMLElement;
  if (msgEl && cnt) {
    msgEl.addEventListener('input', () => {
      cnt.textContent = String(msgEl.value.length);
    });
  }

  // Preferred reply pills selection toggle
  const pills = Array.from(document.querySelectorAll('[data-pref] .ct-pill')) as HTMLButtonElement[];
  pills.forEach(b => {
    b.addEventListener('click', () => {
      pills.forEach(x => x.classList.remove('is-active'));
      b.classList.add('is-active');
    });
  });

  // Accordion open/close toggle for FAQs
  const faqQs = Array.from(document.querySelectorAll('.faq2__q')) as HTMLButtonElement[];
  const faqItems = Array.from(document.querySelectorAll('.faq2__item')) as HTMLElement[];
  faqQs.forEach(q => {
    q.addEventListener('click', () => {
      const item = q.closest('.faq2__item') as HTMLElement;
      const isOpen = item.classList.contains('is-open');
      faqItems.forEach(x => x.classList.remove('is-open'));
      if (!isOpen) {
        item.classList.add('is-open');
      }
    });
  });

  // Accordion dynamic categorised filtering
  const catBtns = Array.from(document.querySelectorAll('[data-faq-cats] .faq2__cat')) as HTMLButtonElement[];
  const listItems = Array.from(document.querySelectorAll('[data-faq-list] .faq2__item')) as HTMLElement[];
  catBtns.forEach(c => {
    c.addEventListener('click', () => {
      const filter = c.dataset.filter || 'all';
      catBtns.forEach(x => x.classList.toggle('is-active', x === c));
      
      listItems.forEach(it => {
        const show = filter === 'all' || it.dataset.cat === filter;
        it.classList.toggle('is-hidden', !show);
        it.classList.remove('is-open');
      });
    });
  });

  // Contact form client validation and submit feedback
  const form = document.querySelector('#contactForm') as HTMLFormElement;
  if (form) {
    const feedbackMsg = document.querySelector('[data-ct-msg]') as HTMLElement;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      let isValid = true;
      
      const requiredInputs = Array.from(form.querySelectorAll('.ct-input[required], .ct-textarea[required]')) as (HTMLInputElement | HTMLTextAreaElement)[];
      requiredInputs.forEach(f => {
        const empty = !f.value.trim();
        f.classList.toggle('is-invalid', empty);
        if (empty) isValid = false;
      });
      
      const emailInput = document.querySelector('#ctEmail') as HTMLInputElement;
      if (emailInput.value && !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(emailInput.value)) {
        emailInput.classList.add('is-invalid');
        isValid = false;
      }
      
      if (!isValid) {
        feedbackMsg.textContent = 'Please complete the required fields with a valid email.';
        feedbackMsg.className = 'ct-form__msg is-err';
        return;
      }
      
      feedbackMsg.textContent = 'Thank you — your message has been sent. We will reply within one business day.';
      feedbackMsg.className = 'ct-form__msg is-ok';
      form.reset();
      if (cnt) cnt.textContent = '0';
    });

    const formInputs = Array.from(form.querySelectorAll('.ct-input, .ct-textarea')) as (HTMLInputElement | HTMLTextAreaElement)[];
    formInputs.forEach(f => {
      f.addEventListener('input', () => f.classList.remove('is-invalid'));
    });
  }
</script>

