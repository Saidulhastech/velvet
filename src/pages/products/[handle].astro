---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import ProductCard from '../../components/product/ProductCard.astro';
import { getShopifyProductWithVariants, getShopifyProducts, getShopifyRelatedProducts } from '../../lib/shopify/client';
import { getProductReviews } from '../../lib/judgeme';

const { handle } = Astro.params;
const { product, variants: shopifyVariants, currency, singleVariant, productId } = await getShopifyProductWithVariants(handle || '', Astro.locals.market);
if (!product) {
  return Astro.rewrite('/404');
}

// Boot data for client-side variant controller
const bootData = JSON.stringify({ currency, variants: shopifyVariants, singleVariant, productId });

// Parse category and gender for breadcrumb
const categoryParts = product.category.split(' · ');
const genderLabel = categoryParts[0] ? (categoryParts[0] === 'Women' ? "Women's" : "Men's") : "";
const categoryName = categoryParts[1] || product.category;

// Dynamically import all images under src/assets/images for gallery
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.{jpeg,jpg,png,gif,webp,WebP}', { eager: true });

// Resolve one image ref: remote URLs pass through, local filenames resolve via
// the assets glob to an optimizable ImageMetadata.
const resolveImg = (img: string): any => {
  if (!img) return '';
  if (img.startsWith('http://') || img.startsWith('https://')) return img;
  const path = `/src/assets/images/${img}`;
  return images[path]?.default ?? img;
};

// Real gallery: the product's full image set when available, else its single
// image. No more per-handle hardcoding or faked filtered duplicates.
const sourceImages = (product.images && product.images.length > 0)
  ? product.images
  : [product.image].filter(Boolean);
let productImages: any[] = sourceImages.map(resolveImg).filter(Boolean);
if (productImages.length === 0) productImages = [product.image || ''];

const getSrcString = (img: any) => {
  if (typeof img === 'string') return img;
  return img?.src || '';
};

// Sizes still available for this product, from the real variant matrix. When
// there's no variant data (mock/single-variant) nothing is force-disabled.
const availableSizes = new Set(
  (product.variants ?? [])
    .filter((v) => v.available)
    .map((v) => String(v.opts?.Size ?? v.opts?.size ?? '').toLowerCase())
    .filter(Boolean),
);

const productsList = await getShopifyProducts(Astro.locals.market);

// Related products: prefer Shopify's real recommendation engine; fall back to a
// same-category/gender heuristic over the catalogue (covers mock mode + stores
// with no recommendations) so the grid never empties.
const related = await getShopifyRelatedProducts(productId, 4, Astro.locals.market);

if (related.length < 4) {
  const heuristic = productsList
    .filter((p) => p.category === product.category && p.id !== product.id)
    .concat(
      productsList.filter((p) => p.gender === product.gender && p.id !== product.id)
    )
    .filter((p) => !related.find((r) => r.id === p.id));
  for (const p of heuristic) {
    if (related.length >= 4) break;
    if (!related.find((r) => r.id === p.id)) related.push(p);
  }
}

// Real reviews only — fetched from Judge.me at request time (review TEXT lives
// in Judge.me, not a Shopify metafield). Empty when unconfigured or the
// product has none yet; never fabricated.
const realReviews = await getProductReviews(productId);
const reviewCount = product.ratingCount ?? realReviews.length;
const avgRating = product.rating ?? 0;
const starStr = (n: number) => '★'.repeat(Math.round(n)) + '☆'.repeat(5 - Math.round(n));
const initials = (name: string) => {
  const parts = name.trim().split(/\s+/).filter(Boolean);
  return (parts.length > 1 ? parts[0][0] + parts[parts.length - 1][0] : name.slice(0, 2)).toUpperCase();
};

// --- SEO: Product + Breadcrumb structured data -------------------------------
const productImageUrl = getSrcString(productImages[0]);
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.description,
  image: productImageUrl ? [new URL(productImageUrl, Astro.site ?? Astro.url).toString()] : undefined,
  sku: product.id,
  brand: { '@type': 'Brand', name: 'Maison Arden' },
  ...(product.rating && reviewCount > 0
    ? { aggregateRating: { '@type': 'AggregateRating', ratingValue: product.rating, reviewCount } }
    : {}),
  offers: {
    '@type': 'Offer',
    price: product.price,
    priceCurrency: currency,
    availability: product.stock === 'in'
      ? 'https://schema.org/InStock'
      : 'https://schema.org/PreOrder',
    url: Astro.url.href,
  },
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site ?? Astro.url).toString() },
    { '@type': 'ListItem', position: 2, name: 'Shop', item: new URL('/shop', Astro.site ?? Astro.url).toString() },
    { '@type': 'ListItem', position: 3, name: product.name, item: Astro.url.href },
  ],
};
---

<BaseLayout
  title={product.name}
  description={`${product.name} from Maison Arden. ${product.description}`}
  ogImage={productImageUrl || '/og-image.jpg'}
  jsonLd={[productSchema, breadcrumbSchema]}
>
  <!-- BREADCRUMB -->
  <section class="shop-hero">
    <div class="shop-hero__inner">
      <div class="shop-hero__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <a href="/shop">Shop</a> &nbsp;/&nbsp; <span>{categoryName}</span>
      </div>
      <h2 class="shop-hero__title">{genderLabel} <em>{categoryName}</em></h2>
      <p class="shop-hero__sub">Considered {categoryName.toLowerCase()} in natural fibres — tailored in Italy and made to last a lifetime.</p>
    </div>
  </section>

  <!-- Boot data for client variant controller -->
  <script id="pdpBootData" type="application/json" set:html={bootData}></script>

  <!-- Main Product Detail -->
  <section class="pdp" aria-label="Product detail">
    <div class="pdp-gallery">
      <div class="pdp-thumbs" id="pdpThumbs">
        {productImages.map((img, idx) => (
          <button class={`pdp-thumb ${idx === 0 ? 'is-active' : ''}`} data-index={idx} data-src={getSrcString(img)} data-position="center center" aria-label={`View image ${idx + 1}`}>
            <Image src={img} alt="" width={78} height={104} />
          </button>
        ))}
      </div>
      <div class="pdp-main" id="pdpMain">
        {product.badge && <span class="pdp-badge">{product.badge}</span>}
        <Image 
          id="pdpMainImg" 
          src={productImages[0]} 
          alt={product.name} 
          width={600} 
          height={750} 
          class="pdp-main-img" 
          loading="eager"
        />
        <span class="pdp-counter"><span id="pdpCur">1</span> / {productImages.length}</span>
        <button class="pdp-arrow pdp-arrow--prev" id="pdpPrev" aria-label="Previous">
          <svg width="16" height="16" viewBox="0 0 18 18" fill="none">
            <path d="M11 3l-6 6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <button class="pdp-arrow pdp-arrow--next" id="pdpNext" aria-label="Next">
          <svg width="16" height="16" viewBox="0 0 18 18" fill="none">
            <path d="M7 3l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
      </div>
    </div>

    <div class="pdp-info">
      <div class="pdp-info__eyebrow">{product.category}</div>
      <h1 class="pdp-info__name">{product.name}</h1>
      {(avgRating > 0 || reviewCount > 0) && (
      <div class="pdp-info__rating">
        <span class="pdp-info__stars" data-rv-avgstars>{starStr(avgRating)}</span>
        <span data-rv-avg>{avgRating.toFixed(1)}</span> · <a href="#reviews" style="color:inherit;text-decoration:underline"><span data-rv-count>{reviewCount}</span> reviews</a>
      </div>
      )}
      <div class="pdp-info__price">
        <span id="pdpPrice">{product.formattedPrice}</span>
        <s id="pdpComparePrice" style="display:none"></s>
        <span class="pdp-info__save" id="pdpSaveBadge" style="display:none"></span>
      </div>
      <div class="pdp-stock" id="pdpStockBadge" data-stock="in"></div>
      <div class="pdp-rule"></div>
      <p class="pdp-info__desc">{product.description}</p>
      
      <div class="pdp-info__meta">
        {product.materials.length > 0 && (
          <span>
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M2 8l3 3 9-9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {product.materials.map(m => m.charAt(0).toUpperCase() + m.slice(1)).join(' & ')}
          </span>
        )}
        <span>
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M8 1l2 4.5 5 .5-3.7 3.3L12 14 8 11.5 4 14l.7-4.7L1 6l5-.5L8 1z" stroke="currentColor" stroke-linejoin="round" />
          </svg> 
          Lifetime Repairs
        </span>
      </div>

      <!-- Color Swatches -->
      {product.swatches && product.swatches.length > 0 && (
        <div class="pdp-field">
          <div class="pdp-field__head">
            <span class="pdp-field__label">Colour</span>
            <span class="pdp-field__value" id="pdpColorVal">{product.swatches[0].color}</span>
          </div>
          <div class="pdp-colors" id="pdpColors">
            {product.swatches.map((sw, idx) => (
              <button 
                class={`pdp-color ${idx === 0 ? 'is-active' : ''}`}
                data-color={sw.color}
                style={`background: ${sw.hex}`}
                aria-label={sw.color}
              />
            ))}
          </div>
        </div>
      )}

      <!-- Sizes Selector -->
      {product.sizes && product.sizes.length > 0 && (
        <div class="pdp-field">
          <div class="pdp-field__head">
            <span class="pdp-field__label">Size</span>
            <button class="pdp-field__link" id="sizeGuideBtn">Size Guide</button>
          </div>
          <div class="pdp-sizes" id="pdpSizes">
            {product.sizes.map((sz, idx) => {
              // Out of stock driven by the real variant matrix, not a hardcoded
              // size. With no variant data, nothing is force-disabled.
              const isOOS = availableSizes.size > 0 && !availableSizes.has(sz.toLowerCase());
              return (
                <button 
                  class={`pdp-size ${!isOOS && idx === 0 ? 'is-active' : ''} ${isOOS ? 'is-oos' : ''}`}
                  data-size={sz}
                  disabled={isOOS}
                >
                  {sz.toUpperCase()}
                </button>
              );
            })}
          </div>
          <div class="pdp-sizeguide" id="pdpSizeGuide">
            <div class="pdp-sizeguide__inner">
              <table>
                <thead>
                  <tr>
                    <th>Size</th>
                    <th>Bust</th>
                    <th>Waist</th>
                    <th>Length</th>
                  </tr>
                </thead>
                <tbody>
                  <tr><td>XS</td><td>82</td><td>64</td><td>96</td></tr>
                  <tr><td>S</td><td>86</td><td>68</td><td>98</td></tr>
                  <tr><td>M</td><td>90</td><td>72</td><td>100</td></tr>
                  <tr><td>L</td><td>94</td><td>76</td><td>102</td></tr>
                  <tr><td>XL</td><td>98</td><td>80</td><td>104</td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      )}

      <!-- Quantity, Add to Bag and Wishlist Actions -->
      <div class="pdp-buy">
        <div class="pdp-qty">
          <button class="pdp-qty__btn" id="pdpMinus" aria-label="Decrease">&minus;</button>
          <span class="pdp-qty__val" id="pdpQty">1</span>
          <button class="pdp-qty__btn" id="pdpPlus" aria-label="Increase">+</button>
        </div>
        <button 
          class="btn-dark pdp-add" 
          id="pdpMainAddBtn"
          data-add-bag
          data-product-id={product.id}
          data-product-name={product.name}
          data-product-price={product.price}
          data-product-image={product.image}
        >
          Add to Bag &mdash; {product.formattedPrice}
        </button>
        <button 
          class="pdp-wish" 
          id="pdpMainWishBtn" 
          aria-label="Save" 
          aria-pressed="false"
          data-product-id={product.id}
          data-wish-add
        >
          <svg width="18" height="18" viewBox="0 0 22 22" fill="none">
            <path d="M11 19S3 14 3 8.3C3 5.5 5.2 3.5 8 3.5c1.6 0 3 .8 4 2 1-1.2 2.4-2 4-2 2.8 0 5 2 5 4.8C21 14 13 19 11 19z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
          </svg>
        </button>
      </div>

      <!-- Trust Badges -->
      <div class="pdp-trust">
        <span class="pdp-trust__item">
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
            <path d="M2 6h12l-1 7H3L2 6z" stroke="currentColor" stroke-linejoin="round" />
            <path d="M5.5 6V4a2.5 2.5 0 0 1 5 0v2" stroke="currentColor" stroke-linecap="round" />
          </svg> 
          Complimentary shipping
        </span>
        <span class="pdp-trust__item">
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
            <path d="M5 9h7a3 3 0 0 0 0-6H6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M7 6L5 9l2 3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
          </svg> 
          30-day easy returns
        </span>
        <span class="pdp-trust__item">
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
            <circle cx="8" cy="8" r="6.5" stroke="currentColor" />
            <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
          </svg> 
          In stock &mdash; ships in 48h
        </span>
      </div>

      <!-- Accordion Details -->
      <div class="pdp-acc">
        <div class="pdp-acc__item is-open">
          <button class="pdp-acc__toggle">Details <span class="pdp-acc__icon"></span></button>
          <div class="pdp-acc__body">
            <div class="pdp-acc__content">
              A signature piece reflecting Maison Arden's commitment to quiet editorial refinement. Designed with a structured shoulder, gentle fluid drape, and timeless silhouette intended to form the anchor of a multi-season wardrobe.
            </div>
          </div>
        </div>
        {product.materialsCare && product.materialsCare.length > 0 && (
          <div class="pdp-acc__item">
            <button class="pdp-acc__toggle">Materials & Care <span class="pdp-acc__icon"></span></button>
            <div class="pdp-acc__body">
              <div class="pdp-acc__content">
                <ul>
                  {product.materialsCare.map((line) => <li>{line}</li>)}
                </ul>
              </div>
            </div>
          </div>
        )}
        {product.shippingReturns && product.shippingReturns.length > 0 && (
          <div class="pdp-acc__item">
            <button class="pdp-acc__toggle">Shipping & Returns <span class="pdp-acc__icon"></span></button>
            <div class="pdp-acc__body">
              <div class="pdp-acc__content">
                {product.shippingReturns.join(' ')}
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Interactive Customer Reviews Section -->
  <section class="reviews" id="reviews" aria-label="Customer reviews">
    <div class="reviews__inner">
      <div class="reviews__head">
        <span class="eyebrow eyebrow--center">Customer Reviews</span>
        <h2 class="section-title">What Our <em>Clients Say</em></h2>
      </div>
      <div class="reviews__top">
        <!-- Average Score Card -->
        <div class="rsum">
          <span class="rsum__label">Overall Rating</span>
          <div class="rsum__avgrow">
            <span class="rsum__avg"><span data-rv-avg>{avgRating.toFixed(1)}</span></span>
            <div>
              <div class="rsum__stars" data-rv-avgstars>{starStr(avgRating)}</div>
              <div class="rsum__count">Based on <span data-rv-count>{reviewCount}</span> reviews</div>
            </div>
          </div>
          <div class="rsum__bars" data-rv-bars hidden={realReviews.length === 0}></div>
          <div class="rsum__rec" data-rv-rec-wrap hidden={realReviews.length === 0}>
            <span class="rsum__rec-num" data-rv-rec>0%</span>
            <span class="rsum__rec-txt">of clients would recommend this piece to a friend</span>
          </div>
          <button class="btn-dark rsum__cta" data-review-toggle>Write a Review</button>
          <div class="rsum__note">
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
              <path d="M7 1l1.6 3.4L12 5l-2.6 2.4L10 11 7 9.2 4 11l.6-3.6L2 5l3.4-.6L7 1z" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round" />
            </svg> 
            Every review is from a verified buyer
          </div>
        </div>

        <div class="reviews__main">
          <!-- Inline Form -->
          <div class="rform-wrap" data-rform-wrap>
            <form class="rform" id="reviewForm" novalidate>
              <h3 class="rform__title">Write a Review</h3>
              <p class="rform__sub">Share your experience with this piece. Your feedback helps others choose well.</p>
              <p class="rform__err" data-rform-err>Please add a rating, your name and a short review.</p>
              <p class="rform__success" data-rform-success>Thanks — your review was submitted and will appear once it's approved.</p>
              <div class="rform__field">
                <span class="rform__label">Your Rating</span>
                 <div class="rform__stars" id="rformStars">
                   <button type="button" class="rstar" data-val="1" aria-label="1 star">&#9733;</button>
                   <button type="button" class="rstar" data-val="2" aria-label="2 stars">&#9733;</button>
                   <button type="button" class="rstar" data-val="3" aria-label="3 stars">&#9733;</button>
                   <button type="button" class="rstar" data-val="4" aria-label="4 stars">&#9733;</button>
                   <button type="button" class="rstar" data-val="5" aria-label="5 stars">&#9733;</button>
                 </div>
              </div>
              <div class="rform__grid">
                <div class="rform__field">
                  <label class="rform__label" for="rvName">Name</label>
                  <input id="rvName" type="text" placeholder="Your name" required />
                </div>
                <div class="rform__field">
                  <label class="rform__label" for="rvEmail">Email</label>
                  <input id="rvEmail" type="email" placeholder="you@example.com" required />
                </div>
              </div>
              <div class="rform__field">
                <label class="rform__label" for="rvTitle">Title</label>
                <input id="rvTitle" type="text" placeholder="Sum it up in a few words" required />
              </div>
              <div class="rform__field">
                <label class="rform__label" for="rvBody">Review</label>
                <textarea id="rvBody" placeholder="What did you think of the fit, quality and feel?" required minlength="10"></textarea>
              </div>
              <div class="rform__actions">
                <button type="submit" class="btn-dark">Submit Review</button>
                <button type="button" class="rform__cancel" data-review-cancel>Cancel</button>
              </div>
            </form>
          </div>

          <!-- Reviews List — real reviews only, fetched from Judge.me -->
          <div class="rlist" id="rList">
            {realReviews.length > 0 ? realReviews.map((rev) => (
              <article class="ritem" data-rating={rev.rating}>
                <div class="ritem__head">
                  <div class="ritem__avatar">{initials(rev.author)}</div>
                  <div class="ritem__who">
                    <div class="ritem__name">{rev.author}</div>
                  </div>
                  <div class="ritem__right">
                    <div class="ritem__stars">{"★".repeat(rev.rating)}{"☆".repeat(5 - rev.rating)}</div>
                    {rev.date && <div class="ritem__date">{rev.date}</div>}
                  </div>
                </div>
                {rev.title && <h3 class="ritem__title">{rev.title}</h3>}
                {rev.body && <p class="ritem__body">{rev.body}</p>}
                <div class="ritem__foot">
                  <span class="ritem__foot-q">Was this helpful?</span>
                  <button class="ritem__helpful" data-helpful="0">
                    <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
                      <path d="M5 7l3-4c.9 0 1.5.8 1.3 1.7L9 6h3.2c.8 0 1.4.8 1.2 1.6l-1 4c-.1.7-.8 1.2-1.5 1.2H5V7z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" />
                      <rect x="2" y="7" width="3" height="6" stroke="currentColor" stroke-width="1.2" />
                    </svg>
                    Helpful (<span data-help-count>0</span>)
                  </button>
                </div>
              </article>
            )) : (
              <p class="rlist__empty" data-rlist-empty>No reviews yet — be the first to share your experience.</p>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Products (You May Also Like) -->
  <section class="pdp-related" id="related" aria-label="You may also like">
    <div class="pdp-related__inner">
      <div class="pdp-related__head">
        <div class="reveal">
          <span class="eyebrow">Complete the Look</span>
          <h2 class="section-title" style="margin-top:14px;">You May Also <em>Like</em></h2>
        </div>
        <a href="/shop" class="btn-dark reveal d1">
          View All 
          <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
            <path d="M1 5h12m0 0L9 1m4 4L9 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
          </svg>
        </a>
      </div>
      <div class="pdp-related__grid">
        {related.map((prod) => (
          <ProductCard product={prod} />
        ))}
      </div>
    </div>
  </section>

  <!-- NEWSLETTER CTA -->
  <section class="news" id="newsletter" aria-label="Newsletter">
    <div class="news__inner">
      <div class="news__card reveal">
        <span class="news__ghost" aria-hidden="true">Arden</span>
        <div class="news__left">
          <span class="news__eyebrow">The Maison Letter</span>
          <h2 class="news__title">Considered style, <em>in your inbox.</em></h2>
          <p class="news__sub">Be first to see new collections, atelier stories and seasonal lookbooks — thoughtfully sent, never noisy.</p>
        </div>
        <div class="news__right">
          <form class="news__form" onsubmit="return false;">
            <input class="news__input" type="email" placeholder="Your email address" aria-label="Email" required />
            <button class="news__btn" type="submit">Subscribe</button>
          </form>
          <div class="news__benefits">
            <span class="news__benefit">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Early Access
            </span>
            <span class="news__benefit">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Member Events
            </span>
            <span class="news__benefit">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                <path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg> 
              Seasonal Lookbooks
            </span>
          </div>
          <p class="news__note">By subscribing you agree to our Privacy Policy. Unsubscribe anytime.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { addToCart, toggleWishlist, persistedWishItems, isCartOpen } from '../../stores/cart';

  const $ = (s: string, c: any = document) => c.querySelector(s);
  const $$ = (s: string, c: any = document) => Array.from(c.querySelectorAll(s));

  // ---- Read Shopify variant boot data ----
  interface VariantData {
    id: string;
    opts: Record<string, string>;
    price: number;
    compareAt: number | null;
    available: boolean;
    qty: number | null;
    img: string | null;
  }
  interface BootData {
    currency: string;
    variants: VariantData[];
    singleVariant: boolean;
    productId: string | null;
  }
  let bootData: BootData = { currency: 'EUR', variants: [], singleVariant: true, productId: null };
  try {
    const bootEl = document.getElementById('pdpBootData');
    if (bootEl?.textContent) bootData = JSON.parse(bootEl.textContent);
  } catch {}
  const { variants, singleVariant } = bootData;
  const currencyCode = bootData.currency;
  const fmt = new Intl.NumberFormat('en-US', { style: 'currency', currency: currencyCode, minimumFractionDigits: 0 });
  const money = (n: number) => fmt.format(n);

  // ---- Selection state ----
  const selected: Record<string, string> = {};
  const baseVariant = variants.find(v => v.available) ?? variants[0];
  if (baseVariant) Object.assign(selected, baseVariant.opts);
  let qty = 1;

  const sameOptionValue = (a: string, b: string) => (a ?? '').toLowerCase() === (b ?? '').toLowerCase();

  function currentVariant(): VariantData | undefined {
    if (singleVariant || variants.length === 0) return baseVariant;
    return variants.find(v => Object.keys(selected).every(k => sameOptionValue(v.opts[k], selected[k])));
  }

  // ---- Render price / availability / stock badge ----
  function renderVariantState() {
    const v = currentVariant();
    // No variant matches the current option combo (and it's not a single-variant
    // product) → treat as unavailable rather than falling back to a wrong price.
    const invalidCombo = !v && !singleVariant && variants.length > 0;
    const price = v?.price ?? (baseVariant?.price ?? 0);
    const compareAt = v?.compareAt ?? null;
    const available = invalidCombo ? false : (v?.available ?? true); // fallback true for mock data
    const onSale = compareAt != null && compareAt > price;

    // Update price display
    const priceEl = $('#pdpPrice');
    if (priceEl) priceEl.textContent = money(price);

    // Update sale price
    const comparEl = $('#pdpComparePrice');
    const saveEl = $('#pdpSaveBadge');
    if (comparEl) {
      comparEl.textContent = onSale && compareAt != null ? money(compareAt) : '';
      (comparEl as HTMLElement).style.display = onSale ? '' : 'none';
    }
    if (saveEl) {
      saveEl.textContent = onSale && compareAt != null ? `Save ${money(compareAt - price)}` : '';
      (saveEl as HTMLElement).style.display = onSale ? '' : 'none';
    }

    // Update Add to Bag button
    const addBtn = $('#pdpMainAddBtn') as HTMLButtonElement | null;
    if (addBtn) {
      addBtn.disabled = !available;
      const priceSpan = addBtn.querySelector('[data-btn-price]');
      if (priceSpan) priceSpan.textContent = money(price * qty);
      if (!priceSpan) addBtn.textContent = available ? `Add to Bag — ${money(price * qty)}` : (invalidCombo ? 'Unavailable' : 'Sold Out');
    }

    // Update stock badge
    const stockBadge = $('#pdpStockBadge');
    if (stockBadge) {
      const q = v?.qty ?? null;
      const label = !available
        ? 'Currently out of stock'
        : (q != null && q > 0 && q <= 10)
          ? `Only ${q} left — order soon`
          : 'In stock — ships today';
      stockBadge.textContent = label;
      (stockBadge as HTMLElement).dataset.stock = available ? (q != null && q <= 10 ? 'low' : 'in') : 'out';
    }

    // Swap the gallery to the selected variant's image (match ignoring query string).
    if (v?.img && thumbs && thumbs.length) {
      const bare = (u: string) => (u || '').split('?')[0];
      const target = thumbs.findIndex((t) => bare(t.dataset.src || '') === bare(v.img || ''));
      if (target >= 0 && target !== idx) show(target);
    }

    // Re-evaluate which sizes are still available for the current colour.
    updateOptionAvailability();
  }

  // ---- Option selection (colour + size) ----
  const colorBtns = $$('#pdpColors .pdp-color') as HTMLButtonElement[];
  const sizeBtns = $$('#pdpSizes .pdp-size') as HTMLButtonElement[];
  const colorVal = $('#pdpColorVal');

  colorBtns.forEach(c => c.addEventListener('click', () => {
    colorBtns.forEach(x => x.classList.remove('is-active'));
    c.classList.add('is-active');
    const colorName = c.getAttribute('data-color') || '';
    if (colorVal) colorVal.textContent = colorName;
    // Match against variant opts — try 'Color' and 'Colour'
    if (selected['Color'] !== undefined) selected['Color'] = colorName;
    else if (selected['Colour'] !== undefined) selected['Colour'] = colorName;
    else selected['Color'] = colorName;
    renderVariantState();
  }));

  sizeBtns.forEach(s => s.addEventListener('click', () => {
    if (s.classList.contains('is-oos') || s.disabled) return;
    sizeBtns.forEach(x => x.classList.remove('is-active'));
    s.classList.add('is-active');
    const sizeName = s.getAttribute('data-size') || '';
    selected['Size'] = sizeName.toUpperCase();
    renderVariantState();
  }));

  // Mark unavailable size/color combinations based on variant data
  function updateOptionAvailability() {
    if (singleVariant || variants.length === 0) return;
    sizeBtns.forEach(btn => {
      const size = (btn.getAttribute('data-size') || '').toUpperCase();
      const colorKey = Object.keys(selected).find(k => /colou?r/i.test(k));
      const trial = colorKey
        ? { [colorKey]: selected[colorKey], Size: size }
        : { Size: size };
      const hasAvailable = variants.some(v =>
        v.available && Object.keys(trial).every(k => sameOptionValue(v.opts[k], trial[k]))
      );
      if (!hasAvailable) {
        btn.classList.add('is-oos');
        btn.disabled = true;
      } else {
        btn.classList.remove('is-oos');
        btn.disabled = false;
      }
    });
  }

  // ---- Size guide open/close ----
  const sg = $('#pdpSizeGuide');
  const sgb = $('#sizeGuideBtn');
  if (sgb && sg) {
    sgb.addEventListener('click', () => sg.classList.toggle('is-open'));
  }

  // ---- Accordion toggling ----
  $$('.pdp-acc__toggle').forEach((t: Element) => t.addEventListener('click', () => {
    const item = t.closest('.pdp-acc__item');
    if (item) item.classList.toggle('is-open');
  }));

  // ---- Qty Selector ----
  const qtyVal = $('#pdpQty');
  let q = 1;
  const minusBtn = $('#pdpMinus');
  const plusBtn = $('#pdpPlus');

  if (minusBtn && qtyVal) {
    minusBtn.addEventListener('click', () => {
      if (q > 1) { q--; qty = q; qtyVal.textContent = String(q); renderVariantState(); }
    });
  }
  if (plusBtn && qtyVal) {
    plusBtn.addEventListener('click', () => {
      if (q < 9) { q++; qty = q; qtyVal.textContent = String(q); renderVariantState(); }
    });
  }

  // ---- Gallery ----
  const mainImg = $('#pdpMainImg') as HTMLImageElement | null;
  const thumbs = $$('#pdpThumbs .pdp-thumb') as HTMLButtonElement[];
  const curEl = $('#pdpCur');
  let idx = 0;

  function show(i: number) {
    if (!mainImg || thumbs.length === 0) return;
    idx = (i + thumbs.length) % thumbs.length;
    const t = thumbs[idx];
    mainImg.style.opacity = '0';
    setTimeout(() => {
      mainImg.src = t.dataset.src || '';
      const filter = t.dataset.filter || '';
      const pos = t.dataset.position || 'center center';
      mainImg.style.filter = '';
      mainImg.style.objectPosition = pos;
      if (filter === 'grayscale') mainImg.style.filter = 'grayscale(1)';
      else if (filter === 'sepia' || filter === 'atelier') mainImg.style.filter = 'sepia(0.2) contrast(1.05)';
      mainImg.style.opacity = '1';
    }, 180);
    thumbs.forEach((x, k) => x.classList.toggle('is-active', k === idx));
    if (curEl) curEl.textContent = String(idx + 1);
  }

  thumbs.forEach((t, k) => t.addEventListener('click', () => show(k)));
  const prev = $('#pdpPrev');
  const next = $('#pdpNext');
  if (prev) prev.addEventListener('click', () => show(idx - 1));
  if (next) next.addEventListener('click', () => show(idx + 1));

  // Arrow-key gallery navigation — skip while typing or when a drawer/modal is open.
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
    const el = document.activeElement as HTMLElement | null;
    if (el && /^(INPUT|TEXTAREA|SELECT)$/.test(el.tagName)) return;
    if (document.querySelector('#cartDrawer.is-open, #wishDrawer.is-open, #qvOverlay.is-open, .nav--left.is-open')) return;
    show(e.key === 'ArrowLeft' ? idx - 1 : idx + 1);
  });

  // Zoom on hover
  const zoomBox = $('#pdpMain');
  if (zoomBox && mainImg) {
    zoomBox.addEventListener('mouseenter', () => { mainImg.style.transform = 'scale(2)'; });
    zoomBox.addEventListener('mousemove', (e: MouseEvent) => {
      const r = zoomBox.getBoundingClientRect();
      mainImg.style.transformOrigin = `${((e.clientX - r.left) / r.width) * 100}% ${((e.clientY - r.top) / r.height) * 100}%`;
    });
    zoomBox.addEventListener('mouseleave', () => { mainImg.style.transform = ''; mainImg.style.transformOrigin = 'center'; });
  }

  // ---- Add to Bag (with real Shopify variant GID) ----
  const addBagBtn = $('#pdpMainAddBtn') as HTMLButtonElement | null;
  addBagBtn?.addEventListener('click', async (e: Event) => {
    e.preventDefault();
    const v = currentVariant();

    if (sizeBtns.length > 0) {
      const hasSizeSelected = sizeBtns.some(s => s.classList.contains('is-active'));
      if (!hasSizeSelected) { alert('Please select a size'); return; }
    }

    // Use real Shopify variant ID from boot data
    const variantId = v?.id;
    if (!variantId) { alert('Could not determine variant. Please refresh.'); return; }

    // Lock button during async
    addBagBtn.disabled = true;
    const origText = addBagBtn.textContent;
    addBagBtn.textContent = 'Adding...';

    const selectedColorBtn = $('#pdpColors .pdp-color.is-active');
    const selectedSizeBtn = $('#pdpSizes .pdp-size.is-active');
    const selectedColor = selectedColorBtn ? selectedColorBtn.getAttribute('data-color') || undefined : undefined;
    const selectedSize = selectedSizeBtn ? selectedSizeBtn.getAttribute('data-size') || undefined : undefined;

    await addToCart({
      id: variantId,
      name: document.querySelector('.pdp-info__name')?.textContent || '',
      price: v.price,
      image: mainImg?.src || '',
      color: selectedColor,
      size: selectedSize,
      description: window.location.pathname.split('/products/')[1] || '',
    }, q);

    // Show success state
    addBagBtn.textContent = '✓ Added';
    isCartOpen.set(true);
    setTimeout(() => {
      addBagBtn.textContent = origText;
      addBagBtn.disabled = false;
    }, 1500);
  });

  // ---- Wishlist Toggle ----
  const wishBtn = $('#pdpMainWishBtn');
  if (wishBtn) {
    const variantIdForWish = wishBtn.getAttribute('data-product-id') || '';
    persistedWishItems.subscribe((items: any[]) => {
      const isSaved = items.some(i => i.id === variantIdForWish);
      wishBtn.setAttribute('aria-pressed', String(isSaved));
      wishBtn.classList.toggle('is-active', isSaved);
    });
    wishBtn.addEventListener('click', (e: Event) => {
      e.preventDefault();
      const v = currentVariant();
      const selectedColorBtn = $('#pdpColors .pdp-color.is-active');
      const selectedSizeBtn = $('#pdpSizes .pdp-size.is-active');
      toggleWishlist({
        id: v?.id || variantIdForWish,
        name: document.querySelector('.pdp-info__name')?.textContent || '',
        price: v?.price ?? 0,
        image: mainImg?.src || '',
        color: selectedColorBtn?.getAttribute('data-color') || undefined,
        size: selectedSizeBtn?.getAttribute('data-size') || undefined,
      });
    });
  }

  // ---- REVIEWS ----
  const reviewsSection = $('#reviews');
  if (reviewsSection) {
    const list = $('#rList');
    const starStr = (n: number) => '★'.repeat(n) + '☆'.repeat(5 - n);

    function renderSummary() {
      if (!list) return;
      // Locally-inserted pending reviews (awaiting Judge.me moderation) are
      // excluded from the aggregate — that number is real Shopify metafield
      // data and shouldn't move until Judge.me actually approves the review.
      const items = $$('.ritem:not([data-pending])', list);
      const total = items.length;
      const ratings = items.map((i: any) => +(i as HTMLElement).dataset.rating || 0);
      const avgstarsEls = $$('[data-rv-avgstars]');
      const recEl = $('[data-rv-rec]');
      const barsEl = $('[data-rv-bars]');
      // Only recompute avg/count from the rendered review list when there ARE
      // real reviews — otherwise leave the server-rendered aggregate rating
      // (from Shopify's reviews.rating metafield) alone instead of zeroing it.
      if (total > 0) {
        const avg = ratings.reduce((a: number, b: number) => a + b, 0) / total;
        $$('[data-rv-avg]').forEach((e: any) => (e.textContent = avg.toFixed(1)));
        $$('[data-rv-count]').forEach((e: any) => (e.textContent = String(total)));
        avgstarsEls.forEach((e: any) => (e.textContent = starStr(Math.round(avg))));
      }
      const recWrap = $('[data-rv-rec-wrap]');
      if (total > 0) {
        if (recWrap) (recWrap as HTMLElement).hidden = false;
        if (barsEl) (barsEl as HTMLElement).hidden = false;
      }
      const rec = total ? Math.round(ratings.filter((r: number) => r >= 4).length / total * 100) : 0;
      if (recEl) recEl.textContent = rec + '%';
      if (barsEl) {
        barsEl.innerHTML = '';
        for (let s = 5; s >= 1; s--) {
          const c = ratings.filter((r: number) => r === s).length;
          const pct = total ? Math.round(c / total * 100) : 0;
          barsEl.insertAdjacentHTML('beforeend',
            `<div class="rbar"><span class="rbar__label">${s} ★</span><span class="rbar__track"><span class="rbar__fill" style="width:${pct}%"></span></span><span class="rbar__pct">${pct}%</span></div>`
          );
        }
      }
    }

    const formWrap = $('[data-rform-wrap]');
    $$('[data-review-toggle]').forEach((b: any) => b.addEventListener('click', () => {
      if (formWrap) {
        formWrap.classList.toggle('is-open');
        if (formWrap.classList.contains('is-open')) {
          rSuccess?.classList.remove('is-shown');
          rErr?.classList.remove('is-shown');
          formWrap.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }
    }));
    $$('[data-review-cancel]').forEach((b: any) => b.addEventListener('click', () => { if (formWrap) formWrap.classList.remove('is-open'); }));

    let rating = 0;
    const starBtns = $$('#rformStars .rstar') as HTMLButtonElement[];
    const paint = (n: number) => starBtns.forEach((b, i) => b.classList.toggle('is-on', i < n));
    starBtns.forEach((b, i) => {
      b.addEventListener('mouseenter', () => paint(i + 1));
      b.addEventListener('click', () => { rating = i + 1; paint(rating); });
    });
    const starContainer = $('#rformStars');
    if (starContainer) starContainer.addEventListener('mouseleave', () => paint(rating));

    const HELP = '<svg width="13" height="13" viewBox="0 0 16 16" fill="none"><path d="M5 7l3-4c.9 0 1.5.8 1.3 1.7L9 6h3.2c.8 0 1.4.8 1.2 1.6l-1 4c-.1.7-.8 1.2-1.5 1.2H5V7z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/><rect x="2" y="7" width="3" height="6" stroke="currentColor" stroke-width="1.2"/></svg>';
    const esc = (t: string) => t.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    const getInitials = (n: string) => {
      const parts = n.trim().split(/\s+/).filter(Boolean);
      return (parts.length > 1 ? parts[0][0] + parts[parts.length - 1][0] : n.slice(0, 2)).toUpperCase();
    };

    function addPendingReview(input: { rating: number; title: string; body: string; name: string }) {
      if (!list) return;
      const emptyState = $('[data-rlist-empty]');
      emptyState?.remove();
      const html = `
        <article class="ritem" data-rating="${input.rating}" data-pending="1">
          <div class="ritem__head">
            <div class="ritem__avatar">${esc(getInitials(input.name))}</div>
            <div class="ritem__who">
              <div class="ritem__name">${esc(input.name)}</div>
              <span class="ritem__pending-badge">Pending approval</span>
            </div>
            <div class="ritem__right">
              <div class="ritem__stars">${'★'.repeat(input.rating)}${'☆'.repeat(5 - input.rating)}</div>
            </div>
          </div>
          ${input.title ? `<h3 class="ritem__title">${esc(input.title)}</h3>` : ''}
          <p class="ritem__body">${esc(input.body)}</p>
        </article>`;
      list.insertAdjacentHTML('afterbegin', html);
    }

    const rForm = $('#reviewForm') as HTMLFormElement | null;
    const rErr = $('[data-rform-err]') as HTMLElement | null;
    const rSuccess = $('[data-rform-success]') as HTMLElement | null;
    const showErr = (msg: string) => {
      if (rSuccess) rSuccess.classList.remove('is-shown');
      if (rErr) { rErr.textContent = msg; rErr.classList.add('is-shown'); }
    };
    if (rForm) {
      rForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (rErr) rErr.classList.remove('is-shown');
        // Inputs use ids (rvName/rvEmail/rvTitle/rvBody), not name attributes.
        const name = ($('#rvName') as HTMLInputElement | null)?.value.trim() || '';
        const email = ($('#rvEmail') as HTMLInputElement | null)?.value.trim() || '';
        const title = ($('#rvTitle') as HTMLInputElement | null)?.value.trim() || '';
        const comment = ($('#rvBody') as HTMLTextAreaElement | null)?.value.trim() || '';
        if (!rating || !name || !email || !comment) {
          showErr('Please add a rating, your name, email and a short review.');
          return;
        }
        const submitBtn = rForm.querySelector('button[type="submit"]') as HTMLButtonElement | null;
        if (submitBtn) submitBtn.disabled = true;
        try {
          const res = await fetch('/api/reviews', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ productId: bootData.productId, rating, title, body: comment, name, email }),
          });
          const result = await res.json();
          if (!result.ok) {
            showErr(result.error || 'Could not submit the review — please try again.');
            return;
          }
          addPendingReview({ rating, title, body: comment, name });
          if (rSuccess) rSuccess.classList.add('is-shown');
          rForm.reset();
          rating = 0;
          paint(0);
          if (formWrap) formWrap.classList.remove('is-open');
        } catch {
          showErr('Could not reach the reviews service — please try again.');
        } finally {
          if (submitBtn) submitBtn.disabled = false;
        }
      });
    }
    $$('[data-helpful]').forEach((b: any) => b.addEventListener('click', function (this: HTMLElement) {
      const c = parseInt(this.dataset.helpful || '0', 10) + 1;
      this.dataset.helpful = String(c);
      this.innerHTML = `${HELP} Helpful (${c})`;
    }));
    renderSummary();
  }

  // ---- Scroll Reveal ----
  const rev = $$('.reveal');
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
    }, { threshold: 0.12 });
    rev.forEach((el: Element) => io.observe(el));
  } else {
    rev.forEach((el: Element) => el.classList.add('in'));
  }

  // ---- Init ----
  updateOptionAvailability();
  renderVariantState();
</script>

<style>
  /* ============ SHOP HERO BREADCRUMB ============ */
  .shop-hero {
    background: var(--lux-light-surface);
    border-bottom: 1px solid var(--lux-light-border);
  }

  .shop-hero__inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(40px, 5vw, 72px) var(--gutter) clamp(34px, 4vw, 56px);
    text-align: center;
  }

  .shop-hero__crumb {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--lux-on-light-soft);
    margin-bottom: 16px;
  }

  .shop-hero__crumb a {
    color: var(--lux-on-light-soft);
    transition: color .2s var(--ease);
  }

  .shop-hero__crumb a:hover {
    color: var(--lux-on-light);
  }

  .shop-hero__crumb span {
    color: var(--lux-secondary-olive);
  }

  .shop-hero__title {
    font-family: var(--font-display);
    font-size: clamp(40px, 5vw, 72px);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -1.5px;
    color: var(--lux-on-light);
  }

  .shop-hero__title em {
    font-style: italic;
    color: var(--lux-secondary-olive);
  }

  .shop-hero__sub {
    font-size: clamp(14px, 1.05vw, 16px);
    line-height: 1.7;
    color: var(--lux-on-light-soft);
    max-width: 56ch;
    margin: 16px auto 0;
  }

  /* Scoped layout and component definitions for Luxury Product Detail Page */
  .pdp {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(24px, 3vw, 44px) var(--gutter) var(--section-y);
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(32px, 4vw, 80px);
    align-items: start;
  }

  /* Gallery Column */
  .pdp-gallery {
    display: grid;
    grid-template-columns: 78px 1fr;
    gap: 14px;
    position: sticky;
    top: 92px;
  }

  .pdp-thumbs {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .pdp-thumb {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    border: 1px solid var(--lux-light-border);
    background: var(--lux-light-surface);
    cursor: pointer;
    opacity: .55;
    transition: opacity .25s var(--ease), border-color .25s var(--ease);
    padding: 0;
  }

  .pdp-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pdp-thumb:hover {
    opacity: .85;
  }

  .pdp-thumb.is-active {
    opacity: 1;
    border-color: var(--lux-primary-dark);
  }

  .pdp-main {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
    background: var(--lux-light-surface);
    cursor: zoom-in;
  }

  .pdp-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .25s var(--ease-soft), opacity .35s var(--ease);
  }

  .pdp-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    z-index: 3;
    padding: 6px 13px;
    background: var(--lux-primary-dark);
    color: var(--lux-accent-lime);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.4px;
    text-transform: uppercase;
  }

  .pdp-counter {
    position: absolute;
    bottom: 16px;
    right: 16px;
    z-index: 3;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--lux-text-primary);
    background: rgba(23, 26, 21, .55);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    padding: 6px 12px;
  }

  .pdp-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    background: rgba(252, 252, 248, .9);
    color: var(--lux-on-light);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transition: opacity .3s var(--ease), background .25s var(--ease);
  }

  .pdp-main:hover .pdp-arrow {
    opacity: 1;
  }

  .pdp-arrow:hover {
    background: var(--lux-primary-dark);
    color: var(--lux-text-primary);
  }

  .pdp-arrow--prev {
    left: 14px;
  }

  .pdp-arrow--next {
    right: 14px;
  }

  /* Info Column Styling */
  .pdp-info {
    position: sticky;
    top: 92px;
  }

  .pdp-info__eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--lux-on-light-soft);
  }

  .pdp-info__name {
    font-family: var(--font-display);
    font-size: clamp(34px, 4vw, 56px);
    font-weight: 500;
    line-height: 1.02;
    letter-spacing: -1.3px;
    color: var(--lux-on-light);
    margin: 14px 0 0;
  }

  .pdp-info__rating {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 16px;
    font-size: 13px;
    color: var(--lux-on-light-soft);
  }

  .pdp-info__stars {
    color: var(--lux-secondary-olive);
    letter-spacing: 2px;
  }

  .pdp-info__price {
    font-size: 22px;
    font-weight: 500;
    color: var(--lux-on-light);
    margin-top: 18px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .pdp-info__price s {
    color: var(--lux-on-light-soft);
    font-weight: 400;
    font-size: 17px;
  }

  .pdp-info__price .pdp-info__save {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .6px;
    text-transform: uppercase;
    color: #B0492F;
  }

  .pdp-stock {
    margin-top: 10px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .4px;
    color: var(--lux-secondary-olive);
  }

  .pdp-stock:empty {
    display: none;
  }

  .pdp-stock[data-stock="low"] {
    color: #B0492F;
  }

  .pdp-stock[data-stock="out"] {
    color: var(--lux-on-light-soft);
  }

  .pdp-rule {
    height: 1px;
    background: var(--lux-light-border);
    margin: 26px 0;
  }

  .pdp-info__desc {
    font-size: 15px;
    line-height: 1.8;
    color: var(--lux-on-light-soft);
    margin: 0;
    max-width: 52ch;
  }

  .pdp-info__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 22px;
    margin-top: 18px;
  }

  .pdp-info__meta span {
    font-size: 12px;
    letter-spacing: .4px;
    color: var(--lux-on-light-soft);
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }

  .pdp-info__meta svg {
    color: var(--lux-secondary-olive);
  }

  .pdp-field {
    margin-top: 28px;
  }

  .pdp-field__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  .pdp-field__label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--lux-on-light);
  }

  .pdp-field__value {
    font-size: 12px;
    color: var(--lux-on-light-soft);
  }

  .pdp-field__link {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .6px;
    text-transform: uppercase;
    color: var(--lux-secondary-olive);
    background: none;
    border: none;
    cursor: pointer;
    border-bottom: 1px solid var(--lux-secondary-olive);
    padding-bottom: 1px;
  }

  .pdp-colors {
    display: flex;
    gap: 12px;
  }

  .pdp-color {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 1px solid var(--lux-light-border-strong);
    cursor: pointer;
    outline: 2px solid transparent;
    outline-offset: 3px;
    transition: outline-color .2s var(--ease), transform .2s var(--ease);
  }

  .pdp-color:hover {
    transform: scale(1.08);
  }

  .pdp-color.is-active {
    outline-color: var(--lux-primary-dark);
  }

  .pdp-sizes {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .pdp-size {
    min-width: 50px;
    padding: 12px 14px;
    border: 1px solid var(--lux-light-border-strong);
    background: transparent;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: .5px;
    color: var(--lux-on-light);
    cursor: pointer;
    transition: background .2s var(--ease), color .2s var(--ease), border-color .2s var(--ease);
  }

  .pdp-size:hover {
    border-color: var(--lux-primary-dark);
  }

  .pdp-size.is-active {
    background: var(--lux-primary-dark);
    color: var(--lux-text-primary);
    border-color: var(--lux-primary-dark);
  }

  .pdp-size.is-oos {
    color: var(--lux-light-border-strong);
    border-color: var(--lux-light-border);
    cursor: not-allowed;
    text-decoration: line-through;
  }

  /* Quantity and Buying Options */
  .pdp-buy {
    display: flex;
    gap: 12px;
    margin-top: 28px;
  }

  .pdp-qty {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--lux-light-border-strong);
    flex-shrink: 0;
  }

  .pdp-qty__btn {
    width: 46px;
    height: 100%;
    min-height: 52px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--lux-on-light);
    cursor: pointer;
    transition: background .2s var(--ease), color .2s var(--ease);
  }

  .pdp-qty__btn:hover {
    background: var(--lux-primary-dark);
    color: var(--lux-text-primary);
  }

  .pdp-qty__val {
    min-width: 40px;
    text-align: center;
    font-size: 14px;
    font-weight: 600;
    color: var(--lux-on-light);
  }

  .pdp-add {
    flex: 1;
    justify-content: center;
  }

  .pdp-wish {
    width: 54px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--lux-light-border-strong);
    background: transparent;
    color: var(--lux-on-light);
    cursor: pointer;
    transition: background .25s var(--ease), color .25s var(--ease), border-color .25s var(--ease);
  }

  .pdp-wish:hover {
    border-color: var(--lux-primary-dark);
  }

  .pdp-wish[aria-pressed="true"] {
    color: #B0492F;
    border-color: #B0492F;
  }

  .pdp-wish[aria-pressed="true"] svg {
    fill: currentColor;
  }

  /* Trust List styling */
  .pdp-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 14px 24px;
    margin-top: 26px;
    padding-top: 24px;
    border-top: 1px solid var(--lux-light-border);
  }

  .pdp-trust__item {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 12px;
    color: var(--lux-on-light-soft);
  }

  .pdp-trust__item svg {
    color: var(--lux-secondary-olive);
    flex-shrink: 0;
  }

  /* Accordions styling */
  .pdp-acc {
    margin-top: 30px;
    border-top: 1px solid var(--lux-light-border);
  }

  .pdp-acc__item {
    border-bottom: 1px solid var(--lux-light-border);
  }

  .pdp-acc__toggle {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 2px;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: .8px;
    text-transform: uppercase;
    color: var(--lux-on-light);
    font-family: var(--font-body);
  }

  .pdp-acc__icon {
    position: relative;
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }

  .pdp-acc__icon::before,
  .pdp-acc__icon::after {
    content: "";
    position: absolute;
    background: var(--lux-on-light);
    transition: transform .3s var(--ease), opacity .3s var(--ease);
  }

  .pdp-acc__icon::before {
    top: 5px;
    left: 0;
    width: 12px;
    height: 1.5px;
  }

  .pdp-acc__icon::after {
    left: 5px;
    top: 0;
    width: 1.5px;
    height: 12px;
  }

  .pdp-acc__item.is-open .pdp-acc__icon::after {
    opacity: 0;
    transform: scaleY(0);
  }

  .pdp-acc__body {
    overflow: hidden;
    max-height: 0;
    transition: max-height .4s var(--ease);
  }

  .pdp-acc__item.is-open .pdp-acc__body {
    max-height: 320px;
  }

  .pdp-acc__content {
    padding: 0 2px 22px;
    font-size: 14px;
    line-height: 1.75;
    color: var(--lux-on-light-soft);
  }

  .pdp-acc__content ul {
    margin: 0;
    padding-left: 18px;
  }

  .pdp-acc__content li {
    margin-bottom: 6px;
  }

  /* Size guide sliding grid */
  .pdp-sizeguide {
    overflow: hidden;
    max-height: 0;
    transition: max-height .4s var(--ease);
  }

  .pdp-sizeguide.is-open {
    max-height: 320px;
  }

  .pdp-sizeguide__inner {
    margin-top: 14px;
    border: 1px solid var(--lux-light-border);
    background: var(--lux-light-surface);
    padding: 16px;
  }

  .pdp-sizeguide table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
  }

  .pdp-sizeguide th,
  .pdp-sizeguide td {
    text-align: left;
    padding: 7px 6px;
    border-bottom: 1px solid var(--lux-light-border);
    color: var(--lux-on-light-soft);
  }

  .pdp-sizeguide th {
    color: var(--lux-on-light);
    font-weight: 600;
    letter-spacing: .5px;
    text-transform: uppercase;
    font-size: 10px;
  }

  /* ===== REVIEWS COMPONENT ===== */
  .reviews {
    background: var(--lux-light-bg);
    border-top: 1px solid var(--lux-light-border);
  }

  .reviews__inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: var(--section-y) var(--gutter);
  }

  .reviews__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 14px;
    margin-bottom: clamp(36px, 4vw, 56px);
  }

  .reviews__top {
    display: grid;
    grid-template-columns: 330px 1fr;
    gap: clamp(36px, 5vw, 80px);
    align-items: start;
  }

  .rsum {
    border: 1px solid var(--lux-light-border);
    background: var(--lux-light-surface);
    padding: clamp(26px, 2.8vw, 36px);
    position: sticky;
    top: 92px;
  }

  .rsum__label {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    color: var(--lux-on-light-soft);
    margin-bottom: 18px;
  }

  .rsum__label::before {
    content: "";
    width: 22px;
    height: 1px;
    background: var(--lux-secondary-olive);
  }

  .rsum__avgrow {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .rsum__avg {
    font-family: var(--font-display);
    font-size: 60px;
    line-height: .9;
    color: var(--lux-on-light);
  }

  .rsum__stars {
    color: var(--lux-secondary-olive);
    letter-spacing: 3px;
    font-size: 16px;
  }

  .rsum__count {
    font-size: 13px;
    color: var(--lux-on-light-soft);
    margin-top: 10px;
  }

  .rsum__bars {
    margin: 22px 0;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  /* Custom inner styles for bars */
  :global(.rbar) {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    color: var(--lux-on-light-soft);
  }

  :global(.rbar__label) {
    width: 32px;
    white-space: nowrap;
  }

  :global(.rbar__track) {
    flex: 1;
    height: 6px;
    background: var(--lux-light-bg);
    border: 1px solid var(--lux-light-border);
    position: relative;
  }

  :global(.rbar__fill) {
    position: absolute;
    inset: 0 auto 0 0;
    background: var(--lux-secondary-olive);
    transition: width .5s var(--ease);
  }

  :global(.rbar__pct) {
    width: 36px;
    text-align: right;
  }

  .rsum__rec {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 0;
    border-top: 1px solid var(--lux-light-border);
    border-bottom: 1px solid var(--lux-light-border);
    margin-bottom: 20px;
  }

  .rsum__rec-num {
    font-family: var(--font-display);
    font-size: 30px;
    line-height: 1;
    color: var(--lux-on-light);
    flex-shrink: 0;
  }

  .rsum__rec-txt {
    font-size: 12px;
    line-height: 1.5;
    color: var(--lux-on-light-soft);
  }

  .rsum__cta {
    width: 100%;
    justify-content: center;
  }

  .rsum__note {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    color: var(--lux-on-light-soft);
    margin-top: 16px;
  }

  .rsum__note svg {
    color: var(--lux-secondary-olive);
    flex-shrink: 0;
  }

  /* List & items */
  .rlist {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .rlist__empty {
    font-size: 13.5px;
    color: var(--lux-on-light-soft);
    padding: clamp(22px, 2.3vw, 32px);
    border: 1px dashed var(--lux-light-border);
    text-align: center;
  }

  /* :global — this list can also be built client-side (pending-review insert
     after submit), which produces plain HTML with no astro-cid scope attr. */
  :global(.ritem) {
    border: 1px solid var(--lux-light-border);
    background: var(--lux-light-surface);
    padding: clamp(22px, 2.3vw, 32px);
    transition: border-color .35s var(--ease), box-shadow .35s var(--ease), transform .35s var(--ease);
    animation: rIn .5s var(--ease) both;
  }

  :global(.ritem:hover) {
    border-color: var(--lux-light-border-strong);
    box-shadow: 0 26px 60px -48px rgba(48, 56, 44, .5);
    transform: translateY(-2px);
  }

  @keyframes rIn {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  :global(.ritem__head) {
    display: flex;
    align-items: center;
    gap: 13px;
  }

  :global(.ritem__avatar) {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: var(--lux-primary-dark);
    color: var(--lux-text-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 600;
    flex-shrink: 0;
  }

  :global(.ritem__who) {
    flex: 1;
    min-width: 0;
  }

  :global(.ritem__name) {
    font-size: 14px;
    font-weight: 600;
    color: var(--lux-on-light);
    display: flex;
    align-items: center;
    gap: 9px;
    flex-wrap: wrap;
  }

  :global(.ritem__pending-badge) {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--lux-secondary-olive, #4b5a3a);
    background: rgba(107, 112, 94, .08);
    border: 1px solid rgba(107, 112, 94, .25);
    padding: 3px 9px;
    border-radius: 2px;
    margin-top: 4px;
  }

  :global(.ritem__verified) {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .5px;
    text-transform: uppercase;
    color: var(--lux-secondary-olive);
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  :global(.ritem__loc) {
    font-size: 12px;
    color: var(--lux-on-light-soft);
    margin-top: 2px;
  }

  :global(.ritem__right) {
    text-align: right;
    flex-shrink: 0;
  }

  :global(.ritem__stars) {
    color: var(--lux-secondary-olive);
    letter-spacing: 2px;
    font-size: 13px;
  }

  :global(.ritem__date) {
    font-size: 11px;
    color: var(--lux-on-light-soft);
    margin-top: 3px;
  }

  :global(.ritem__title) {
    font-size: 15px;
    font-weight: 600;
    color: var(--lux-on-light);
    margin: 18px 0 7px;
  }

  :global(.ritem__body) {
    font-size: 14px;
    line-height: 1.72;
    color: var(--lux-on-light-soft);
    margin: 0;
    max-width: 72ch;
  }

  :global(.ritem__foot) {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 18px;
    padding-top: 16px;
    border-top: 1px solid var(--lux-light-border);
  }

  :global(.ritem__foot-q) {
    font-size: 12px;
    color: var(--lux-on-light-soft);
  }

  :global(.ritem__helpful) {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .4px;
    color: var(--lux-on-light-soft);
    background: none;
    border: 1px solid var(--lux-light-border-strong);
    padding: 7px 14px;
    cursor: pointer;
    transition: color .25s var(--ease), border-color .25s var(--ease), background .25s var(--ease);
  }

  :global(.ritem__helpful:hover) {
    border-color: var(--lux-primary-dark);
    color: var(--lux-on-light);
  }

  :global(.ritem__helpful.is-on) {
    border-color: var(--lux-secondary-olive);
    color: var(--lux-secondary-olive);
    background: rgba(107, 112, 94, .06);
  }

  :global(.ritem__helpful svg) {
    transition: transform .25s var(--ease);
  }

  :global(.ritem__helpful.is-on svg) {
    transform: translateY(-2px);
  }

  /* Interactive Form wrapper */
  .rform-wrap {
    max-height: 0;
    overflow: hidden;
    transition: max-height .5s var(--ease);
    margin-bottom: 16px;
  }

  .rform-wrap.is-open {
    max-height: 820px;
  }

  .rform {
    border: 1px solid var(--lux-light-border-strong);
    background: var(--lux-light-surface);
    padding: clamp(24px, 3vw, 38px);
  }

  .rform__title {
    font-family: var(--font-display);
    font-size: clamp(24px, 2.4vw, 32px);
    font-weight: 500;
    color: var(--lux-on-light);
    margin: 0 0 4px;
  }

  .rform__sub {
    font-size: 13px;
    color: var(--lux-on-light-soft);
    margin: 0 0 22px;
  }

  .rform__field {
    display: flex;
    flex-direction: column;
    gap: 7px;
    margin-bottom: 16px;
  }

  .rform__label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--lux-on-light);
  }

  .rform__stars {
    display: inline-flex;
    gap: 6px;
  }

  .rstar {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 26px;
    line-height: 1;
    color: var(--lux-light-border-strong);
    transition: color .15s var(--ease), transform .15s var(--ease);
    padding: 0;
  }

  .rstar:hover {
    transform: scale(1.12);
  }

  .rstar.is-on {
    color: var(--lux-secondary-olive);
  }

  .rform__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .rform input,
  .rform textarea {
    background: var(--lux-light-elevated);
    border: 1px solid var(--lux-light-border-strong);
    padding: 12px 14px;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--lux-on-light);
    outline: none;
    transition: border-color .2s var(--ease);
    width: 100%;
  }

  .rform input:focus,
  .rform textarea:focus {
    border-color: var(--lux-primary-dark);
  }

  .rform textarea {
    resize: vertical;
    min-height: 110px;
  }

  .rform__err {
    font-size: 12px;
    color: #B0492F;
    margin: 0 0 14px;
    display: none;
  }

  .rform__err.is-shown {
    display: block;
  }

  .rform__success {
    font-size: 12px;
    color: var(--lux-secondary-olive, #4b5a3a);
    margin: 0 0 14px;
    display: none;
  }

  .rform__success.is-shown {
    display: block;
  }

