{
  "name": "velvet",
  "type": "module",
  "version": "1.0.0",
  "description": "Maison Arden — a luxury-fashion Shopify headless storefront theme built with Astro SSR. Multi-market, localized pricing, cart/wishlist/compare, and a graceful mock-data mode.",
  "author": "Brandbes <hi@brandbes.com>",
  "license": "MIT",
  "homepage": "https://velvet.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Brandbes-Astro-Themes/velvet.git"
  },
  "keywords": [
    "astro",
    "astro-theme",
    "astro-template",
    "shopify",
    "headless-commerce",
    "ecommerce",
    "storefront",
    "luxury",
    "fashion",
    "ssr",
    "cloudflare"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:cloudflare": "astro build",
    "build:node": "astro build",
    "build:vercel": "astro build",
    "build:netlify": "astro build",
    "start:node": "node ./dist/server/entry.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "release:patch": "npm version patch -m \"chore: release %s\" && git push && git push --tags",
    "release:minor": "npm version minor -m \"chore: release %s\" && git push && git push --tags",
    "release:major": "npm version major -m \"chore: release %s\" && git push && git push --tags"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.2",
    "@astrojs/netlify": "^8.1.1",
    "@astrojs/node": "^11.0.2",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^11.0.2",
    "@nanostores/persistent": "^1.3.4",
    "@shopify/storefront-api-client": "^1.0.10",
    "astro": "^7.0.7",
    "nanostores": "^1.3.0",
    "wrangler": "4.104.0"
  },
  "overrides": {
    "bare-fs": "4.7.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "typescript": "^6.0.3"
  }
}
